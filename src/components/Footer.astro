---
import ContactInfo from './ContactInfo.astro';
---

<footer class="bg-carbon text-bone py-20 md:py-24 border-t-[3px] border-terracotta">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-16">

        <!-- Brand -->
        <div class="col-span-1">
          <img src="/yourhq-logo-white.png" alt="YourHQ" loading="lazy" decoding="async" class="h-20 w-auto mb-6" />
          <p class="font-sans text-sm text-bone/70 leading-relaxed">
            Founder-led websites for Kiwi small businesses.<br/>
            Built in Whangārei, servicing NZ-wide.
          </p>
          <div class="flex gap-5 mt-8">
            <a href="https://www.facebook.com/yourhqnz/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-softGrey hover:text-terracotta transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/yourhq_/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-softGrey hover:text-terracotta transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>

        <!-- Links -->
        <div>
          <h4 class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-6">Company</h4>
          <ul class="space-y-4 font-sans text-sm text-bone/80">
            <li><a href="/how-it-works" class="hover:text-white transition-colors duration-300 inline-block">How It Works</a></li>
            <li><a href="/pricing" class="hover:text-white transition-colors duration-300 inline-block">Pricing</a></li>
            <li><a href="/portfolio" class="hover:text-white transition-colors duration-300 inline-block">Portfolio</a></li>
            <li><a href="/our-story" class="hover:text-white transition-colors duration-300 inline-block">Our Story</a></li>
            <li><a href="/network" class="hover:text-white transition-colors duration-300 inline-block">YourHQ Network</a></li>
            <li><a href="/refer" class="hover:text-white transition-colors duration-300 inline-block">Refer a Friend</a></li>
          </ul>
          <h4 class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-6 mt-10">Also by Lian</h4>
          <ul class="space-y-4 font-sans text-sm text-bone/80">
            <li><a href="https://www.dreamstorm.org" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-300 inline-block">DreamStorm <span class="text-terracotta/80 font-serif italic text-[15px] ml-1">- Apps & AI</span></a></li>
          </ul>
        </div>

        <!-- Free Resources -->
        <div>
          <h4 class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-6">Free Resources</h4>
          <ul class="space-y-4 font-sans text-sm text-bone/80">
            <li><a href="/ecosystem" class="hover:text-white transition-colors duration-300 inline-block">Your Digital Ecosystem</a></li>
            <li><a href="/google-guide" class="hover:text-white transition-colors duration-300 inline-block">Get Found on Google <span class="text-terracotta/80 font-serif italic text-[15px] ml-1">- Free Guide</span></a></li>
            <li><a href="/guide" class="hover:text-white transition-colors duration-300 inline-block">5 Signs You Need a Website</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors duration-300 inline-block">Blog</a></li>
            <li><a href="/faq" class="hover:text-white transition-colors duration-300 inline-block">FAQ</a></li>
          </ul>
          <h4 class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-6 mt-10">Client Area</h4>
          <ul class="space-y-4 font-sans text-sm text-bone/80">
            <li><a href="/welcome" class="hover:text-white transition-colors duration-300 inline-block">Welcome <span class="text-terracotta/80 font-serif italic text-[15px] ml-1">- Onboarding</span></a></li>
            <li><a href="https://billing.stripe.com/p/login/00waEWh0S14s3xH4UzdZ600" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-300 inline-block">Manage Subscription <span class="text-terracotta/80 font-serif italic text-[15px] ml-1">- Customer Portal</span></a></li>
          </ul>
          <h4 class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-6 mt-10">Legal</h4>
          <ul class="space-y-4 font-sans text-sm text-bone/80">
            <li><a href="/legal" class="hover:text-white transition-colors duration-300 inline-block">Terms & FAQ</a></li>
            <li><a href="/privacy" class="hover:text-white transition-colors duration-300 inline-block">Privacy Policy</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="font-sans text-sm text-bone/80">
          <h4 class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-6">Contact</h4>
          <ContactInfo variant="footer" />
        </div>
      </div>

      <div class="border-t border-white/10 mt-20 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
        <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">&copy; {new Date().getFullYear()} YourHQ Limited.</p>
        <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">Fast builds. Long-term care.</p>
      </div>
    </div>
  </footer>