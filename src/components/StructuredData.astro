---
// Structured Data (JSON-LD) for SEO and AEO
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "YourHQ",
  "legalName": "YourHQ Limited",
  "url": "https://yourhq.co.nz",
  "logo": "https://yourhq.co.nz/favicon.svg",
  "foundingDate": "2024",
  "description": "Hand-coded, permanently owned websites for established business owners and personal brands. Founded in Aotearoa New Zealand. Clients worldwide.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Whangārei",
    "addressRegion": "Northland",
    "addressCountry": "NZ"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+64-22-172-5793",
    "contactType": "Customer Service",
    "email": "hello@yourhq.co.nz",
    "availableLanguage": "English"
  },
  "sameAs": [
    "https://www.facebook.com/yourhqnz",
    "https://www.instagram.com/yourhq_/",
    "https://www.linkedin.com/company/yourhq"
  ],
  "founder": {
    "@type": "Person",
    "name": "Lian Passmore"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "YourHQ",
  "image": "https://yourhq.co.nz/og-image.jpg",
  "priceRange": "$$",
  "telephone": "+64-22-172-5793",
  "email": "hello@yourhq.co.nz",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Whangārei",
    "addressRegion": "Northland",
    "addressCountry": "New Zealand"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -35.7253,
    "longitude": 174.3230
  },
  "url": "https://yourhq.co.nz",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "09:00",
    "closes": "17:00"
  }
};

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Website Design, Development, and Ongoing Care",
  "provider": {
    "@type": "Organization",
    "name": "YourHQ"
  },
  "areaServed": {
    "@type": "Country",
    "name": "New Zealand"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Website Build and Caretaker",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "The Build",
          "description": "Hand-coded website. Up to 8 pages. Written in your voice from one Drive-Home Interview. Includes blog and resources architecture, portfolio and case study layouts, media and press section, socials embed (Instagram, Facebook, Threads, X, LinkedIn), Google Business Profile setup or optimisation, enquiry form, basic email capture, SEO and AI search optimisation, stock or AI-optimised photos, domain, and hosting."
        },
        "price": "1800",
        "priceCurrency": "NZD"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Caretaker Subscription",
          "description": "Ongoing hosting, security, on-demand updates, and an annual design refresh after 12 months. Sorted, Connected, and Building tiers."
        },
        "price": "129",
        "priceCurrency": "NZD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "129",
          "priceCurrency": "NZD",
          "unitText": "MONTH"
        }
      }
    ]
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />
