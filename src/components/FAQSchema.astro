---
// FAQ Schema for Pricing Page - helps Google and AI answer engines
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does a website cost in New Zealand?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Professional website costs in NZ range from $700 to $15,000+ depending on complexity and who builds it. YourHQ uses one fixed build price ($1,800 NZD + GST) plus a monthly Caretaker subscription that scales with how active your site is: Sorted ($129/mo NZD + GST), Connected ($179/mo NZD + GST), or Building ($249/mo NZD + GST). Power-Ups for booking platforms, email tools, and Stripe are priced separately at build time."
      }
    },
    {
      "@type": "Question",
      "name": "What's included in the monthly fee?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The monthly fee covers Vercel hosting, SSL, backups, security, on-demand updates, annual design refresh, plus a tier-based monthly dev-time allowance: 30 minutes on Sorted, 1 hour on Connected, 2 hours on Building. On-demand updates include text changes, photo swaps, and content edits. Just text or email. Any single request requiring more than 30 minutes of dev work gets a written estimate before it starts. Not included by default: new pages, new integrations, or major scope changes (quoted separately)."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to build a website?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most clients are live within 1 to 2 weeks. After the Drive-Home Interview and one round of copy review, the site is built, previewed, and launched. Total client time: under 30 minutes."
      }
    },
    {
      "@type": "Question",
      "name": "Can I cancel anytime?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, all packages are month-to-month with no long-term contracts. You can cancel anytime with 30 days notice."
      }
    },
    {
      "@type": "Question",
      "name": "Do I own my website?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You own your domain, content, and design from day one. We register domains in your name and manage hosting while you're a customer. If you cancel, you keep everything - we'll help you move it to any provider you choose."
      }
    },
    {
      "@type": "Question",
      "name": "What if I need changes to my website?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Just text or email a photo or message. First response within one business day. Standard updates shipped within 2 to 3 business days. Urgent fixes (site down, payment flow broken, security issue) handled same business day, regardless of tier. Each tier includes a monthly dev-time allowance, and anything beyond it gets a written estimate before work starts. There is no priority support tier. Every Caretaker tier gets the same response window."
      }
    },
    {
      "@type": "Question",
      "name": "Is this better than a traditional web agency?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Traditional agencies charge $3,000-$10,000 upfront and then disappear. YourHQ provides ongoing support for a fraction of the cost, with no meetings required and unlimited updates included."
      }
    },
    {
      "@type": "Question",
      "name": "Do you work with clients outside Northland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! We're based in Northland but work with businesses across all of New Zealand - Auckland, Wellington, Christchurch, Queenstown, and everywhere in between. All communication happens via text, phone, and email, so location doesn't matter."
      }
    },
    {
      "@type": "Question",
      "name": "Can I cancel anytime?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All packages are month-to-month with no lock-in contracts. You can cancel anytime with 30 days' notice. You own your domain, content, and design from day one - we'll help you move to any provider you choose. The subscription covers managed hosting, maintenance, and updates."
      }
    },
    {
      "@type": "Question",
      "name": "Is this cheaper than a traditional agency?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Usually, yes. Agencies often cost $10,000–$20,000 over two years. YourHQ is $1,800 NZD + GST setup plus $129–$249/mo NZD + GST for the Caretaker subscription, including updates within your tier's dev-time allowance and an annual design refresh."
      }
    },
    {
      "@type": "Question",
      "name": "Is the monthly fee tax deductible?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Monthly fees are typically deductible business expenses (like internet or phone). Your setup fee may have different treatment. Check with your accountant for your situation."
      }
    },
    {
      "@type": "Question",
      "name": "What's included in the Google Maps setup?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every YourHQ build includes Google Business Profile setup. We claim or verify your listing, write the description, set service areas, add photos, and link it to your website. Standard across every build."
      }
    }
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
