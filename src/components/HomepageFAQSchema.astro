    },
    {
      "@type": "Question",
      "name": "How quickly can my tradie website go live?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most tradie websites are live within 1 to 2 weeks. After a 20-minute Drive-Home Interview, Lian builds your site while you're on the tools. No meetings, no homework, no tech stress."
      }
    },
    {
      "@type": "Question",
      "name": "Do you build websites for salons outside Auckland?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! We're based in Northland but work with businesses across all of New Zealand - Auckland, Wellington, Christchurch, and everywhere in between. All communication happens via text and phone, so location doesn't matter."
      }
    },
    {
      "@type": "Question",
      "name": "What makes YourHQ different from Wix or Squarespace?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "With Wix or Squarespace, you do all the work yourself — 40+ hours of building, learning, and troubleshooting. With YourHQ, Lian does everything for you and most clients are live within 1 to 2 weeks. Hand-coded, faster, more secure than a template builder. On-demand updates and an annual design refresh are included in your monthly Caretaker subscription, not billed per change."
      }
    },
    {
      "@type": "Question",
      "name": "Will my website help me rank on Google?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Every YourHQ site is built with SEO and AEO/GEO fundamentals: sub-second load times, mobile-first design, hand-coded clean markup, local business schema, and content structured for both Google and AI search engines (ChatGPT, Perplexity, Claude). Optimised for local searches like 'electrician near me' or 'hair salon Whangārei' so customers can actually find you."
      }
    }
  ]
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
