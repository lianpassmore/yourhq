---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Subscription Confirmed | YourHQ"
  description="Your Caretaker subscription is active. Your site is going live."
>
  <Navbar client:load />

  <main class="bg-paper min-h-screen">

    <!-- SUCCESS HEADER -->
    <section class="pt-32 pb-16 bg-white border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

        <div class="mb-8 flex justify-center">
          <div class="w-20 h-20 bg-deepGreen rounded-full flex items-center justify-center border-4 border-white shadow-hard">
            <span class="text-4xl text-white">&check;</span>
          </div>
        </div>

        <p class="font-mono text-xs font-bold uppercase tracking-widest text-deepGreen mb-4">Subscription Active</p>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[0.9] mb-6">
          You're All Set.
        </h1>
        <p class="text-2xl text-gray-700 max-w-2xl mx-auto leading-relaxed">
          Your Caretaker subscription is active. Now I take your site live.
        </p>
      </div>
    </section>

    <!-- WHAT'S NEXT -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 text-center leading-tight">
            What Happens Next.
          </h2>

          <div class="space-y-0">

            <!-- Step 1 -->
            <div class="flex gap-6 md:gap-10 pb-12 border-l-4 border-signal pl-8 md:pl-12 relative">
              <div class="absolute -left-[13px] top-0 w-6 h-6 rounded-full bg-signal border-4 border-white"></div>
              <div>
                <span class="inline-block bg-signal text-white px-3 py-1 text-xs font-bold mb-3 uppercase tracking-widest">In the next 24 hours</span>
                <h3 class="text-2xl font-bold mb-3">Domain Connected</h3>
                <p class="text-gray-700 leading-relaxed">
                  I point your domain at your site, set up email forwarding if you need it, and get the certificates in place.
                </p>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-6 md:gap-10 pb-12 border-l-4 border-hibiscus pl-8 md:pl-12 relative">
              <div class="absolute -left-[13px] top-0 w-6 h-6 rounded-full bg-hibiscus border-4 border-white"></div>
              <div>
                <span class="inline-block bg-hibiscus text-white px-3 py-1 text-xs font-bold mb-3 uppercase tracking-widest">Same Week</span>
                <h3 class="text-2xl font-bold mb-3">Google Notified</h3>
                <p class="text-gray-700 leading-relaxed">
                  Sitemap submitted, Google Business Profile aligned, search and AI tools pointed at your new permanent address.
                </p>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-6 md:gap-10 pb-12 border-l-4 border-frangipani pl-8 md:pl-12 relative">
              <div class="absolute -left-[13px] top-0 w-6 h-6 rounded-full bg-frangipani border-4 border-white"></div>
              <div>
                <span class="inline-block bg-frangipani text-white px-3 py-1 text-xs font-bold mb-3 uppercase tracking-widest">Ongoing</span>
                <h3 class="text-2xl font-bold mb-3">You Text. I Update.</h3>
                <p class="text-gray-700 leading-relaxed">
                  New phone number, new service, fresh photos, new testimonial. Send it through. I'll handle it.
                </p>
              </div>
            </div>

            <!-- Step 4 -->
            <div class="flex gap-6 md:gap-10 border-l-4 border-deepGreen pl-8 md:pl-12 relative">
              <div class="absolute -left-[13px] top-0 w-6 h-6 rounded-full bg-deepGreen border-4 border-white"></div>
              <div>
                <span class="inline-block bg-deepGreen text-white px-3 py-1 text-xs font-bold mb-3 uppercase tracking-widest">When You Want It</span>
                <h3 class="text-2xl font-bold mb-3">Design Refresh, On Demand</h3>
                <p class="text-gray-700 leading-relaxed">
                  Twelve months in, if you want a fresh look — new layout, new vibe, kept current — the Design Refresh Add-On is there for $600 + GST. Order it when you want it. Never forced on a schedule, never a full rebuild.
                </p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- MANAGE SUBSCRIPTION -->
    <section class="py-20 bg-white border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-extrabold tracking-tighter mb-6 leading-tight">
            Manage Your Subscription Anytime.
          </h2>
          <p class="text-lg text-gray-700 mb-10 max-w-2xl mx-auto">
            Update your card, view invoices, or change your tier from your customer portal. Sign in with the email you used at checkout.
          </p>
          <a href="https://billing.stripe.com/p/login/00waEWh0S14s3xH4UzdZ600" target="_blank" rel="noopener noreferrer" class="inline-block bg-carbon text-white px-12 py-5 font-bold uppercase tracking-widest border-2 border-carbon hover:bg-signal hover:border-signal transition-colors text-lg">
            Open Customer Portal &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- HELP -->
    <section class="py-16 bg-carbon text-white">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h3 class="text-2xl font-bold mb-4">Anything I Should Know?</h3>
        <p class="text-gray-400 mb-8 max-w-xl mx-auto">
          Updates, fixes, fresh photos, anything. Drop me a line.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="sms:0221725793" class="bg-signal text-white px-6 py-3 text-sm font-bold uppercase tracking-widest hover:bg-white hover:text-carbon transition-colors">
            Text 022 172 5793
          </a>
          <a href="mailto:hello@yourhq.co.nz" class="bg-transparent text-white border-2 border-white px-6 py-3 text-sm font-bold uppercase tracking-widest hover:bg-white hover:text-carbon transition-colors">
            Email hello@yourhq.co.nz
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
