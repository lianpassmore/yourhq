---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';

const buildLink = "/start-build";
---

<Layout
  title="Pricing | YourHQ"
  description="One Build. One Price. Care that scales with you. $3,800 NZD + GST setup. Monthly care from $149 NZD. Add-Ons for booking, email, Stripe."
>
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: 'Home', url: 'https://yourhq.co.nz/' },
      { name: 'Pricing', url: 'https://yourhq.co.nz/pricing' }
    ]}
  />
  <FAQSchema slot="head" />
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white">

    <!-- ============================================================
         HEADER
    ============================================================ -->
    <section class="pt-24 md:pt-32 pb-24 border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-[10px] md:text-xs font-medium uppercase tracking-[0.15em] text-deepGreen mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> Pricing
          </span>
          <h1 class="font-display font-bold text-[clamp(3.5rem,7vw,6.5rem)] leading-none tracking-tight mb-8">
            One Build. One Price.<br/>
            <span class="font-serif italic text-terracotta normal-case">Care That Scales With You.</span>
          </h1>
          <p class="font-sans text-xl md:text-2xl text-carbon/80 max-w-2xl leading-relaxed">
            This is what it costs.<br/>
            This is what you get.<br/>
            This is how I work.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION: THE BUILD
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="grid lg:grid-cols-12 gap-16 lg:gap-12 mb-16">
          <div class="lg:col-span-5 lg:pr-8">
            <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight mb-8">
              One build.<br/>
              Every client.<br/>
              <span class="font-serif italic text-softGrey normal-case">Same standard.</span>
            </h2>
            <p class="font-sans text-lg text-carbon/80 leading-relaxed mb-10">
              There's no starter tier. No features you pay extra to unlock. Every client gets the same build because anything less isn't worth putting my name on.
            </p>

            <!-- Price Block -->
            <div class="bg-bone rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col justify-between mb-8">
              <div>
                <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-deepGreen mb-4">The Build</p>
                <p class="font-serif italic text-xl text-carbon/80 leading-relaxed mb-8">
                  Your permanently owned digital home. Hand-coded, written in your voice, built to last.
                </p>
              </div>
              <div>
                <div class="flex items-baseline gap-2 mb-2">
                  <span class="font-display font-bold text-5xl md:text-6xl tracking-tight text-carbon">$3,800</span>
                  <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">NZD + GST</span>
                </div>
                <p class="font-mono text-[10px] text-softGrey mb-8 uppercase tracking-[0.15em]">One-time setup fee · The last setup fee you'll ever pay.</p>
                <a href={buildLink} class="block w-full bg-carbon text-white text-center px-8 py-4 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors shadow-subtle">
                  Start Your Build
                </a>
              </div>
            </div>
          </div>

          <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6 lg:gap-8 self-start">

            <div class="bg-surface rounded-3xl p-8 border border-carbon/5 shadow-sm">
              <p class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-carbon mb-4 border-b border-carbon/10 pb-4">Your Story, Captured</p>
              <ul class="space-y-3 text-sm text-carbon/80 leading-relaxed">
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div><strong class="text-carbon font-medium">The Drive-Home Interview, on your terms.</strong> Talk to my AI voice agent anytime that suits — car, couch, between meetings. Or fill in a written form at your own pace.</div></li>
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div><strong class="text-carbon font-medium">Market and audience research.</strong> Your buyer, your competitors, where the gap is. Your site is positioned before a word is written.</div></li>
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div><strong class="text-carbon font-medium">Conversion-first copywriting.</strong> Written in your voice, built to move people from "just looking" to "getting in touch."</div></li>
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div>Content raid + shared drive for your photos and assets</div></li>
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div>Copy review page — you see every word, section by section, before anything gets built</div></li>
              </ul>
            </div>

            <div class="bg-surface rounded-3xl p-8 border border-carbon/5 shadow-sm">
              <p class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-carbon mb-4 border-b border-carbon/10 pb-4">Your Site, Built Properly</p>
              <ul class="space-y-3 text-sm text-carbon/80 leading-relaxed">
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Up to 8 pages, hand-coded</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Blog and resources architecture</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Portfolio and case study layouts</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Media and press section</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Socials embed (Instagram, Facebook, Threads, X, LinkedIn)</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Stock photos if needed, or your existing photos AI-optimised</li>
              </ul>
            </div>

            <div class="bg-surface rounded-3xl p-8 border border-carbon/5 shadow-sm">
              <p class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-carbon mb-4 border-b border-carbon/10 pb-4">Your Foundation, Sorted</p>
              <ul class="space-y-3 text-sm text-carbon/80 leading-relaxed">
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Google Business Profile setup or optimisation</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Enquiry form direct to your inbox</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Basic email capture (CSV you own)</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> SEO optimised, get found on Google</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> AI search optimised, get found on ChatGPT, Perplexity, and other AI tools</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Domain, hosting, SSL, backups, security</li>
              </ul>
            </div>

            <div class="bg-surface rounded-3xl p-8 border border-carbon/5 shadow-sm">
              <p class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-carbon mb-4 border-b border-carbon/10 pb-4">Your Home, Kept Fresh</p>
              <ul class="space-y-3 text-sm text-carbon/80 leading-relaxed">
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic">Y</span> <div><strong class="text-carbon font-medium">On-demand updates, forever.</strong> New service? Photo from a project? New testimonial? Message me.</div></li>
                <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic">Y</span> <div><strong class="text-carbon font-medium">Caretaker relationship.</strong> I built it. I host it. I look after it. I know your site like I know my own.</div></li>
              </ul>
            </div>

          </div>
        </div>

        <!-- Callout -->
        <div class="bg-carbon text-bone rounded-3xl p-8 md:p-12 max-w-4xl mx-auto shadow-elegant text-center">
          <p class="font-display font-bold text-2xl md:text-3xl uppercase tracking-tight mb-4">Not a template. <span class="font-serif italic text-white/60 normal-case">Not a page builder.</span></p>
          <p class="font-sans text-bone/80 leading-relaxed max-w-2xl mx-auto">
            Hand-coded. Under a second to load. Mobile-first. Built for standard search and AI-generated answers. Yours unconditionally from day one.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION: POWER-UPS
    ============================================================ -->
    <section class="py-24 md:py-32 bg-bone border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="max-w-3xl mb-16 text-center mx-auto">
          <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta mb-4">Add-Ons</p>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4vw,3.5rem)] uppercase leading-none tracking-tight mb-6 text-carbon">
            For When Your Site <span class="font-serif italic text-softGrey normal-case">Needs to Do More.</span>
          </h2>
          <p class="font-sans text-lg text-carbon/80 leading-relaxed max-w-2xl mx-auto">
            The build is complete as it stands. Add-Ons are for when your site needs to talk to something else — a booking system, an email tool, Stripe — or when you want extra services beyond what's included. Fixed prices. No quotes. You only add what you actually need.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">

          <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="flex items-start justify-between mb-4 gap-4">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon">Bookings Embed</h3>
              <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-deepGreen bg-deepGreen/5 px-3 py-1 rounded-full whitespace-nowrap">+ $100 NZD</span>
            </div>
            <p class="font-sans text-carbon/75 leading-relaxed text-sm">
              Connect your existing booking tool. Calendly, Timely, Acuity. Embedded and styled to match.
            </p>
          </div>

          <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="flex items-start justify-between mb-4 gap-4">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon">Email Platform + Lead Magnet</h3>
              <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-deepGreen bg-deepGreen/5 px-3 py-1 rounded-full whitespace-nowrap">+ $250 NZD</span>
            </div>
            <p class="font-sans text-carbon/75 leading-relaxed text-sm">
              Your email platform connected. Welcome sequence, three emails. Lead magnet page built and wired.
            </p>
          </div>

          <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="flex items-start justify-between mb-4 gap-4">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon">Stripe.<br/>Services or Digital Products</h3>
              <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-deepGreen bg-deepGreen/5 px-3 py-1 rounded-full whitespace-nowrap">+ $350 NZD</span>
            </div>
            <p class="font-sans text-carbon/75 leading-relaxed text-sm mt-auto">
              Deposits, session packs, PDFs, recordings. Up to 5 products.
            </p>
          </div>

          <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="flex items-start justify-between mb-4 gap-4">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon">Stripe.<br/>Course Delivery</h3>
              <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-deepGreen bg-deepGreen/5 px-3 py-1 rounded-full whitespace-nowrap">+ $600 NZD</span>
            </div>
            <p class="font-sans text-carbon/75 leading-relaxed text-sm mt-auto">
              A structured course with modules. Checkout plus access delivery.
            </p>
          </div>

          <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="flex items-start justify-between mb-4 gap-4">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon">One-off Hour</h3>
              <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-deepGreen bg-deepGreen/5 px-3 py-1 rounded-full whitespace-nowrap">+ $175 NZD</span>
            </div>
            <p class="font-sans text-carbon/75 leading-relaxed text-sm mt-auto">
              Buy an hour of dev time when something bigger comes up. No commitment, no subscription. For quoted work that falls outside your tier's included time.
            </p>
          </div>

          <div class="bg-surface rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle md:col-span-2 flex flex-col md:flex-row items-start justify-between gap-6">
            <div class="max-w-md">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon mb-2">Content Autopilot</h3>
              <p class="font-sans text-carbon/75 leading-relaxed text-sm">
                Your social posts become blog articles. Fortnightly approval queue. One email, one tap, published.
              </p>
            </div>
            <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-carbon bg-white border border-carbon/10 px-4 py-2 rounded-full whitespace-nowrap shadow-sm shrink-0">
              + $200 NZD setup &middot; $99/mo NZD ongoing
            </span>
          </div>

          <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="flex items-start justify-between mb-4 gap-4">
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon">Design Refresh</h3>
              <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-deepGreen bg-deepGreen/5 px-3 py-1 rounded-full whitespace-nowrap">+ $600 NZD</span>
            </div>
            <p class="font-sans text-carbon/75 leading-relaxed text-sm mt-auto">
              On-demand visual update. Fonts, colours, layouts, hero sections refreshed to match current design trends. Available 12 months after launch. Order it when you want it.
            </p>
          </div>

          <div class="bg-carbon text-bone rounded-3xl p-8 md:p-10 shadow-elegant md:col-span-2 flex flex-col md:flex-row items-start justify-between gap-6 border border-carbon">
            <div class="max-w-xl">
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta mb-3">Bolts onto any tier</p>
              <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-white mb-2">Concierge</h3>
              <p class="font-sans text-bone/80 leading-relaxed text-sm mb-4">
                Add Concierge to Sorted, Connected, or Building. You jump the queue and get more time on the clock.
              </p>
              <ul class="space-y-2 font-sans text-sm text-bone/85">
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Priority queue position</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> 24-hour turnaround on weekdays</li>
                <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> An extra 1.5 hours of dev time on top of your tier</li>
              </ul>
            </div>
            <span class="font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-white bg-white/10 border border-white/20 px-4 py-2 rounded-full whitespace-nowrap shrink-0">
              + $199/mo NZD
            </span>
          </div>

        </div>

        <div class="text-center mt-16 max-w-2xl mx-auto">
          <p class="font-sans text-carbon/70">
            Add-Ons are offered at build checkout. Existing clients can add anything anytime, just message me. They'll appear on your next invoice.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION: NOT MY LANE
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="font-display font-bold text-[clamp(2.5rem,4vw,3.5rem)] uppercase leading-none tracking-tight text-carbon">
            Not My Lane. <br/>
            <span class="font-serif italic text-softGrey normal-case">I'll Point You Somewhere Good.</span>
          </h2>
        </div>

        <div class="bg-bone rounded-3xl border border-carbon/10 shadow-subtle overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-2 border-b border-carbon/10 p-6 md:p-8 bg-surface">
            <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-carbon font-medium">If you need</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta hidden md:block">I'll send you to</p>
          </div>
          <div class="divide-y divide-carbon/5">
            {[
              ['Physical products, inventory, shipping', 'A Shopify developer'],
              ['Full course platform + community', 'A Kajabi consultant'],
              ['Paid community or membership platform', 'Circle or Mighty Networks'],
              ['Newsletter as the primary product', 'Substack or Ghost'],
              ['Google or Meta Ads management', 'A PPC specialist'],
              ['SEO campaigns and link building', 'An SEO specialist'],
              ['CRM and sales pipeline', 'A HubSpot partner'],
              ['Custom web app or SaaS', 'A dev agency']
            ].map(([need, refer]) => (
              <div class="grid grid-cols-1 md:grid-cols-2 p-6 md:px-8 hover:bg-white/50 transition-colors gap-2 md:gap-8 items-center">
                <p class="font-sans text-carbon/90 text-sm font-medium">{need}</p>
                <div class="flex items-center gap-2">
                  <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta md:hidden">I'll send you to:</span>
                  <p class="font-serif italic text-carbon/70 text-lg">{refer}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <p class="font-serif italic text-xl text-carbon/70 mt-12 text-center">
          I'd rather refer you well than take the job and do it badly.
        </p>
      </div>
    </section>

    <!-- ============================================================
         SECTION: MONTHLY CARETAKER FEE
    ============================================================ -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="max-w-3xl mb-12 mx-auto text-center">
          <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta mb-4">Monthly Caretaker Fee</p>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight mb-8 text-carbon">
            Monthly Care <span class="font-serif italic text-softGrey normal-case">That Makes Sense.</span>
          </h2>
          <p class="font-sans text-lg text-carbon/80 leading-relaxed mb-6">
            This isn't a hosting fee. It's me knowing your site, watching it, updating it.
          </p>
          <p class="font-sans text-lg text-carbon/80 leading-relaxed">
            The level scales with what your site is doing. A simple content site costs less to maintain than one processing payments. That's just honest pricing.
          </p>
        </div>

        <div class="max-w-3xl mb-16 mx-auto text-left bg-white p-8 md:p-10 rounded-3xl border border-carbon/10 shadow-subtle">
          <h3 class="font-display font-bold text-2xl uppercase tracking-tight text-carbon mb-4">Beyond Hosting</h3>
          <p class="font-sans text-carbon/80 leading-relaxed mb-6 text-sm md:text-base">
            A $60 hosting plan is just a parking space. My Monthly Care is the mechanic, the security guard, and the driver.
          </p>
          <ul class="space-y-4 font-sans text-carbon/80 text-sm">
             <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div><strong class="text-carbon font-medium">Performance Hosting:</strong> Hand-coded sites on enterprise servers. Under 1s load times.</div></li>
             <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div><strong class="text-carbon font-medium">Security &amp; Shielding:</strong> SSL, daily backups, and active threat monitoring.</div></li>
             <li class="flex gap-3 items-start"><span class="text-terracotta font-serif italic mt-0.5">Y</span> <div><strong class="text-carbon font-medium">The "message me" service.</strong> Most hosts have a ticket system. I have a phone number and an email. Send me an update and it’s done.</div></li>
          </ul>
        </div>

        <div class="grid lg:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">

          <!-- Sorted -->
          <div class="bg-white rounded-3xl p-8 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mb-2">Level 1</div>
            <p class="font-display font-bold text-2xl uppercase tracking-tight text-carbon mb-6">Sorted</p>

            <div class="flex items-baseline gap-2 mb-6 border-b border-carbon/10 pb-6">
              <span class="font-display font-bold text-5xl tracking-tight text-carbon">$149</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">NZD / month</span>
            </div>

            <p class="font-sans text-sm text-carbon/80 mb-8 leading-relaxed">
              Your site is your credibility anchor. Looked after, always current. You message when something changes.
            </p>

            <ul class="space-y-3 text-sm text-carbon/80 mb-8 flex-grow">
              <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> 30 minutes of included dev time per month</li>
              <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Hosting, security &amp; SSL, backups</li>
              <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> On-demand updates via text or email</li>
              <li class="flex gap-3"><span class="text-terracotta font-serif italic">Y</span> Annual uptime and performance review</li>
            </ul>

            <a href="/foundation" class="inline-block font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border-b border-carbon/20 pb-1 hover:border-carbon transition-colors self-start">
              Sorted Details &rarr;
            </a>
          </div>

          <!-- Connected -->
          <div class="bg-bone rounded-3xl p-8 border border-carbon/10 shadow-subtle flex flex-col">
            <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-deepGreen mb-2">Level 2</div>
            <p class="font-display font-bold text-2xl uppercase tracking-tight text-carbon mb-6">Connected</p>

            <div class="flex items-baseline gap-2 mb-6 border-b border-carbon/10 pb-6">
              <span class="font-display font-bold text-5xl tracking-tight text-carbon">$199</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">NZD / month</span>
            </div>

            <p class="font-sans text-sm text-carbon/80 mb-8 leading-relaxed">
              Your site is doing active work. Booking systems running, email list growing, more regular updates.
            </p>

            <ul class="space-y-3 text-sm text-carbon/80 mb-8 flex-grow">
              <li class="flex gap-3"><span class="text-deepGreen font-serif italic">Y</span> 1 hour of included dev time per month</li>
