---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import HowToSchema from '../components/HowToSchema.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { BOOKING_URL, PHONE } from '../lib/site.js';

const buildIncludes = [
  'Up to 8 pages, built by hand',
  'Blog and resources, as standard',
  'Portfolio and case study layouts',
  'Media and press section',
  'Socials embedded (Instagram, Facebook, Threads, X, LinkedIn)',
  'Google Business Profile set up or optimised',
  'Enquiry form direct to your inbox',
  'Email capture you own (CSV)',
  'Found on Google, cited by AI tools',
  'Stock photos if needed, or your photos optimised',
];

const valueStack = [
  { h: 'Your story and copy, written for you.', b: 'A professional copywriter for an 8-page site typically runs $1,500 to $3,000, and you’d still have to brief them. Here it comes from one conversation, in your voice, and you approve every word.' },
  { h: 'Market and audience research.', b: 'Done properly, $500 to $1,500 from a marketing consultant. Included, before a word of your copy is written.' },
  { h: 'The site itself, built by hand.', b: 'An agency build for a custom 8-page site runs $5,000 to $15,000 in NZ, and you’d manage the project. Yours is built page by page, loads in under a second, and you spend zero time on it.' },
  { h: 'A blog, ready to go.', b: 'Usually a $500 to $1,000 add-on, if it’s offered at all. Included, because businesses that publish get found and sites that never change get buried.' },
  { h: 'Google Business Profile, set up properly.', b: 'Typically $300 to $500 from a local SEO person. Included, because it’s where local search happens.' },
  { h: 'Found on Google, cited by AI tools.', b: 'On-page SEO setup alone is commonly $500 to $1,500. Included and built in from the first line, not bolted on after.' },
  { h: 'The unglamorous plumbing.', b: 'Enquiry form, email capture you own, socials embedded, domain in your name, hosting, security. The pieces everyone else itemises. Included.' },
];

const iNeed = [
  'One 20-minute Website Chat',
  'One Drive-Home Interview call',
  'Your business name and contact details',
  'One round of copy feedback',
  'Any logos or specific photos you want included (optional, I’ll find what I need otherwise)',
];

const iDontNeed = [
  'You writing a single word of copy',
  'You briefing a designer',
  'Weekly check-in meetings',
  'A "website project" taking over your calendar',
  'You learning anything new',
];

const faqs = [
  { q: 'Do I have to write anything at all?', a: 'Nothing. I write every word, from your interview, your existing content, and one round of your feedback.' },
  { q: 'I already have a website. Is this a rebuild?', a: 'Yes, and that’s most of my clients. You’ve grown past what you have. I start fresh, in your voice, to where you are now. If you want the evidence before deciding, start with the Website Audit.' },
  { q: 'Is this for a business or a personal brand?', a: 'Both. Same standard. The difference is what’s at the centre: your business, or you.' },
  { q: 'What happens on the Website Chat?', a: 'Twenty minutes, free, no prep. You tell me what’s going on, I tell you honestly what I’d do, and if we’re a fit you get a written proposal within days. If we’re not, I’ll point you somewhere better.' },
  { q: 'What if I don’t love the site?', a: 'Full refund of your setup fee, minus card processing (about 3%) and domain costs. You see the complete finished site before the subscription starts.' },
  { q: 'How much time does this take from my end?', a: 'One chat, one interview call, one round of copy feedback. Less than an hour all up, and most of that is you talking about your favourite subject.' },
  { q: 'Why do you limit builds each month?', a: 'Because every site I build, I keep. Hosting it, updating it, answering the texts, for good. The cap means every build gets done properly and the people already on my books never wait because I’m chasing the next job.' },
  { q: 'Do you work with clients outside New Zealand?', a: 'Yes. Based in Whangārei, Aotearoa, working globally. Everything happens remotely.' },
  { q: 'What if my existing photos and content aren’t very good?', a: 'I’ll tell you, honestly and early. The content raid pulls everything I can find, but I won’t use low-quality photos or outdated content just to fill space. If what’s there isn’t up to standard, we’ll work out what’s needed. That might mean a photographer, stock in the short term, or waiting until you have something worth putting up. I’d rather have that conversation upfront than build something that doesn’t represent you.' },
];
---

<Layout
  title="How It Works | One Conversation Websites | YourHQ"
  description="From a free 20-minute chat to a live website in 1 to 2 weeks. No copy to write, no platform to learn, no project to manage. The full YourHQ process."
>
  <HowToSchema slot="head" />
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: 'Home', url: 'https://yourhq.co.nz/' },
      { name: 'How It Works', url: 'https://yourhq.co.nz/how-it-works' }
    ]}
  />
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white overflow-hidden">

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="pt-24 md:pt-32 pb-24 border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-badge uppercase text-deepGreen mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> THE PROCESS
          </span>
          <h1 class="font-display font-bold text-hero mb-8 text-carbon uppercase">
            One Conversation.<br/>
            <span class="font-serif italic text-terracotta normal-case font-normal">I Handle Everything Else.</span>
          </h1>
          <p class="font-sans text-subhead text-softGrey max-w-2xl">
            No copy to write. No designer to brief. No platform to learn. No project to manage.<br/>
            You talk. I build your digital home. Most clients are live within 1 to 2 weeks of saying yes.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         HOW IT STARTS
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-12 gap-12 md:gap-16 items-start">
        <div class="md:col-span-5">
          <h2 class="font-display font-bold text-display uppercase text-carbon leading-[1.05]">
            It starts with a chat.<br/>
            <span class="font-serif italic text-softGrey normal-case font-normal">Not a contract.</span>
          </h2>
        </div>
        <div class="md:col-span-7 space-y-6 font-sans text-body text-softGrey max-w-2xl">
          <p>Book a free 20-minute Website Chat. No prep, no pitch, no homework. You tell me what&rsquo;s going on, I look at whatever you&rsquo;ve already got before we talk, and I tell you honestly what I&rsquo;d do in your shoes. If I&rsquo;m not the right fit, I&rsquo;ll say so and point you somewhere better.</p>
          <p>Not a phone person? Completely fine, it&rsquo;s not for everyone. Fill in the contact form instead and we&rsquo;ll do the whole thing in writing. Same honesty, same proposal, no call required.</p>
          <p>If we&rsquo;re a fit, you get a proposal within a couple of days. One page. Your site, what it includes, what it costs to build, what the monthly care number is. In writing, no surprises, no obligation.</p>
          <p>Say yes, and I book you in. I take on a limited number of builds each month, so every site gets done properly and nobody already on my books waits for support. If the month is full, I&rsquo;ll tell you straight and hold your spot in the next one.</p>
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="inline-block bg-carbon text-white px-8 py-3.5 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors duration-300 text-center shadow-subtle">
              Book a Website Chat
            </a>
            <a href="/contact" class="inline-block bg-transparent text-carbon border border-carbon/20 px-8 py-3.5 rounded-full font-medium text-sm hover:border-carbon transition-colors duration-300 text-center">
              Or start with the form instead
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         THE PROMISE
    ============================================================ -->
    <section class="py-24 md:py-32 bg-bone border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center md:text-left">
          <h2 class="font-display font-bold text-display uppercase mb-10 text-carbon">
            You don&rsquo;t become<br/>
            the project manager.<br/>
            <span class="font-serif italic text-softGrey normal-case font-normal">Not even close.</span>
          </h2>
          <div class="space-y-6 md:border-l border-carbon/10 md:pl-8">
            <p class="font-sans text-body text-softGrey">
              You&rsquo;re not here to manage a build. You&rsquo;re here because you want this off your plate. Permanently, properly, by someone who knows what they&rsquo;re doing.
            </p>
            <p class="font-sans text-body text-softGrey">
              So here&rsquo;s the deal. You talk once, you give feedback once, and then you don&rsquo;t hear from me until there&rsquo;s something worth seeing.
            </p>
            <p class="font-sans text-body font-medium text-carbon">
              Most clients spend less than 30 minutes on their end, start to live site.
            </p>
            <p class="font-serif italic text-accent text-terracotta">
              That&rsquo;s not a selling point. That&rsquo;s just how this should work.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         THE BUILD PROCESS (TIMELINE)
    ============================================================ -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="relative">
            <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-[1px] bg-carbon/5 md:-ml-[0.5px]"></div>

            <!-- STEP 1 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">01</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Drive-Home Interview</h3>
                    <p class="font-mono text-badge uppercase text-deepGreen mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: one conversation</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Call my AI assistant whenever suits. In the car on the way home, between meetings, on the couch. No forms, no typing, no scheduled Zoom. You just talk.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        It asks the questions that pull out your story. Your work, your clients, the things that make you unmistakably you. Most people are surprised by what comes out. The best website copy lives in conversation, not in a brief.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Prefer writing to talking? There&rsquo;s a written version of the interview you can fill in at your own pace instead. Same questions, same result, no talking required.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don&rsquo;t fill in a form. You don&rsquo;t write a brief. You don&rsquo;t prepare anything. <strong class="font-sans font-medium text-carbon not-italic text-body">You just talk.</strong>
                    </p>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">01</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm">
                        <strong class="block font-mono text-badge uppercase text-softGrey mb-3">Time Required</strong>
                        <p class="font-display font-bold text-subhead text-carbon mb-1">15 to 20 Minutes</p>
                        <p class="font-sans text-ui text-softGrey">One conversation.</p>
                    </div>
                </div>
            </div>

            <!-- STEP 2 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-3 md:order-1 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 right-12 select-none z-0">02</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm ml-auto">
                        <strong class="block font-mono text-badge uppercase text-softGrey mb-3">Your Job</strong>
                        <p class="font-display font-bold text-subhead text-carbon">One Round of Feedback</p>
                    </div>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-1 md:order-3 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">02</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">I Write Your Copy</h3>
                    <p class="font-mono text-badge uppercase text-carbon mb-6 pb-4 border-b border-carbon/5 inline-block">Your time: one round of feedback</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        I turn your interview into full website copy. Written in your voice, reviewed by me personally. You get a private page showing every section clearly laid out, with a comment field next to each block.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Read it. Tell me what feels right and what doesn&rsquo;t. One round of changes. Nothing gets built until you&rsquo;ve signed off on every word.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don&rsquo;t write a word. You don&rsquo;t stare at a blank page. You don&rsquo;t guess at what your site should say. <strong class="font-sans font-medium text-carbon not-italic text-body">You just tell me what feels right.</strong>
                    </p>
                </div>
            </div>

            <!-- STEP 3 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">03</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Content Raid</h3>
                    <p class="font-mono text-badge uppercase text-terracotta mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: zero</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        While you&rsquo;re getting on with your life, I go through your existing digital footprint. Instagram, LinkedIn, Facebook, Google Reviews, your existing site, anywhere you already show up.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        I pull photos, testimonials, media mentions, business details. The good stuff you&rsquo;ve probably forgotten you have. You don&rsquo;t send me a thing.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don&rsquo;t dig through your camera roll. You don&rsquo;t compile a folder. You don&rsquo;t send me anything. <strong class="font-sans font-medium text-carbon not-italic text-body">I find it.</strong>
                    </p>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">03</span>
                    <div class="bg-bone rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm">
                        <strong class="block font-mono text-badge uppercase text-carbon mb-3">Honest Note</strong>
                        <p class="font-sans text-ui text-softGrey">
                          I work with what&rsquo;s actually there. If your existing content is strong, I&rsquo;ll use it. If it&rsquo;s thin or low quality, I&rsquo;ll tell you honestly before we build, and we&rsquo;ll talk about what&rsquo;s needed to get the site to the standard it deserves. I won&rsquo;t build something that undersells you just because we&rsquo;re working around bad source material.
                        </p>
                    </div>
                </div>
            </div>

            <!-- STEP 4 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-3 md:order-1 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 right-12 select-none z-0">04</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm ml-auto text-left">
                      <strong class="block font-mono text-badge uppercase text-deepGreen mb-4 pb-3 border-b border-carbon/5">Every Build Includes</strong>
                      <ul class="space-y-3 font-sans text-ui text-softGrey">
                        {buildIncludes.map((item) => (
                          <li class="flex gap-3"><span class="text-terracotta shrink-0" aria-hidden="true">&#10003;</span> {item}</li>
                        ))}
                      </ul>
                    </div>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-1 md:order-3 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">04</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Build</h3>
                    <p class="font-mono text-badge uppercase text-deepGreen mb-6 pb-4 border-b border-carbon/5 inline-block">Your time: zero</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Every line built specifically for your site. No templates, no page builders, no plugins waiting to break. What that means for you: the site loads in under a second, nothing needs updating on your end, ever, and it&rsquo;s built to be found on Google and cited when people ask AI tools a question.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Your blog is part of the build, not an extra, because businesses that publish get found and businesses that never change get buried. Same goes for your Google Business Profile, your enquiry form, and email capture you own. The standard build is everything you need to be credible and found. That&rsquo;s the point of it.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don&rsquo;t check in. You don&rsquo;t approve mock-ups in rounds. You don&rsquo;t lose a weekend to this. <strong class="font-sans font-medium text-carbon not-italic text-body">I build it.</strong>
                    </p>
                </div>
            </div>

            <!-- STEP 5 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">05</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">Preview</h3>
                    <p class="font-mono text-badge uppercase text-carbon mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: however long you want</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Private staging link. View it on your phone. Share it with whoever you want a second opinion from.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Love it, we go live.<br/>
                        Want changes, I sort them.<br/>
                        Don&rsquo;t love it, full refund of your setup fee, minus card processing (about 3%) and domain costs.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You see the finished thing. Not a wireframe. Not a concept. The actual site. <strong class="font-sans font-medium text-carbon not-italic text-body">Love it or leave it. That simple.</strong>
                    </p>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">05</span>
                    <div class="bg-carbon text-bone rounded-2xl p-8 border border-carbon shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm">
                        <strong class="block font-mono text-badge uppercase text-terracotta mb-3">Decision</strong>
                        <p class="font-display font-bold text-subhead text-white">Love It or Leave It</p>
                    </div>
                </div>
            </div>

            <!-- STEP 6 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-3 md:order-1 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 right-12 select-none z-0">06</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm ml-auto">
                        <strong class="block font-mono text-badge uppercase text-softGrey mb-3">Result</strong>
                        <p class="font-display font-bold text-subhead text-carbon mb-1">Permanent Address</p>
                        <p class="font-sans text-ui text-softGrey">Within 24 hours.</p>
                    </div>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-1 md:order-3 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">06</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">Go Live</h3>
                    <p class="font-mono text-badge uppercase text-deepGreen mb-6 pb-4 border-b border-carbon/5 inline-block">Your time: zero</p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Domain connected within 24 hours of your approval. Google notified. Your permanent address on the internet is set.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don&rsquo;t touch a thing. <strong class="font-sans font-medium text-carbon not-italic text-body">You&rsquo;re live.</strong>
                    </p>
                </div>
            </div>

            <!-- STEP 7 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">07</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">I Stay</h3>
                    <p class="font-mono text-badge uppercase text-terracotta mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: a text, when you need me</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        This is where most web designers stop. I don&rsquo;t.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Hosting, security, backups, all running quietly in the background. Updates on demand. Just message me.
                    </p>
