---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import HowToSchema from '../components/HowToSchema.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const buildLink = "/start-build";

const faqsHowItWorks = [
  { q: 'Do I have to write anything at all?', a: 'Nothing. I write every word, from your interview, your existing content, and one round of your feedback.' },
  { q: 'I already have a website. Is this a rebuild?', a: 'Yes, and that\'s most of my clients. You\'ve grown past what you have. I start fresh, in your voice, to where you are now.' },
  { q: 'Is this for a business or a personal brand?', a: 'Both. Same standard. The difference is what\'s at the centre. Your business, or you.' },
  { q: 'What if I don\'t love the site?', a: 'Full refund of your setup fee, minus Stripe processing (~3%) and domain costs. You see the complete finished site before the subscription starts.' },
  { q: 'How much time does this take from my end?', a: 'One interview call. One round of copy feedback. Less than 30 minutes total across the whole process.' },
  { q: 'Do you work with clients outside New Zealand?', a: 'Yes. I\'m based in Whangārei, Aotearoa, and I work globally. Everything happens remotely.' },
  { q: 'What if my existing photos and content aren\'t very good?', a: 'I\'ll tell you. Honestly and early. The content raid pulls everything I can find, but I won\'t use low-quality photos or outdated content just to fill space. If what\'s there isn\'t up to standard, I\'ll flag it before we build and we\'ll work out what\'s needed. That might mean commissioning a photographer, using stock in the short term, or waiting until you have something worth putting on the site. I\'d rather have that conversation upfront than build something that doesn\'t represent you properly.' }
];
---

<Layout
  title="How It Works | YourHQ"
  description="One conversation. I handle everything else. Hand-coded websites, written in your voice, looked after forever. Most clients are live within 1 to 2 weeks."
>
  <HowToSchema slot="head" />
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: 'Home', url: 'https://yourhq.co.nz/' },
      { name: 'How It Works', url: 'https://yourhq.co.nz/how-it-works' }
    ]}
  />
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white">

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="pt-24 md:pt-32 pb-24 border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-badge uppercase text-deepGreen mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> THE PROCESS
          </span>
          <h1 class="font-display font-bold text-hero mb-8 text-carbon uppercase">
            One Conversation.<br/>
            <span class="font-serif italic text-terracotta normal-case font-normal">I Handle Everything Else.</span>
          </h1>
          <p class="font-sans text-subhead text-softGrey max-w-2xl">
            No copy to write. No designer to brief. No platform to learn. No project to manage.<br/>
            You talk. I build your digital home. Most clients are live within 1 to 2 weeks.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         THE PROMISE
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/5 shadow-subtle">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center md:text-left">
          <h2 class="font-display font-bold text-display uppercase mb-10 text-carbon">
            You don't become<br/>
            the project manager.<br/>
            <span class="font-serif italic text-softGrey normal-case font-normal">Not even close.</span>
          </h2>
          <div class="space-y-6 md:border-l border-carbon/10 md:pl-8">
            <p class="font-sans text-body text-softGrey">
              You're not here to manage a build. You're here because you want this off your plate. Permanently, properly, by someone who actually knows what they're doing.
            </p>
            <p class="font-sans text-body text-softGrey">
              So here's the deal. You talk once, you give feedback once, and then you don't hear from me until there's something worth seeing.
            </p>
            <p class="font-sans text-body font-medium text-carbon">
              Most clients spend less than 30 minutes on their end. Start to live site.
            </p>
            <p class="font-serif italic text-accent text-terracotta">
              That's not a selling point. That's just how this should work.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         THE PROCESS (TIMELINE)
    ============================================================ -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="relative">
            <!-- Elegant Timeline Line -->
            <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-[1px] bg-carbon/5 md:-ml-[0.5px]"></div>

            <!-- STEP 1 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">01</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Drive-Home Interview</h3>
                    <p class="font-mono text-badge uppercase text-deepGreen mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: one conversation</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Call my AI assistant whenever suits. In the car on the way home, between meetings, on the couch. No forms, no typing, no scheduled Zoom. You just talk.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        I ask the questions that pull out your story. Your work, your clients, your vision, the things that make you unmistakably you. Most people are surprised by what comes out. The best website copy lives in conversation, not in a brief.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don't fill in a form. You don't write a brief. You don't prepare anything. <strong class="font-sans font-medium text-carbon not-italic text-body">You just talk.</strong>
                    </p>
                </div>
                <!-- Timeline Dot -->
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">01</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm">
                        <strong class="block font-mono text-badge uppercase text-softGrey mb-3">Time Required</strong>
                        <p class="font-display font-bold text-subhead text-carbon mb-1">15 Minutes</p>
                        <p class="font-sans text-ui text-softGrey">One conversation.</p>
                    </div>
                </div>
            </div>

            <!-- STEP 2 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-3 md:order-1 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 right-12 select-none z-0">02</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm ml-auto">
                        <strong class="block font-mono text-badge uppercase text-softGrey mb-3">Your Job</strong>
                        <p class="font-display font-bold text-subhead text-carbon">One Round of Feedback</p>
                    </div>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-1 md:order-3 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">02</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">I Write Your Copy</h3>
                    <p class="font-mono text-badge uppercase text-carbon mb-6 pb-4 border-b border-carbon/5 inline-block">Your time: one round of feedback</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        I turn your interview into full website copy. Written in your voice, reviewed by me personally. You get a private page showing every section clearly laid out, with a comment field next to each block.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Read it. Tell me what feels right and what doesn't. One round of changes. Nothing gets built until you've signed off on every word.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don't write a word. You don't stare at a blank page. You don't guess at what your site should say. <strong class="font-sans font-medium text-carbon not-italic text-body">You just tell me what feels right.</strong>
                    </p>
                </div>
            </div>

            <!-- STEP 3 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">03</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Content Raid</h3>
                    <p class="font-mono text-badge uppercase text-terracotta mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: zero</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        While you're getting on with your life, I go through your existing digital footprint. Instagram, LinkedIn, Facebook, Google Reviews, Substack, your existing site, anywhere you already show up.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        I pull photos, testimonials, media mentions, business details. The good stuff you've probably forgotten you have. You don't send me a thing.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don't dig through your camera roll. You don't compile a folder. You don't send me anything. <strong class="font-sans font-medium text-carbon not-italic text-body">I find it.</strong>
                    </p>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">03</span>
                    <div class="bg-bone rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm">
                        <strong class="block font-mono text-badge uppercase text-carbon mb-3">Honest Note</strong>
                        <p class="font-sans text-ui text-softGrey">
                          I work with what's actually there. If your existing content is strong, I'll use it. If it's thin or low quality, I'll tell you honestly before we build, and we'll talk about what we need to get the site to the standard it deserves. I won't build something that undersells you just because we're working around bad source material.
                        </p>
                    </div>
                </div>
            </div>

            <!-- STEP 4 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-3 md:order-1 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 right-12 select-none z-0">04</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm ml-auto text-left">
                      <strong class="block font-mono text-badge uppercase text-deepGreen mb-4 pb-3 border-b border-carbon/5">Every Build Includes</strong>
                      <ul class="space-y-3 font-sans text-ui text-softGrey">
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Up to 8 pages, hand-coded</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Blog and resources architecture</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Portfolio and case study layouts</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Media and press section</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Socials embed (Instagram, Facebook, Threads, X, LinkedIn)</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Google Business Profile setup or optimisation</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Enquiry form direct to your inbox</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Basic email capture (CSV you own)</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> SEO optimised, get found on Google</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> AI search optimised, get found when people ask ChatGPT, Perplexity, and other AI tools</li>
                        <li class="flex gap-3"><span class="text-terracotta font-serif italic text-lg leading-none">Y</span> Stock photos if needed, or your existing photos AI-optimised</li>
                      </ul>
                    </div>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-1 md:order-3 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">04</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Build</h3>
                    <p class="font-mono text-badge uppercase text-deepGreen mb-6 pb-4 border-b border-carbon/5 inline-block">Your time: zero</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Hand-coded in Astro. Under a second to load. Mobile-first. Built for standard search and AI-generated answers. Future-ready.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Not a template. Not a theme with your logo dropped in. Built from your approved copy, to your visual brand, one page at a time.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don't check in. You don't approve mock-ups in rounds. You don't lose a weekend to this. <strong class="font-sans font-medium text-carbon not-italic text-body">I build it.</strong>
                    </p>
                </div>
            </div>

            <!-- STEP 5 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">05</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">Preview</h3>
                    <p class="font-mono text-badge uppercase text-carbon mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: however long you want</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        Private staging link. View it on your phone. Share it with whoever you want a second opinion from.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Love it. We go live.<br/>
                        Want changes. I sort them.<br/>
                        Don't love it. Full refund of your setup fee, minus Stripe processing (~3%) and domain costs.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You see the finished thing. Not a wireframe. Not a concept. The actual site. <strong class="font-sans font-medium text-carbon not-italic text-body">Love it or leave it. That simple.</strong>
                    </p>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">05</span>
                    <div class="bg-carbon text-bone rounded-2xl p-8 border border-carbon shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm">
                        <strong class="block font-mono text-badge uppercase text-terracotta mb-3">Decision</strong>
                        <p class="font-display font-bold text-subhead text-white">Love It or Leave It</p>
                    </div>
                </div>
            </div>

            <!-- STEP 6 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 mb-24 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-3 md:order-1 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 right-12 select-none z-0">06</span>
                    <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant group-hover:shadow-float transition-all duration-500 relative z-10 max-w-sm ml-auto text-left md:text-right">
                        <strong class="block font-mono text-badge uppercase text-softGrey mb-3">Result</strong>
                        <p class="font-display font-bold text-subhead text-carbon mb-1">Permanent Address</p>
                        <p class="font-sans text-ui text-softGrey">Within 24 hours.</p>
                    </div>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-1 md:order-3 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">06</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">Go Live</h3>
                    <p class="font-mono text-badge uppercase text-deepGreen mb-6 pb-4 border-b border-carbon/5 inline-block">Your time: zero</p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Domain connected within 24 hours of your approval. Google notified. Your permanent address on the internet is set.
                    </p>
                    <p class="font-serif italic text-accent text-softGrey">
                        You don't touch a thing. Domain connected. Google notified. <strong class="font-sans font-medium text-carbon not-italic text-body">You're live.</strong>
                    </p>
                </div>
            </div>

            <!-- STEP 7 -->
            <div class="relative grid md:grid-cols-2 gap-8 md:gap-16 items-center group">
                <div class="pl-20 md:pl-0 md:text-right md:pr-16 order-1 relative">
                    <span class="font-serif italic text-headline text-terracotta md:hidden mb-4 block">07</span>
                    <h3 class="font-display font-bold text-headline uppercase mb-2 text-carbon">The Caretakers Take Over</h3>
                    <p class="font-mono text-badge uppercase text-carbon mb-6 pb-4 border-b border-carbon/5 inline-block md:block md:ml-auto">Your time: a text, when you need me</p>
                    <p class="font-sans text-body text-softGrey mb-4">
                        This is where most web designers stop. I don't.
                    </p>
                    <p class="font-sans text-body text-softGrey mb-6">
                        Hosting, security, SSL, backups. Running quietly in the background. Updates on demand. Just message me.
                    </p>
                    <ul class="space-y-3 font-sans text-ui text-softGrey mb-6 border-l border-carbon/20 pl-6 text-left md:text-right md:border-l-0 md:border-r md:pr-6 md:pl-0 inline-block">
                      <li>New service? <span class="font-medium text-carbon">Message me.</span></li>
                      <li>Media mention? <span class="font-medium text-carbon">Message me.</span></li>
                      <li>Big pivot? <span class="font-medium text-carbon">Message me.</span></li>
                      <li>Something broke? <span class="font-medium text-carbon">I'm on it.</span></li>
                    </ul>
                    <p class="font-serif italic text-accent text-softGrey">
                        Message me when something changes. That's the whole ongoing relationship. <strong class="font-sans font-medium text-carbon not-italic text-body">You evolve. I keep up.</strong>
                    </p>
                </div>
                <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-white rounded-full border border-carbon/20 ring-4 ring-surface transform -translate-x-1/2 z-10 top-6 md:top-1/2 mt-1.5 md:mt-0 order-2 transition-colors group-hover:bg-deepGreen group-hover:border-deepGreen"></div>
                <div class="pl-20 md:pl-16 order-3 relative">
                    <span class="hidden md:block font-serif italic text-hero text-terracotta/10 absolute -top-12 left-12 select-none z-0">07</span>
                    <a href={buildLink} class="inline-block bg-carbon text-white px-8 py-4 rounded-full font-medium text-ui hover:bg-deepGreen transition-all duration-300 shadow-elegant hover:shadow-float relative z-10">
                        Start Your Build
                    </a>
                </div>
            </div>

        </div>
      </div>
    </section>

    <!-- ============================================================
         WHAT I NEED FROM YOU
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-16">
            <h2 class="font-display font-bold text-display uppercase text-carbon">
              What I Need.<br/>
              <span class="font-serif italic normal-case text-softGrey font-normal">And What I Don't.</span>
            </h2>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-surface rounded-2xl p-8 border border-carbon/5 shadow-elegant">
              <h3 class="font-mono text-badge uppercase text-deepGreen mb-8 border-b border-carbon/5 pb-4">What I Need</h3>
              <ul class="space-y-4 font-sans text-body text-softGrey">
                <li class="flex items-start gap-3"><span class="text-terracotta font-serif italic text-lg leading-none mt-0.5">Y</span> One Drive-Home Interview call</li>
                <li class="flex items-start gap-3"><span class="text-terracotta font-serif italic text-lg leading-none mt-0.5">Y</span> Your business name and contact details</li>
                <li class="flex items-start gap-3"><span class="text-terracotta font-serif italic text-lg leading-none mt-0.5">Y</span> One round of copy feedback</li>
                <li class="flex items-start gap-3"><span class="text-terracotta font-serif italic text-lg leading-none mt-0.5">Y</span> Any logos or specific photos you want included (optional, I'll find what I need otherwise)</li>
              </ul>
            </div>

            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-elegant">
              <h3 class="font-mono text-badge uppercase text-terracotta mb-8 border-b border-carbon/5 pb-4">What I Don't Need</h3>
              <ul class="space-y-4 font-sans text-body text-softGrey">
                <li class="flex items-start gap-3"><span class="text-softGrey font-mono text-xs mt-1 leading-none">+</span> You writing a single word of copy</li>
                <li class="flex items-start gap-3"><span class="text-softGrey font-mono text-xs mt-1 leading-none">+</span> You briefing a designer</li>
                <li class="flex items-start gap-3"><span class="text-softGrey font-mono text-xs mt-1 leading-none">+</span> Weekly check-in meetings</li>
                <li class="flex items-start gap-3"><span class="text-softGrey font-mono text-xs mt-1 leading-none">+</span> A "website project" taking over your calendar</li>
                <li class="flex items-start gap-3"><span class="text-softGrey font-mono text-xs mt-1 leading-none">+</span> You learning anything new</li>
              </ul>
            </div>
          </div>

          <div class="mt-12 bg-deepGreen text-bone rounded-2xl p-8 md:p-12 text-center shadow-elegant border border-carbon/5">
            <p class="font-serif italic text-headline text-bone">You run the business. <span class="font-display font-bold uppercase text-white">I build and look after the home.</span></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         I STAY (CARETAKER MODEL)
    ============================================================ -->
    <section class="py-24 md:py-32 bg-bone border-b border-carbon/5">
