---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import DiscoveryForm from '../components/DiscoveryForm.jsx';
---

<Layout
  title="The Drive-Home Interview | YourHQ"
  description="Start your website build with a simple conversation."
>
  <Navbar client:load />

  <main class="bg-bone min-h-screen text-carbon font-sans selection:bg-deepGreen selection:text-white flex flex-col">

    <!-- HEADER -->
    <section class="pt-32 pb-20 px-6 lg:px-12 border-b border-carbon/10 text-center">
      <div class="max-w-4xl mx-auto">
        
        <!-- Refined Step Label -->
        <span class="inline-block font-mono text-badge text-signal mb-8 px-4 py-1.5 bg-white rounded-full border border-carbon/5 shadow-subtle">
          Step 01: Content Gathering
        </span>

        <h1 id="dynamic-greeting" class="font-display text-hero font-bold text-carbon mb-8 leading-tight">
          The Drive-Home Interview.
        </h1>
        
        <!-- The Whisper / Tension Technique -->
        <p class="font-serif italic text-headline text-terracotta mb-6">
          No forms. No typing. Just talk.
        </p>
        <p class="font-sans text-subhead text-softGrey max-w-2xl mx-auto leading-relaxed">
          Your digital assistant is ready to capture what makes your business you.
        </p>
      </div>
    </section>

    <!-- INSTRUCTIONS CONTENT -->
    <section class="py-24 bg-white border-b border-carbon/10 flex-grow px-6 lg:px-12">
      <div class="max-w-3xl mx-auto">

        <!-- Elevated Instruction Card -->
        <div class="bg-surface rounded-2xl border border-carbon/5 p-10 md:p-16 shadow-elegant relative overflow-hidden">
          
          <div class="space-y-12">
            
            <!-- Block 1 -->
            <div>
              <h2 class="font-sans font-semibold text-subhead text-carbon mb-6 flex items-center gap-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-white border border-carbon/10 font-mono text-xs text-carbon shadow-sm">1</span>
                What this is
              </h2>
              <p class="font-sans text-body text-softGrey leading-relaxed pl-12">
                You're about to speak with the <strong class="text-carbon font-semibold">YourHQ Assistant</strong> - an AI interview tool trained to capture your business details and story for your website. This isn't a live call. It takes about 10–15 minutes.
              </p>
            </div>

            <!-- Block 2 -->
            <div>
              <h2 class="font-sans font-semibold text-subhead text-carbon mb-6 flex items-center gap-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-white border border-carbon/10 font-mono text-xs text-carbon shadow-sm">2</span>
                Before you start
              </h2>
              <ul class="space-y-4 font-sans text-body text-softGrey pl-12">
                <li class="flex items-start gap-3">
                  <span class="text-deepGreen mt-0.5">✓</span>
                  <span>Find a reasonably quiet spot (car with windows up is perfect).</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-deepGreen mt-0.5">✓</span>
                  <span>Don't overthink it - speak naturally, like you're telling a friend about your business.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-deepGreen mt-0.5">✓</span>
                  <span>Tap the <strong class="text-carbon font-semibold">blue button</strong> in the bottom right corner to begin.</span>
                </li>
              </ul>
            </div>
            
            <!-- Privacy Notice -->
            <div class="mt-8 pt-8 border-t border-carbon/10">
              <p class="font-sans text-ui text-softGrey/80">
                <strong class="font-semibold text-softGrey uppercase tracking-wider text-[10px] mr-2">Privacy Notice:</strong> 
                By starting, you consent to your voice being recorded and processed to generate website copy. We don't clone voices. We don't sell data.
              </p>
            </div>

          </div>
        </div>

        <!-- Help Text -->
        <div class="text-center mt-10 font-sans text-ui text-softGrey">
          <p>Need help? Text us at <span class="text-carbon font-semibold">022 172 5793</span></p>
        </div>

      </div>
    </section>

    <!-- WRITTEN FORM -->
    <section class="py-24 bg-bone px-6 lg:px-12">
      <div class="max-w-4xl mx-auto">

        <div class="text-center mb-16">
          <h2 class="font-display text-display font-bold text-carbon mb-6">
            Prefer to Type?
          </h2>
          <p class="font-sans text-subhead text-softGrey max-w-2xl mx-auto">
            Fill this in at your own pace. All fields are optional - answer what you can and we'll cover the rest.
          </p>
        </div>

        <!-- Form Container -->
        <div class="bg-white rounded-2xl border border-carbon/5 shadow-elegant p-8 md:p-12 lg:p-16">
          
          <div class="mb-12 pb-8 border-b border-carbon/5">
            <span class="inline-block font-mono text-[10px] text-carbon uppercase tracking-[0.15em] mb-4">Written Intake Form</span>
            <h3 class="font-sans font-semibold text-headline text-carbon mb-2">Discovery Questions</h3>
            <p class="font-serif italic text-accent text-softGrey">The more you fill in, the better your site.</p>
          </div>
          
          <!-- React Component -->
          <DiscoveryForm client:load tier="growth" />
        </div>

      </div>
    </section>

  </main>

  <Footer />

  <!-- ELEVENLABS VOICE AGENT WIDGET -->
  <elevenlabs-convai agent-id="agent_8801kbr4e3s1f32vwgejq4wdcezp"></elevenlabs-convai>
  <script is:inline src="https://unpkg.com/@elevenlabs/convai-widget-embed" async type="text/javascript"></script>

  <!-- DYNAMIC GREETING SCRIPT -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const name = urlParams.get('name');
      const greetingElement = document.getElementById('dynamic-greeting');

      if (name && greetingElement) {
        const cleanName = name.charAt(0).toUpperCase() + name.slice(1);
        greetingElement.innerHTML = `Kia ora, ${cleanName}.<br/>Ready for your interview?`;
      }

      // Notify via ntfy.sh when the ElevenLabs interview ends
      const widget = document.querySelector('elevenlabs-convai');
      if (widget) {
        widget.addEventListener('elevenlabs-convai:call-ended', () => {
          const name = new URLSearchParams(window.location.search).get('name');
          const message = name
            ? `${name.charAt(0).toUpperCase() + name.slice(1)} just completed their discovery interview.`
            : 'Someone just completed their discovery interview.';

          fetch('https://ntfy.sh/yourhq-discovery', {
            method: 'POST',
            body: message,
            headers: {
              'Title': 'Discovery Interview Completed',
              'Priority': 'high',
              'Tags': 'tada',
            },
          }).catch(() => {});
        });
      }
    });
  </script>

</Layout>