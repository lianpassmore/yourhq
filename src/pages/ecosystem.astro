---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

import { BOOKING_URL } from '../lib/site.js';

const faqs = [
  { q: 'Does my website replace my social media presence?', a: 'No. Social is where you show up and reach new people. The website is where you send them when they want the full picture. Both matter. The difference is one is rented, one is owned.' },
  { q: 'What if the platforms I use change or disappear?', a: 'Your website is the one thing that doesn\'t depend on any platform\'s decisions. Your domain, content, design. Owned unconditionally. If Instagram disappeared tomorrow, your website is still there.' },
  { q: 'What\'s the difference between SEO and AEO?', a: 'SEO is how your site shows up in Google\'s traditional results. AEO, Answer Engine Optimisation, is how your site shows up in AI-generated answers, like when someone asks ChatGPT a question and it pulls from real websites. We build for both.' },
  { q: 'What does "hand-coded" actually mean?', a: 'Every line of code is written specifically for your site, not assembled from a template or generated by a page builder. Hand-coded sites are faster, cleaner, more secure, and more distinctive.' }
];

const refers = [
  ['Physical products, inventory, shipping', 'A Shopify developer'],
  ['Full course platform and community', 'A Kajabi consultant'],
  ['Paid membership or community platform', 'Circle or Mighty Networks'],
  ['Newsletter as the primary product', 'Substack or Ghost'],
  ['Google or Meta Ads management', 'A PPC specialist'],
  ['SEO campaigns and link building', 'An SEO specialist'],
  ['CRM and sales pipeline', 'A HubSpot partner'],
  ['Custom web app or SaaS product', 'A dev agency']
];

const techStack = [
  { num: 6, title: "What the visitor sees", desc: "Pages, copy, design, photos, forms, CTAs. Fast, clear, credible. Under 1 second load time. The goal.", tag: "The goal", bg: "bg-carbon", text: "text-white" },
  { num: 5, title: "Content and copy", desc: "Written from the Drive-Home Interview, content raid on existing socials, and the client's footprint. Kept fresh via one-inbox updates.", tag: "YourHQ + Client", bg: "bg-surface text-carbon border border-carbon/10", text: "text-carbon" },
  { num: 4, title: "Builder / framework", desc: "How the site is constructed. The biggest quality gap. No page builders, no visual editors, no bloat. Pure hand-coded components.", tag: "Astro + Tailwind", bg: "bg-surface text-carbon border border-carbon/10", text: "text-carbon" },
  { num: 3, title: "Platform / CMS", desc: "Where WordPress plugin bloat, security holes, and 'my site broke' come from. Astro generates static files. No CMS layer needed.", tag: "None (Static)", bg: "bg-surface text-carbon border border-carbon/10", text: "text-carbon" },
  { num: 2, title: "Hosting", desc: "Invisible but critical. Determines speed, reliability, uptime. Vercel's global edge network means the site loads from a server near the visitor.", tag: "Vercel Edge", bg: "bg-surface text-carbon border border-carbon/10", text: "text-carbon" },
  { num: 1, title: "Domain", desc: "Their address. The only part of the stack that is irreversibly theirs from day one. Always registered in the client's name.", tag: "Owned by client", bg: "bg-surface text-carbon border border-carbon/10", text: "text-carbon" }
];
---

<Layout
  title="Visual Reference Maps & Ecosystem | YourHQ"
  description="A plain-English guide to the digital landscape. Where your website sits, what surrounds it, and how it all connects."
>
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white pb-32">

    <!-- HERO -->
    <section class="pt-24 md:pt-32 pb-24 border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-badge uppercase text-deepGreen mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> Visual Reference Maps &amp; Ecosystem
          </span>
          <h1 class="font-display font-bold text-hero uppercase tracking-tight leading-none mb-8 text-carbon">
            How Your Website Fits Into <br/>
            <span class="font-serif italic text-terracotta normal-case font-normal">Everything Else You're Doing Online.</span>
          </h1>
          <p class="font-sans text-subhead text-softGrey max-w-3xl">
            A plain-English guide to the digital landscape in 2026. What changed with AI search, why the website matters more now, not less, and every YourHQ diagram in one place.
          </p>
        </div>
      </div>
    </section>

    <!-- THE NUMBERS (From Astro) -->
    <section class="py-24 bg-white border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-12">
          <span class="font-mono text-badge uppercase text-terracotta mb-4 block">The 2026 Shift</span>
          <h2 class="font-display font-bold text-display uppercase tracking-tight mb-8 text-carbon">
            The website's job changed. <br/>
            <span class="font-serif italic text-softGrey normal-case font-normal">Most sites haven't noticed.</span>
          </h2>
          <div class="space-y-6 font-sans text-body text-softGrey">
            <p>For twenty years the website was a destination. You did things to get people to it, and more visitors meant more business.</p>
            <p>That era is ending. Around 60% of Google searches now finish without a click, and when an AI answer sits at the top of the page, that figure climbs past 80%. Some industries lost 40 to 70% of their search traffic in a single year. Services, consulting and training sit squarely in the impact zone.</p>
            <p>So is the website dead? The opposite. The clicks that survive convert around 23% better, because the people who still arrive are further along, closer to spending, and judging harder. And the AI answers themselves have to come from somewhere. They're built from real websites, and they favour the ones that are clear, current, well-structured and straight to the point.</p>
            <p class="font-medium text-carbon">The website stopped being a traffic machine and became two things: the source AI pulls from, and the place where trust is finally decided. Fewer visitors, higher stakes, and a much lower tolerance for a site that's out of date.</p>
          </div>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-surface rounded-2xl p-10 border border-carbon/5 shadow-subtle">
            <p class="font-display font-bold text-[4rem] leading-none tracking-tight text-carbon mb-4">41<span class="text-3xl text-terracotta">%</span></p>
            <p class="font-sans text-body text-softGrey">more trustworthy. How consumers rate a business that has a website, second only to reviews.</p>
          </div>
          <div class="bg-surface rounded-2xl p-10 border border-carbon/5 shadow-subtle">
            <p class="font-display font-bold text-[4rem] leading-none tracking-tight text-carbon mb-4">58<span class="text-3xl text-terracotta">%</span></p>
            <p class="font-sans text-body text-softGrey">check a business's website to verify what they saw on social media or in an AI recommendation.</p>
          </div>
          <div class="bg-surface rounded-2xl p-10 border border-carbon/5 shadow-subtle">
            <p class="font-display font-bold text-[4rem] leading-none tracking-tight text-carbon mb-4">60<span class="text-3xl text-terracotta">%</span></p>
            <p class="font-sans text-body text-softGrey">say an outdated-looking website damages how they rate a business's quality.</p>
          </div>
        </div>
        <p class="font-sans text-xs text-softGrey/70 mt-6 max-w-3xl">
          Consumer figures: DreamHost Local Business Trust Index, November 2025, US sample. AI search figures: 2026 SEO industry reporting, directional.
        </p>
      </div>
    </section>

    <!-- SIGNALS VS SOURCE (From Astro) -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-7">
            <h2 class="font-display font-bold text-display uppercase tracking-tight mb-8 text-carbon">
              Everything You Do Online Is a Signal.<br/>
              <span class="font-serif italic text-softGrey normal-case font-normal">Where Does It Lead?</span>
            </h2>
            <div class="space-y-6 font-sans text-body text-softGrey">
              <p>You post on LinkedIn. You show up on Instagram. You get mentioned in a podcast. Someone leaves a Google review.</p>
              <p>Every one of those is a signal. A small piece of evidence that you exist, that you're real, that you're worth paying attention to.</p>
              <p>But signals need somewhere to point. A destination. A place that holds the whole story. Permanently, completely, in your own words, on your own terms.</p>
              <p>Without that, signals scatter. People find fragments. They can't get the full picture. In the moment they're deciding whether to trust you. They hesitate.</p>
            </div>
          </div>
          <div class="lg:col-span-5">
            <div class="bg-carbon text-bone rounded-3xl p-10 md:p-12 shadow-elegant hover:shadow-float transition-all duration-500">
              <p class="font-display font-bold text-headline text-white mb-6 uppercase">Your profiles are signals.<br/><span class="text-terracotta">Your website is the source.</span></p>
              <p class="font-sans text-body text-bone/80">
                Every post, every review, every appearance. They should point somewhere permanent. Somewhere you own. Somewhere that says: this is who I am, this is what I stand for, and I'm not going anywhere.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DIAGRAM 01: WEBSITE TYPES -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/5" id="types">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-16">
          <span class="font-mono text-badge uppercase text-terracotta mb-4 block">Diagram 01</span>
          <h2 class="font-display font-bold text-display uppercase tracking-tight mb-4 text-carbon">
            Types of websites <br/><span class="font-serif italic text-softGrey normal-case font-normal">we build.</span>
          </h2>
          <p class="font-sans text-body text-softGrey max-w-2xl">
            Two fundamental types, same stack. Architecture and copy angle differ based on whether the person is the brand.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div class="bg-surface rounded-2xl p-8 md:p-10 border border-carbon/5 shadow-subtle hover:shadow-elegant transition-shadow">
            <p class="font-mono text-badge uppercase text-deepGreen mb-4">Type 01</p>
            <h3 class="font-display font-bold text-headline uppercase text-carbon mb-2">Business site</h3>
            <p class="font-serif italic text-accent text-softGrey mb-8">The business exists separately from the person: tradie, clinic, café, salon, studio.</p>
            <ul class="space-y-3 font-sans text-ui text-carbon">
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Homepage: what we do + who for</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Social proof: client results</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Primary CTA: call / form / quote</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Credibility signals: quals, certs</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Google search: service keywords</li>
            </ul>
          </div>

          <div class="bg-surface rounded-2xl p-8 md:p-10 border border-carbon/5 shadow-subtle hover:shadow-elegant transition-shadow">
            <p class="font-mono text-badge uppercase text-terracotta mb-4">Type 02</p>
            <h3 class="font-display font-bold text-headline uppercase text-carbon mb-2">Personal brand</h3>
            <p class="font-serif italic text-accent text-softGrey mb-8">The person IS the business: coach, speaker, consultant, creator, author.</p>
            <ul class="space-y-3 font-sans text-ui text-carbon">
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Homepage: who I am + what I believe</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Social proof: media, talks, publications</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Primary CTA: work with me / join / buy</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Multiple audience routing</li>
              <li class="flex items-start gap-3"><span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span> Google search: name + topic keywords</li>
            </ul>
          </div>
        </div>

        <div class="bg-carbon text-bone rounded-2xl p-6 text-center font-sans text-ui shadow-elegant mb-8">
          <strong class="font-medium text-white uppercase tracking-wide">Both types:</strong> same Astro + Tailwind + Vercel stack &middot; same caretaker model &middot; same Drive-Home Interview &middot; same on-demand updates
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          <div class="bg-surface rounded-xl p-6 text-center border border-deepGreen/20 shadow-subtle relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-deepGreen"></div>
            <p class="font-sans font-bold text-sm text-carbon mb-1 mt-2">Presence</p>
            <p class="font-sans text-[11px] text-softGrey">Exist, look credible, get found</p>
          </div>
          <div class="bg-surface rounded-xl p-6 text-center border border-deepGreen/20 shadow-subtle relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-deepGreen"></div>
            <p class="font-sans font-bold text-sm text-carbon mb-1 mt-2">Authority</p>
            <p class="font-sans text-[11px] text-softGrey">Portfolio, blog, thought leader hub</p>
          </div>
          <div class="bg-surface rounded-xl p-6 text-center border border-deepGreen/20 shadow-subtle relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-deepGreen"></div>
            <p class="font-sans font-bold text-sm text-carbon mb-1 mt-2">Community</p>
            <p class="font-sans text-[11px] text-softGrey">Email capture, lead magnet</p>
          </div>
          <div class="bg-surface rounded-xl p-6 text-center border border-deepGreen/20 shadow-subtle relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-deepGreen"></div>
            <p class="font-sans font-bold text-sm text-carbon mb-1 mt-2">Commerce</p>
            <p class="font-sans text-[11px] text-softGrey">Stripe services, digital products</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center border border-carbon/10 shadow-subtle">
            <p class="font-sans font-bold text-sm text-softGrey mb-1">E-commerce</p>
            <p class="font-sans text-[11px] text-softGrey/70">Shopify &rarr; Refer out</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center border border-carbon/10 shadow-subtle">
            <p class="font-sans font-bold text-sm text-softGrey mb-1">App / Platform</p>
            <p class="font-sans text-[11px] text-softGrey/70">Custom dev &rarr; Refer out</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DIAGRAM 02: THE ECOSYSTEM -->
    <section class="py-24 md:py-32 bg-bone border-b border-carbon/5" id="ecosystem">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <span class="font-mono text-badge uppercase text-terracotta mb-4 block">Diagram 02</span>
          <h2 class="font-display font-bold text-display uppercase tracking-tight mb-4 text-carbon">
            The Digital <span class="font-serif italic text-softGrey normal-case font-normal">Ecosystem.</span>
          </h2>
          <p class="font-sans text-body text-softGrey max-w-2xl mx-auto">
            Where YourHQ sits relative to every other type of web service.
          </p>
        </div>

        <div class="max-w-4xl mx-auto">
          <!-- Traffic -->
          <div class="flex flex-wrap justify-center gap-3 mb-6">
            {['Google / SEO', 'Meta Ads', 'LinkedIn', 'Instagram', 'Podcast / Press', 'Referral / WOM'].map((item) => (
              <div class="px-5 py-2.5 rounded-full bg-white border border-carbon/10 shadow-subtle font-sans text-xs font-medium text-softGrey">{item}</div>
            ))}
          </div>

          <!-- Arrow -->
          <div class="flex justify-center mb-6">
            <div class="w-px h-10 bg-carbon/20 relative">
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-2 h-2 border-r border-b border-carbon/40 rotate-45"></div>
            </div>
          </div>

          <!-- The Source -->
          <div class="bg-carbon text-white rounded-3xl p-10 text-center shadow-elegant mb-6 relative z-10 hover:shadow-float transition-shadow">
            <h3 class="font-display font-bold text-headline uppercase mb-2">The Website. The Source.</h3>
            <p class="font-sans text-ui text-bone/70">Everything else is a signal. This is where it all leads. Owned, permanent, never disappears.</p>
          </div>

          <!-- Arrow -->
          <div class="flex justify-center mb-6">
            <div class="w-px h-10 bg-carbon/20 relative">
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-2 h-2 border-r border-b border-carbon/40 rotate-45"></div>
            </div>
          </div>

          <!-- YourHQ Builds -->
          <div class="flex flex-wrap justify-center gap-3 mb-10">
            {['Build + Copy + Care', 'Forms + Capture', 'Stripe / Checkout', 'Blog + Autopilot'].map((item) => (
              <div class="px-5 py-2.5 rounded-full bg-deepGreen text-white shadow-subtle font-sans text-xs font-medium">{item}</div>
            ))}
          </div>

          <!-- Partners & Referrals -->
          <div class="grid md:grid-cols-2 gap-8 pt-10 border-t border-carbon/10">
            <div>
              <p class="font-mono text-badge text-carbon uppercase mb-4 text-center md:text-left">Partners (We work alongside)</p>
              <div class="flex flex-wrap justify-center md:justify-start gap-2">
                {['Copywriter', 'Photographer', 'Brand Designer', 'SEO Specialist', 'Social Media Mgr'].map((item) => (
                  <div class="px-4 py-2 rounded-lg bg-surface border border-carbon/10 font-sans text-[11px] text-carbon">{item}</div>
                ))}
              </div>
            </div>
            <div>
              <p class="font-mono text-badge text-softGrey uppercase mb-4 text-center md:text-left">Refer Out (Not our lane)</p>
              <div class="flex flex-wrap justify-center md:justify-start gap-2">
                {['Shopify', 'Kajabi / LMS', 'Circle / Community', 'Substack / Ghost', 'HubSpot / CRM', 'Custom Dev'].map((item) => (
                  <div class="px-4 py-2 rounded-lg bg-white border border-carbon/5 text-softGrey font-sans text-[11px] line-through decoration-softGrey/40">{item}</div>
                ))}
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- DIAGRAM 03: TECH STACK -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/5" id="stack">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-16 md:flex justify-between items-end">
          <div class="max-w-2xl">
            <span class="font-mono text-badge uppercase text-terracotta mb-4 block">Diagram 03</span>
            <h2 class="font-display font-bold text-display uppercase tracking-tight mb-4 text-carbon">
              The Technology <span class="font-serif italic text-softGrey normal-case font-normal">Stack.</span>
            </h2>
            <p class="font-sans text-body text-softGrey">
              Six layers, bottom to top. Most people only see layer 6. Understanding the stack is why our sites are faster and more secure.
            </p>
          </div>
        </div>

        <div class="max-w-4xl bg-white rounded-3xl shadow-elegant border border-carbon/5 overflow-hidden">
          {techStack.map((layer, i) => (
            <div class={`flex flex-col md:flex-row p-6 md:p-8 gap-6 md:gap-8 items-start md:items-center group transition-colors ${i !== techStack.length - 1 ? 'border-b border-carbon/5' : ''} hover:bg-bone`}>
              <div class="w-14 h-14 rounded-full bg-surface border border-carbon/5 flex items-center justify-center font-mono text-xl font-bold text-carbon shrink-0 group-hover:bg-deepGreen group-hover:text-white group-hover:border-deepGreen transition-colors">
                {layer.num}
              </div>
              <div class="flex-grow">
                <h3 class="font-display font-bold text-subhead mb-2 text-carbon">{layer.title}</h3>
                <p class="font-sans text-ui text-softGrey max-w-xl leading-relaxed">{layer.desc}</p>
              </div>
              <div class="shrink-0 w-full md:w-auto md:text-right mt-4 md:mt-0">
                <span class={`inline-block px-4 py-2 font-mono text-[10px] uppercase tracking-widest rounded-lg ${layer.bg} ${layer.text}`}>{layer.tag}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DIAGRAM 04: BUILD WORKFLOW -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/5" id="workflow">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-16">
          <span class="font-mono text-badge uppercase text-terracotta mb-4 block">Diagram 04</span>
          <h2 class="font-display font-bold text-display uppercase tracking-tight mb-4 text-carbon">
            The Build <span class="font-serif italic text-softGrey normal-case font-normal">Workflow.</span>
          </h2>
          <p class="font-sans text-body text-softGrey max-w-2xl">
            From Drive-Home Interview to live site. The caretaker relationship begins at launch.
          </p>
        </div>

        <div class="max-w-3xl relative">
          <!-- Continuous Line -->
          <div class="absolute left-6 top-6 bottom-6 w-px bg-carbon/10"></div>

          <div class="space-y-8 relative">
            
            <!-- Step 1 -->
            <div class="flex gap-8 group">
              <div class="w-12 h-12 rounded-full bg-surface border border-carbon/10 flex items-center justify-center font-mono text-lg font-bold text-terracotta shrink-0 relative z-10 group-hover:bg-terracotta group-hover:text-white transition-colors">1</div>
              <div class="bg-surface rounded-2xl p-6 md:p-8 shadow-subtle flex-grow border border-carbon/5 group-hover:shadow-elegant transition-all">
                <p class="font-mono text-[10px] uppercase tracking-widest text-terracotta mb-2">Client Action</p>
                <h3 class="font-display font-bold text-subhead mb-2 text-carbon">Drive-Home Interview</h3>
                <p class="font-sans text-ui text-softGrey">Client calls the AI voice agent. On the couch, in the car, between jobs. Their own time, their own terms. No forms, no typing, no scheduled Zoom. Just talk.</p>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-8 group">
              <div class="w-12 h-12 rounded-full bg-surface border border-carbon/10 flex items-center justify-center font-mono text-lg font-bold text-softGrey shrink-0 relative z-10 transition-colors">2</div>
              <div class="bg-white rounded-2xl p-6 md:p-8 shadow-subtle flex-grow border border-carbon/5">
                <p class="font-mono text-[10px] uppercase tracking-widest text-softGrey mb-2">Automation</p>
                <h3 class="font-display font-bold text-subhead mb-2 text-carbon">Agent drafts copy + content raid</h3>
                <p class="font-sans text-ui text-softGrey">The agent processes the transcript and raids the client's existing footprint. Pulls photos, testimonials, business info. Drafts all page copy. Time from client: zero.</p>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-8 group">
              <div class="w-12 h-12 rounded-full bg-surface border border-carbon/10 flex items-center justify-center font-mono text-lg font-bold text-carbon shrink-0 relative z-10 transition-colors">3</div>
              <div class="bg-white rounded-2xl p-6 md:p-8 shadow-subtle flex-grow border border-carbon/5">
                <p class="font-mono text-[10px] uppercase tracking-widest text-carbon mb-2">Lian Touchpoint</p>
                <h3 class="font-display font-bold text-subhead mb-2 text-carbon">Lian reviews copy</h3>
                <p class="font-sans text-ui text-softGrey">Lian reads the agent's draft, refines the voice, flags anything needed, and approves it for client review. Quality control before the client sees it.</p>
              </div>
            </div>

            <!-- Step 4 -->
