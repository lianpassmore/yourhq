---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const buildLink = "https://buy.stripe.com/00w00i6me14s4BLev9dZ604";

const testimonials = [
  { quote: "Creating a website wasn't something I was looking forward to. But the whole process was smooth, easy and stress-free. The outcome is clean, professional, and suits our business perfectly.", author: "Brad", role: "Carve Earthworks · Earthworks · Northland", color: "border-signal" },
  { quote: "While I was still figuring out Google Drive, Lian had already pulled images from our Facebook and had a draft site ready. My mates reckon it's banging.", author: "Reuben", role: "Johnson & Sons · Commercial Builder", color: "border-frangipani" }
];
---

<Layout
  title="Websites for Tradies NZ | Hand-Coded, Looked After Forever | YourHQ"
  description="Hand-coded websites for New Zealand tradies. Electricians, plumbers, builders, earthworks, painters, landscapers. One conversation. Live in 1 to 2 weeks. From $1,800 NZD + GST. Looked after forever."
>
  <Navbar client:load />

  <main class="bg-paper min-h-screen">

    <!-- HERO -->
    <section class="pt-32 pb-20 border-b border-carbon bg-[size:40px_40px] bg-grid-pattern">
      <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="inline-block py-1 px-3 rounded-full bg-signal/10 text-signal font-bold text-sm mb-6 tracking-wide uppercase font-mono">
            For Tradies
          </span>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[0.95] mb-8">
            You're Brilliant at Your Trade.<br/>
            <span class="text-signal">You Shouldn't Have to Be Brilliant at Websites Too.</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-700 max-w-3xl leading-relaxed mb-2">
            Hand-coded websites for New Zealand tradies. One conversation, written in your voice, hosted and looked after forever.
          </p>
          <p class="font-mono text-xs uppercase tracking-widest text-gray-500">
            From $1,800 NZD + GST &middot; from $129/mo NZD &middot; Built in Aotearoa &middot; Working nationwide
          </p>
        </div>
      </div>
    </section>

    <!-- THE PAIN -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-10 leading-tight">
          You Win Work on Reputation.<br/>
          <span class="text-gray-400">Online Should Match.</span>
        </h2>
        <div class="space-y-6 text-lg text-carbon/90 leading-relaxed">
          <p>
            You've been doing this long enough to know what good work looks like. Years of jobs, repeat clients, the kind of word of mouth that doesn't lie.
          </p>
          <p>
            But when someone Googles your name before they call, what do they find? An old Facebook page. A half-built Wix site. A listing with no photos. Or nothing.
          </p>
          <p>
            That's the gap I close.
          </p>
          <p class="font-bold text-carbon">
            Your online presence should look as solid as the work you actually do.
          </p>
        </div>
      </div>
    </section>

    <!-- BUILT FOR -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
            Built For Trades<br/>
            <span class="text-gray-400">That Win Work on Quality.</span>
          </h2>
          <div class="grid md:grid-cols-2 gap-0 border-l border-t border-carbon">
            {[
              ['Electricians', 'Domestic, commercial, industrial'],
              ['Builders', 'New builds, renovations, light commercial'],
              ['Earthworks &amp; Civil', 'Driveways, sites, drainage, demolition'],
              ['Plumbers &amp; Drainlayers', 'Maintenance and new work'],
              ['Painters &amp; Decorators', 'Interior, exterior, commercial'],
              ['Landscapers &amp; Concreters', 'Hard and soft landscaping']
            ].map(([trade, sub]) => (
              <div class="bg-white border-r border-b border-carbon p-6">
                <p class="font-extrabold text-lg mb-1">{trade}</p>
                <p class="font-mono text-xs uppercase tracking-widest text-gray-500">{sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
          What You Get.<br/>
          <span class="text-gray-400">All In.</span>
        </h2>

        <ul class="space-y-5 text-lg text-carbon/90">
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-signal text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">A site built in your voice, from one phone call.</p>
              <p class="text-base text-carbon/70">No forms. No copy briefs. No Zoom meetings. The Drive-Home Interview takes 15 minutes, hands-free.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-signal text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Hand-coded. Loads in under a second.</p>
              <p class="text-base text-carbon/70">No WordPress. No Wix. No page-builder bloat. Built the way Google and AI engines actually want to see.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-signal text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Google Business Profile set up or sorted.</p>
              <p class="text-base text-carbon/70">So people searching for your trade in your area actually find you.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-signal text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Owned by you. Unconditionally.</p>
              <p class="text-base text-carbon/70">Domain in your name from day one. If you ever leave, you take everything.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-signal text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Looked after forever.</p>
              <p class="text-base text-carbon/70">Hosting, security, on-demand updates by text, plus an annual design refresh. From $129/mo NZD.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-16 text-center">
          Real Tradies. <span class="text-signal">Real Sites.</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-8">
          {testimonials.map((t) => (
            <div class={`bg-white text-carbon p-8 border-l-8 ${t.color} shadow-hard-sm`}>
              <p class="text-lg italic leading-relaxed mb-6">"{t.quote}"</p>
              <div class="border-t border-carbon/10 pt-4">
                <p class="font-extrabold">{t.author}</p>
                <p class="font-mono text-xs text-gray-500 uppercase tracking-widest">{t.role}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="text-center mt-12">
          <a href="/portfolio" class="inline-block font-bold uppercase tracking-widest text-sm text-carbon border-b-2 border-signal hover:text-signal transition-colors">
            See the full portfolio &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-32 bg-carbon text-white text-center">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tighter mb-8 leading-tight">
          People Are Already Searching for Your Trade. <span class="text-signal">Let's Build the Place They Find.</span>
        </h2>
        <p class="text-xl text-gray-300 mb-12 leading-relaxed">
          One conversation. Live in 1 to 2 weeks.<br/>
          Hand-coded, in your voice, looked after forever.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={buildLink} class="inline-block bg-signal text-white px-12 py-5 border-2 border-signal hover:bg-transparent hover:text-white transition-colors font-bold uppercase tracking-widest text-lg">
            Start Your Build
          </a>
          <a href="/pricing" class="inline-block bg-transparent text-white px-12 py-5 border-2 border-white hover:bg-white hover:text-carbon transition-colors font-bold uppercase tracking-widest text-lg">
            See Pricing
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
