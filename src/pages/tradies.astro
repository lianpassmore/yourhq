---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const buildLink = "/start-build";

const tradiesServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Websites for Tradies in New Zealand",
  "description": "Hand-coded websites for New Zealand tradies — electricians, plumbers, builders, earthworks, painters, landscapers. One Drive-Home Interview, written in your voice, live in 1 to 2 weeks.",
  "serviceType": "Website Design and Development",
  "provider": { "@id": "https://yourhq.co.nz/#organization" },
  "areaServed": { "@type": "Country", "name": "New Zealand" },
  "audience": {
    "@type": "BusinessAudience",
    "audienceType": "Tradies, electricians, plumbers, builders, earthworks contractors, painters, landscapers"
  },
  "offers": {
    "@type": "Offer",
    "price": "1800",
    "priceCurrency": "NZD",
    "url": "https://yourhq.co.nz/start-build"
  }
};

const trades = [
  ['Electricians', 'Domestic, commercial, industrial'],
  ['Builders', 'New builds, renovations, light commercial'],
  ['Earthworks & Civil', 'Driveways, sites, drainage, demolition'],
  ['Plumbers & Drainlayers', 'Maintenance and new work'],
  ['Painters & Decorators', 'Interior, exterior, commercial'],
  ['Landscapers & Concreters', 'Hard and soft landscaping']
];

const testimonials = [
  { quote: "Creating a website wasn't something I was looking forward to. But the whole process was smooth, easy and stress-free. The outcome is clean, professional, and suits our business perfectly.", author: 'Brad', role: 'Carve Earthworks · Earthworks · Northland' },
  { quote: "While I was still figuring out Google Drive, Lian had already pulled images from our Facebook and had a draft site ready. My mates reckon it's banging.", author: 'Reuben', role: 'Johnson & Sons · Commercial Builder' }
];

const included = [
  { title: 'A site built in your voice, from one phone call.', body: 'No forms. No copy briefs. No Zoom meetings. The Drive-Home Interview takes about 20 minutes, hands-free.' },
  { title: 'Hand-coded. Loads in under a second.', body: 'No WordPress. No Wix. No page-builder bloat. Built the way Google and AI search engines actually want to see.' },
  { title: 'Google Business Profile set up or sorted.', body: 'So people searching for your trade in your area actually find you.' },
  { title: 'Owned by you. Unconditionally.', body: 'Domain in your name from day one. If you ever leave, you take everything.' },
  { title: 'Looked after forever.', body: 'Hosting, security, on-demand updates. Message me when something changes. From $149/mo NZD.' }
];
---

<Layout
  title="Websites for Tradies NZ | Hand-Coded, Looked After Forever | YourHQ"
  description="Hand-coded websites for New Zealand tradies. Electricians, plumbers, builders, earthworks, painters, landscapers. One conversation. Live in 1 to 2 weeks. From $2,500 NZD + GST. Looked after forever."
>
  <BreadcrumbSchema
    slot="head"
    items={[
      { name: 'Home', url: 'https://yourhq.co.nz/' },
      { name: 'Who We Build For', url: 'https://yourhq.co.nz/who-we-build-for' },
      { name: 'Tradies', url: 'https://yourhq.co.nz/tradies' }
    ]}
  />
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify(tradiesServiceSchema)} />
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white">

    <!-- ============================================================
         01 · HERO
    ============================================================ -->
    <section class="relative bg-bone pt-24 md:pt-32 pb-24 md:pb-32 px-4 sm:px-6 lg:px-8 border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto">
        <div class="max-w-4xl">
          <span class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-signal mb-8 font-medium flex items-center gap-3">
            <span class="w-8 h-[1px] bg-signal"></span> For Tradies &amp; Builders
          </span>
          <h1 class="font-display font-bold text-[clamp(3rem,7vw,6.5rem)] leading-[0.95] tracking-tight text-carbon">
            <span class="block uppercase">You're brilliant</span>
            <span class="block font-serif italic text-softGrey normal-case mt-2 mb-4 text-[clamp(1.5rem,4vw,3.5rem)] leading-none">at your trade.</span>
            <span class="block uppercase">You shouldn't have to be</span>
            <span class="block font-serif italic text-signal normal-case mt-2 text-[clamp(1.5rem,4vw,3.5rem)] leading-none">brilliant at websites too.</span>
          </h1>
          <p class="font-sans text-lg md:text-xl text-carbon/80 max-w-2xl leading-relaxed mt-10">
            Hand-coded websites for New Zealand tradies. One conversation, written in your voice, looked after forever.
          </p>
          <p class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-deepGreen mt-6 font-medium">
            From $3,800 NZD + GST · from $149/mo NZD · Built in Aotearoa · Working nationwide
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4 font-sans">
            <a href={buildLink} class="bg-carbon text-white px-8 py-3.5 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors duration-300 text-center shadow-subtle">
              Start Your Build
            </a>
            <a href="/pricing" class="bg-transparent text-carbon border border-carbon/20 px-8 py-3.5 rounded-full font-medium text-sm hover:border-carbon transition-colors duration-300 text-center">
              See Pricing
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         02 · THE GAP
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display font-bold text-[clamp(2.25rem,4.5vw,3.5rem)] uppercase leading-none tracking-tight mb-10">
          You win work on reputation.<br/>
          <span class="font-serif italic text-softGrey normal-case">Online should match.</span>
        </h2>
        <div class="space-y-6 font-sans text-lg text-carbon/80 leading-relaxed">
          <p>
            You've been doing this long enough to know what good work looks like. Years of jobs, repeat clients, the kind of word of mouth that doesn't lie.
          </p>
          <p>
            But when someone Googles your name before they call, what do they find? An old Facebook page. A half-built Wix site. A listing with no photos. Or nothing.
          </p>
          <p class="font-serif italic text-xl text-carbon">
            That's the gap I close.
          </p>
          <p class="font-medium text-carbon">
            Your online presence should look as solid as the work you actually do.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================
         03 · BUILT FOR
    ============================================================ -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-screen-xl mx-auto">
        <div class="max-w-4xl mx-auto">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">Built For</span>
          <h2 class="font-display font-bold text-[clamp(2.25rem,4.5vw,3.5rem)] uppercase leading-none tracking-tight mb-12">
            Trades that win work<br/>
            <span class="font-serif italic text-signal normal-case">on quality.</span>
          </h2>
          <div class="grid sm:grid-cols-2 gap-4 md:gap-6">
            {trades.map(([trade, sub]) => (
              <div class="bg-white rounded-2xl p-6 md:p-7 border border-carbon/10 shadow-subtle">
                <p class="font-display font-bold text-lg uppercase tracking-tight text-carbon mb-2">{trade}</p>
                <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">{sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         04 · WHAT YOU GET
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">What's Included</span>
        <h2 class="font-display font-bold text-[clamp(2.25rem,4.5vw,3.5rem)] uppercase leading-none tracking-tight mb-12">
          What you get.<br/>
          <span class="font-serif italic text-softGrey normal-case">All in.</span>
        </h2>

        <ul class="border-t border-carbon/10">
          {included.map((item, idx) => (
            <li class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-4 md:gap-6 items-start">
              <span class="font-mono col-span-2 text-[10px] uppercase tracking-[0.15em] text-signal mt-1">{String(idx + 1).padStart(2, '0')}</span>
              <div class="col-span-10">
                <p class="font-sans font-semibold text-lg md:text-xl text-carbon mb-2">{item.title}</p>
                <p class="font-sans text-base text-carbon/70 leading-relaxed">{item.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ============================================================
         05 · TESTIMONIALS
    ============================================================ -->
    <section class="py-24 md:py-32 bg-bone border-b border-carbon/10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-screen-xl mx-auto">
        <div class="text-center mb-16">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">Real Tradies</span>
          <h2 class="font-display font-bold text-[clamp(2.25rem,4.5vw,3.5rem)] uppercase leading-none tracking-tight">
            Real sites.<br/>
            <span class="font-serif italic text-signal normal-case">Real work.</span>
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6 md:gap-8">
          {testimonials.map((t) => (
            <figure class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle">
              <blockquote class="font-serif italic text-lg md:text-xl leading-snug text-carbon/85 mb-6">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              <figcaption class="border-t border-carbon/10 pt-4">
                <p class="font-display font-bold text-base uppercase tracking-tight text-carbon">{t.author}</p>
                <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey mt-1">{t.role}</p>
              </figcaption>
            </figure>
          ))}
        </div>
        <div class="text-center mt-12">
          <a href="/portfolio" class="inline-block font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border-b border-carbon/20 pb-1 hover:border-carbon transition-colors">
            See the full portfolio &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         06 · FINAL CTA
    ============================================================ -->
    <section class="py-24 md:py-32 bg-carbon text-bone border-y border-carbon px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-display font-bold text-[clamp(2.5rem,5vw,4rem)] uppercase leading-none tracking-tight text-white mb-8">
          People are already searching<br/>
          <span class="font-serif italic text-signal normal-case">for your trade.</span>
        </h2>
        <p class="font-serif italic text-xl md:text-2xl text-bone/80 mb-12 leading-snug">
          Let's build the place they find.<br/>
          <span class="text-white">One conversation. Live in 1 to 2 weeks.</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center font-sans">
          <a href={buildLink} class="bg-white text-carbon px-8 py-3.5 rounded-full font-medium text-sm hover:bg-bone transition-colors duration-300 text-center shadow-subtle">
            Start Your Build
          </a>
          <a href="/pricing" class="bg-transparent text-white border border-white/30 px-8 py-3.5 rounded-full font-medium text-sm hover:border-white transition-colors duration-300 text-center">
            See Pricing
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
