---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const stripeLink = "https://buy.stripe.com/7sYfZgaCu5kIb093QvdZ60b";
---

<Layout
  title="Connected Caretaker | YourHQ"
  description="Level 2 Caretaker. $199/month NZD. 1 hour of included dev time, plus everything in Sorted, plus monitoring of booking and email integrations."
>
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white pb-32">

    <!-- HERO -->
    <section class="pt-24 md:pt-32 pb-20 border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-badge uppercase text-signal mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-signal"></span> Caretaker &middot; Level 2
          </span>
          <h1 class="font-display font-bold text-hero uppercase tracking-tight leading-none mb-8 text-carbon">
            Connected.<br/>
            <span class="font-serif italic text-signal normal-case font-normal">For Sites Doing Active Work.</span>
          </h1>
          <p class="font-sans text-subhead text-softGrey max-w-2xl">
            Your site is doing real work. Booking systems running, email list growing, more regular updates. More moving parts, more care.
          </p>
        </div>
      </div>
    </section>

    <!-- PRICE + INCLUSIONS -->
    <section class="py-24 md:py-32 bg-white border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

          <!-- Price card (Sticky) -->
          <div class="lg:col-span-5 relative">
            <div class="bg-surface rounded-3xl p-8 md:p-10 border border-carbon/5 shadow-elegant sticky top-32">
              <p class="font-mono text-badge uppercase tracking-widest text-signal mb-4">Connected</p>

              <div class="flex items-baseline gap-2 mb-4">
                <span class="font-display font-bold text-[4rem] leading-none text-carbon tracking-tight">$199</span>
                <span class="font-mono text-badge text-softGrey uppercase">NZD / month</span>
              </div>

              <p class="font-mono text-[10px] text-softGrey uppercase tracking-widest mb-10 pb-6 border-b border-carbon/5 leading-relaxed">
                NZD + GST &middot; cancel anytime <br/> 30 days notice
              </p>

              <a href={stripeLink} class="block w-full bg-signal text-white text-center px-8 py-4 rounded-full font-medium text-ui shadow-subtle hover:shadow-float hover:bg-carbon transition-all duration-300 mb-6">
                Start Connected
              </a>

              <a href="/pricing" class="block text-center font-sans text-ui font-medium text-softGrey hover:text-carbon transition-colors">
                Compare All Tiers &rarr;
              </a>
            </div>
          </div>

          <!-- Inclusions -->
          <div class="lg:col-span-7 pt-4">
            <h2 class="font-display font-bold text-display uppercase tracking-tight mb-12 text-carbon">
              What's <span class="font-serif italic text-softGrey normal-case font-normal">Included.</span>
            </h2>

            <div class="bg-surface rounded-2xl p-6 border border-carbon/5 shadow-subtle mb-10 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-1 h-full bg-deepGreen"></div>
              <p class="font-mono text-badge uppercase tracking-widest text-deepGreen mb-2">Everything in Sorted</p>
              <p class="font-sans text-body text-softGrey">
                Hosting, SSL, backups, security, and on-demand updates.
              </p>
            </div>

            <p class="font-mono text-badge uppercase tracking-widest text-signal mb-6">Plus, on top</p>

            <ul class="space-y-6 font-sans text-body text-softGrey mb-16">
              <li class="flex gap-5 border-b border-carbon/5 pb-6">
                <span class="text-signal text-2xl font-serif mt-1">&check;</span>
                <div>
                  <p class="font-sans font-bold text-carbon text-lg mb-1">1 hour of included dev time</p>
                  <p class="text-softGrey">Each month. For the more regular updates that come with an active site. Anything beyond that is quoted before it starts.</p>
                </div>
              </li>
              <li class="flex gap-5 border-b border-carbon/5 pb-6">
                <span class="text-signal text-2xl font-serif mt-1">&check;</span>
                <div>
                  <p class="font-sans font-bold text-carbon text-lg mb-1">Booking platform monitoring</p>
                  <p class="text-softGrey">If your Calendly, Acuity, or Timely embed breaks or changes, I notice and fix it before you do.</p>
                </div>
              </li>
              <li class="flex gap-5">
                <span class="text-signal text-2xl font-serif mt-1">&check;</span>
                <div>
                  <p class="font-sans font-bold text-carbon text-lg mb-1">Email platform monitoring</p>
                  <p class="text-softGrey">Your capture forms, welcome sequence, and lead magnet stay wired up and delivering. If something goes silent, I'm on it.</p>
                </div>
              </li>
            </ul>

            <div class="bg-surface rounded-2xl p-8 border border-carbon/5 shadow-subtle relative overflow-hidden">
              <div class="absolute top-0 left-0 w-1 h-full bg-signal"></div>
              <p class="font-display font-bold text-subhead text-carbon mb-2">When Connected is right for you</p>
              <p class="font-sans text-body text-softGrey leading-relaxed">
                Your site is doing active work. Bookings come through it, email captures convert, you're updating it more regularly than once in a blue moon. The extra time and monitoring keep it running cleanly without you having to think about it.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- PAUSE / CANCEL -->
    <section class="py-24 md:py-32 bg-surface border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle hover:shadow-elegant transition-all duration-300">
            <p class="font-mono text-badge uppercase tracking-widest text-signal mb-4">Pause Anytime</p>
            <p class="font-sans text-body text-softGrey leading-relaxed">
              Hosting and security continue. Site stays live. No penalty.
            </p>
          </div>
          <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle hover:shadow-elegant transition-all duration-300">
            <p class="font-mono text-badge uppercase tracking-widest text-terracotta mb-4">Cancel Anytime</p>
            <p class="font-sans text-body text-softGrey leading-relaxed">
              30 days notice. Full static export of your site. You own your domain, content, and design from day one.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- HELP CTA -->
    <section class="py-32 bg-carbon text-bone text-center px-4">
      <div class="max-w-3xl mx-auto">
        <span class="font-mono text-badge uppercase text-terracotta block mb-6">The Next Step</span>
        <h2 class="font-display font-bold text-display uppercase tracking-tight mb-12 text-white">
          Questions Before <br/>
          <span class="font-serif italic text-bone/60 normal-case font-normal">You Sign Up?</span>
        </h2>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="sms:0275668803" class="inline-flex justify-center items-center bg-bone text-carbon px-8 py-4 rounded-full font-medium text-ui hover:bg-deepGreen hover:text-white transition-all duration-300 shadow-elegant hover:shadow-float">
            Text 027 566 8803
          </a>
          <a href="mailto:lian@yourhq.co.nz" class="inline-flex justify-center items-center bg-transparent text-bone border border-bone/30 px-8 py-4 rounded-full font-medium text-ui hover:border-bone transition-colors duration-300">
            Email lian@yourhq.co.nz
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
