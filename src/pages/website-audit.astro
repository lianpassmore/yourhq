---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const stripeLink = "https://buy.stripe.com/aFadR825Y00oeclbiXdZ60j";
---

<Layout
  title="The Website Audit | YourHQ"
  description="A full professional read of your current website. Scored, diagnosed, and written up in a single document, delivered to your inbox within five working days."
>
  <Navbar client:load />

  <!-- Global: Bone background, Carbon text. The clean, breathing room of the new brand. -->
  <main class="bg-bone text-carbon min-h-screen font-sans selection:bg-deepGreen selection:text-white">

    <!-- 1. HERO: The Architectural Vibe -->
    <section class="pt-32 pb-16 px-6 lg:px-12 border-b border-carbon/10">
      <div class="max-w-7xl mx-auto">

        <!-- Top Meta Data Row -->
        <div class="flex justify-between items-start border-b border-carbon/10 pb-4 mb-16">
          <p class="font-mono text-badge text-softGrey">
            RC / Diagnostic &middot; {new Date().getFullYear()}
          </p>
          <p class="font-mono text-badge text-softGrey text-right">
            Any Platform<br/>Up To Eight Pages
          </p>
        </div>

        <!-- Massive Decisive Headline (Agrandir Display) -->
        <div class="max-w-5xl">
          <h1 class="font-display text-hero font-bold text-carbon mb-6">
            The<br/>Website Audit.
          </h1>

          <div class="grid md:grid-cols-12 gap-8 items-end mt-12">
            <div class="md:col-span-8">
              <!-- The Whisper (Tension Technique) -->
              <p class="font-serif italic text-headline text-terracotta">
                A full professional read of your site. <br/>
                <span class="text-carbon">Scored. Diagnosed. Written up.</span>
              </p>
            </div>
            <div class="md:col-span-4">
              <!-- Clear, functional DM Sans Body -->
              <p class="font-sans text-body text-softGrey">
                One document in your inbox within five working days. You answer eight questions by email. Everything else is handled.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- 2. THE SPLIT: Details & Pricing -->
    <section class="py-24 px-6 lg:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-12 gap-y-16 lg:gap-x-16">

          <!-- Left: The Price (Elevated Card) -->
          <div class="lg:col-span-5">
            <div class="sticky top-32">

              <!-- Refined White Card with High-End Shadow -->
              <div class="bg-white rounded-2xl p-8 md:p-12 shadow-elegant border border-carbon/5 relative">

                <p class="font-mono text-badge text-softGrey mb-8 border-b border-carbon/10 pb-4">The Audit</p>

                <p class="font-display text-price font-bold text-carbon mb-2">
                  $997
                </p>

                <div class="flex items-center gap-3 mb-10">
                  <span class="font-mono text-badge text-carbon">NZD + GST</span>
                  <span class="w-full h-[1px] bg-carbon/10"></span>
                </div>

                <p class="font-sans text-ui text-softGrey mb-10">
                  One-time payment. Delivered as a single written document within five working days. Afterpay available at checkout for eligible NZ customers.
                </p>

                <!-- Signal Blue CTA -->
                <a href={stripeLink} class="block w-full bg-signal text-white rounded-full text-center px-8 py-4 text-ui font-medium hover:bg-carbon hover:shadow-float transition-all duration-300">
                  Order the Website Audit
                </a>
              </div>

              <!-- Functional Callout -->
              <div class="mt-8 ml-4 md:ml-8 border-l-2 border-signal pl-6">
                <p class="font-sans text-ui text-softGrey max-w-[250px]">
                  After payment, we'll email you eight questions. Answer them and the work begins.
                </p>
              </div>
            </div>
          </div>

          <!-- Right: What's Included -->
          <div class="lg:col-span-7">
            <h2 class="font-display text-headline font-bold text-carbon mb-12">What You Get.</h2>

            <div class="border-t border-carbon/10">

              <!-- Item 1 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">01</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">A score out of 50</p>
                  <p class="font-sans text-body text-softGrey">Every page scored across five dimensions, plus the ten-second test on your homepage hero. You see exactly where you stand.</p>
                </div>
              </div>

              <!-- Item 2 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">02</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">What's working, what's holding you back</p>
                  <p class="font-sans text-body text-softGrey">Every finding carries a risk tag, so you know what to fix first and what can wait.</p>
                </div>
              </div>

              <!-- Item 3 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">03</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">Path to purchase and trust check</p>
                  <p class="font-sans text-body text-softGrey">How a visitor actually moves toward buying, and whether your site earns enough trust to let them.</p>
                </div>
              </div>

              <!-- Item 4 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">04</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">Site sizing and a new structure</p>
                  <p class="font-sans text-body text-softGrey">Pages to keep, pages to cut, pages to add, and a recommended structure for the site you should have.</p>
                </div>
              </div>

              <!-- Item 5 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">05</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">Page-by-page copy in your voice</p>
                  <p class="font-sans text-body text-softGrey">Written copy for the recommended new structure, in your voice, ready to use.</p>
                </div>
              </div>

              <!-- Item 6 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">06</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">Before-and-after comparisons</p>
                  <p class="font-sans text-body text-softGrey">Your two or three weakest pages rewritten side by side, so the difference is plain to see.</p>
                </div>
              </div>

              <!-- Item 7 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">07</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">SEO and AEO guidance per page</p>
                  <p class="font-sans text-body text-softGrey">How to be found by search engines and answer engines alike, page by page.</p>
                </div>
              </div>

              <!-- Item 8 -->
              <div class="py-8 border-b border-carbon/10 grid grid-cols-12 gap-6 items-start group">
                <span class="font-mono col-span-2 text-badge text-softGrey mt-1 group-hover:text-signal transition-colors">08</span>
                <div class="col-span-10">
                  <p class="font-sans font-semibold text-subhead text-carbon mb-2">Design direction and a clear next step</p>
                  <p class="font-sans text-body text-softGrey">Direction for how the site should look, and one clear recommendation on what to do next.</p>
                </div>
              </div>

            </div>

            <!-- Modern Editorial Callout Blocks -->
            <div class="mt-16 grid sm:grid-cols-2 gap-4">
              <!-- Deep Green Accent Block -->
              <div class="bg-surface rounded-xl p-8 border-l-4 border-deepGreen shadow-subtle">
                <p class="font-mono text-badge text-deepGreen mb-4">Works On Any Platform</p>
                <p class="font-sans text-ui text-softGrey">
                  WordPress, Squarespace, Wix, Shopify, custom builds. Covers sites up to eight pages.
                </p>
              </div>

              <!-- Terracotta Accent Block -->
              <div class="bg-surface rounded-xl p-8 border-l-4 border-terracotta shadow-subtle">
                <p class="font-mono text-badge text-terracotta mb-4">Larger Sites</p>
                <p class="font-sans text-ui text-softGrey">
                  More than eight pages, or something more complex? Email lian@yourhq.co.nz before purchasing.
                </p>
              </div>
            </div>

            <!-- Time Commitment Strip -->
            <div class="mt-4 bg-white rounded-xl p-8 border-l-4 border-signal shadow-subtle">
              <p class="font-mono text-badge text-signal mb-4">Your Time Commitment</p>
              <p class="font-sans text-ui text-softGrey">
                Eight questions, answered by email. That's it. Everything else is handled.
              </p>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- 3. HELP: High-end Sign-off -->
    <section class="py-24 px-6 border-t border-carbon/10">
      <div class="max-w-7xl mx-auto flex flex-col items-center text-center">

        <!-- Y Monogram Graphic -->
        <div class="w-12 h-12 rounded-full bg-surface border border-carbon/10 flex items-center justify-center text-terracotta font-serif italic text-2xl mb-8 shadow-subtle">
          Y
        </div>

        <h3 class="font-display text-headline font-bold text-carbon mb-12">Still have questions?</h3>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-8">
          <a href="sms:0275668803" class="font-mono text-badge text-carbon border-b border-carbon/20 pb-1 hover:text-signal hover:border-signal transition-colors duration-200">
            Text 027 566 8803
          </a>
          <span class="hidden sm:block w-1.5 h-1.5 bg-carbon/20 rounded-full"></span>
          <a href="mailto:lian@yourhq.co.nz" class="font-mono text-badge text-carbon border-b border-carbon/20 pb-1 hover:text-signal hover:border-signal transition-colors duration-200">
            lian@yourhq.co.nz
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
