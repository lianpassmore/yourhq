---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const buildLink = "/start-build";

const cities = [
  'Auckland', 'Wellington', 'Christchurch', 'Hamilton', 'Tauranga', 'Dunedin',
  'Whangārei', 'Palmerston North', 'Napier', 'Hastings', 'Nelson', 'Queenstown',
  'New Plymouth', 'Rotorua', 'Invercargill'
];

const faqs = [
  { q: 'How much does a professional website cost in New Zealand?', a: 'YourHQ websites start at $1,800 NZD + GST one-time, with monthly Caretaker care from $129/mo NZD. Traditional agencies typically charge $5,000 to $15,000 NZD upfront, then bill per change. DIY tools like Wix and Squarespace cost $30 to $50/mo NZD, but require 40 to 80 hours of your own time. We sit between the two with a productised, one-conversation model.' },
  { q: 'How long does it take to build a website in New Zealand?', a: 'Most YourHQ clients are live within 1 to 2 weeks. The whole thing takes less than 30 minutes of your time. One Drive-Home Interview, one round of copy feedback, then we build, preview, and go live.' },
  { q: 'Do you build websites outside Whangārei or Northland?', a: 'Yes. YourHQ is based in Whangārei and works with clients across all of New Zealand. Auckland, Wellington, Christchurch, Hamilton, Tauranga, the lot. The whole process happens remotely. Phone, email, and texts. No travel needed.' },
  { q: 'What makes YourHQ different from a traditional NZ web design agency?', a: 'Three things. First, every site is hand-coded by Lian personally. No outsourcing, no junior staff, no templates. Second, the Caretaker model means I stay on after launch. Hosting, security, updates, annual refresh. I don\'t build and disappear. Third, the price is fixed and known upfront.' },
  { q: 'What if I already have a website?', a: 'Most of my clients do. I start fresh, in your voice, to where you are now. Your old site stays up until launch day, then we transition the domain across.' },
  { q: 'Do I own the website I pay for?', a: 'Completely. Your domain, content, and design are yours unconditionally from day one. If you ever leave, I provide a full static export. Nothing held hostage.' },
  { q: 'Will my New Zealand website rank on Google?', a: 'Every YourHQ site is built for both standard search (SEO) and AI-generated answers (AEO). Mobile-first, hand-coded, loads in under a second, with proper structured data and Google Business Profile setup included.' }
];
---

<Layout
  title="Website Design NZ | Hand-Coded, Owned by You, Looked After Forever | YourHQ"
  description="Hand-coded website design across New Zealand. From $1,800 NZD + GST. One conversation, written in your voice, looked after forever. Auckland, Wellington, Christchurch, Whangārei, nationwide."
>
  <Navbar client:load />

  <main class="bg-paper min-h-screen">

    <!-- HERO -->
    <section class="pt-32 pb-20 border-b border-carbon bg-[size:40px_40px] bg-grid-pattern">
      <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="inline-block py-1 px-3 rounded-full bg-signal/10 text-signal font-bold text-sm mb-6 tracking-wide uppercase font-mono">
            Website Design &middot; New Zealand
          </span>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[0.95] mb-8">
            Website Design Across New Zealand.<br/>
            <span class="text-signal">Built Once. Looked After Forever.</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-700 max-w-3xl leading-relaxed mb-2">
            Hand-coded websites for established New Zealand businesses and personal brands. Written in your voice. Owned by you unconditionally. Refreshed every year.
          </p>
          <p class="font-mono text-xs uppercase tracking-widest text-gray-500">
            From $1,800 NZD + GST &middot; from $129/mo NZD &middot; Founded in Aotearoa &middot; Servicing nationwide
          </p>
        </div>
      </div>
    </section>

    <!-- THE THREE OPTIONS -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
          Three Ways to Get a Website in NZ.<br/>
          <span class="text-gray-400">Only One Stays With You.</span>
        </h2>

        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead>
              <tr class="bg-paper border-2 border-carbon">
                <th class="p-4 text-left font-mono text-xs uppercase tracking-widest text-gray-500"></th>
                <th class="p-4 text-left font-mono text-xs uppercase tracking-widest text-gray-500 border-l border-carbon">DIY (Wix / Squarespace)</th>
                <th class="p-4 text-left font-mono text-xs uppercase tracking-widest text-gray-500 border-l border-carbon">NZ Web Agency</th>
                <th class="p-4 text-left font-mono text-xs uppercase tracking-widest text-signal border-l border-carbon bg-signal/5">YourHQ</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['Setup cost', '$0', '$5,000–15,000', '$1,800 NZD + GST'],
                ['Your time', '40–80 hours', '6–12 weeks of briefing', 'One conversation'],
                ['Monthly', '$30–50', '$0 (then pay per change)', '$129–249 NZD'],
                ['Updates', 'You do it yourself', 'Invoice per change', 'Just text me'],
                ['Rebuild in 3 years', '$0 (you do it again)', '$5,000–15,000', '$0, refresh included'],
                ['Sounds like you', 'Rarely', 'Sometimes', 'Always']
              ].map(([label, diy, agency, yhq]) => (
                <tr class="border-x-2 border-b-2 border-carbon">
                  <td class="p-4 font-bold text-carbon bg-paper">{label}</td>
                  <td class="p-4 border-l border-carbon text-carbon/70">{diy}</td>
                  <td class="p-4 border-l border-carbon text-carbon/70">{agency}</td>
                  <td class="p-4 border-l border-carbon font-bold text-carbon bg-signal/5">{yhq}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS BRIEF -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
          One Conversation.<br/>
          <span class="text-gray-400">I Handle Everything Else.</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-0 border-l border-t border-carbon">
          {[
            ['01', 'The Drive-Home Interview', 'You call when it suits. Car, couch, between meetings. Hands-free for 15 minutes.'],
            ['02', 'I Write Your Copy', 'In your voice, reviewed by me. You see every section before I build a thing.'],
            ['03', 'The Content Raid', 'I go through your existing footprint. Socials, Google, anywhere you show up. You send me nothing.'],
            ['04', 'The Build', 'Hand-coded in Astro. Under a second to load. Mobile-first. Built for SEO and AEO.'],
            ['05', 'Preview', 'Private link. Love it, we go live. Don\'t love it, full refund.'],
            ['06', 'Go Live', 'Domain connected. Google notified. Your permanent address is set.'],
            ['07', 'The Caretakers Take Over', 'Hosting, security, updates, annual refresh. I stay.']
          ].map(([num, title, body]) => (
            <div class="bg-white border-r border-b border-carbon p-6">
              <p class="font-mono text-xs font-bold uppercase tracking-widest text-signal mb-2">Step {num}</p>
              <p class="font-extrabold text-lg mb-2">{title}</p>
              <p class="text-sm text-carbon/80 leading-relaxed">{body}</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-12">
          <a href="/how-it-works" class="inline-block font-bold uppercase tracking-widest text-sm text-carbon border-b-2 border-signal hover:text-signal transition-colors">
            See the full process &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- WHO WE BUILD FOR -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
          Built For Established<br/>
          New Zealand Businesses<br/>
          <span class="text-gray-400">and Personal Brands.</span>
        </h2>

        <div class="space-y-5">
          <div class="bg-paper border-l-4 border-signal p-6">
            <p class="font-mono text-xs font-bold uppercase tracking-widest text-signal mb-2">Trades &amp; Construction</p>
            <p class="text-carbon/90">Electricians, builders, earthworks, plumbers, painters, landscapers, concreters. <a href="/tradies" class="font-bold underline">More for tradies &rarr;</a></p>
          </div>
          <div class="bg-paper border-l-4 border-frangipani p-6">
            <p class="font-mono text-xs font-bold uppercase tracking-widest text-frangipani mb-2">Professional Services</p>
            <p class="text-carbon/90">Physiotherapists, accountants, lawyers, consultants, financial advisers, coaches, architects. <a href="/professionals" class="font-bold underline">More for professionals &rarr;</a></p>
          </div>
          <div class="bg-paper border-l-4 border-hibiscus p-6">
            <p class="font-mono text-xs font-bold uppercase tracking-widest text-hibiscus mb-2">Creatives, Hospo &amp; Personal Brands</p>
            <p class="text-carbon/90">Cafes, restaurants, photographers, designers, speakers, podcasters, stylists, writers. <a href="/creatives" class="font-bold underline">More for creatives &rarr;</a></p>
          </div>
        </div>
      </div>
    </section>

    <!-- NATIONWIDE -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-8 leading-tight">
          Working Across <span class="text-signal">All of New Zealand.</span>
        </h2>
        <p class="text-lg text-carbon/80 leading-relaxed mb-10">
          Based in Whangārei, Aotearoa. Working remotely with clients in every corner of the country.
        </p>
        <div class="flex flex-wrap gap-2">
          {cities.map((city) => (
            <span class="inline-block bg-white border border-carbon/20 px-4 py-2 text-sm font-bold text-carbon">
              {city}
            </span>
          ))}
        </div>
        <p class="text-base text-carbon/70 mt-8 italic">
          Not on the list? It doesn't matter. The whole process happens by phone, text, and email. Where you're based makes no difference.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 text-center">
          Common <span class="text-signal">Questions</span>
        </h2>
        <div class="space-y-8">
          {faqs.map((item) => (
            <div class="border-l-4 border-signal pl-6 py-2">
              <h3 class="text-xl font-bold mb-3 text-carbon">{item.q}</h3>
              <p class="text-carbon/80 leading-relaxed">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-32 bg-carbon text-white text-center">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tighter mb-8 leading-tight">
          Ready to Own<br/>Your Digital Home?
        </h2>
        <p class="text-xl text-gray-300 mb-12 leading-relaxed">
          One conversation. Live in 1 to 2 weeks.<br/>
          Hand-coded, in your voice, looked after forever.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={buildLink} class="inline-block bg-signal text-white px-12 py-5 border-2 border-signal hover:bg-transparent hover:text-white transition-colors font-bold uppercase tracking-widest text-lg">
            Start Your Build
          </a>
          <a href="/pricing" class="inline-block bg-transparent text-white px-12 py-5 border-2 border-white hover:bg-white hover:text-carbon transition-colors font-bold uppercase tracking-widest text-lg">
            See Pricing
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
