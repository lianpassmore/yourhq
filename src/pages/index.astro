---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/StructuredData.astro';
import HomepageFAQSchema from '../components/HomepageFAQSchema.astro';

const buildLink = "/start-build";

const portfolio = [
  { name: 'Rumours On Rust', screenshot: '/rumoursonrust-site.webp', meta: 'Café · Whangārei' },
  { name: 'Carve Earthworks',  screenshot: '/carve-earthworks-site.webp', meta: 'Earthworks · Northland' },
  { name: 'Ember & Ice',       screenshot: '/emberandice-site.webp',    meta: 'Wellness · Northland' },
  { name: 'Johnson & Sons',    screenshot: '/johnsonandsons-site.webp',  meta: 'Commercial Builder · Northland' },
];

const steps = [
  { n: '01', t: 'The Drive-Home Interview', b: 'You call whenever suits. Car, couch, between meetings. I capture everything I need to write your site in your actual voice.' },
  { n: '02', t: 'I Write Your Copy',         b: 'Turned around in your voice, reviewed by me. You see every section before I build a thing. One round of feedback.' },
  { n: '03', t: 'The Content Raid',          b: 'I go through your existing footprint: socials, Google, existing site, anywhere you show up. You send me nothing.' },
  { n: '04', t: 'The Build',                 b: 'Hand-coded. Under a second to load. Mobile-first. Built for standard search and AI answers.' },
  { n: '05', t: 'Preview',                   b: 'Private link. Love it, we go live. Don’t love it, full refund.' },
  { n: '06', t: 'Go Live',                   b: 'Domain connected. Google notified. Your permanent address is set.' },
  { n: '07', t: 'The Caretakers Take Over',  b: 'Hosting, security, updates, annual refresh. I stay. That’s the whole model.' },
];

const testimonials = [
  { q: 'Creating a website wasn’t something I was looking forward to — but the whole process was smooth, easy and stress-free. The outcome is clean, professional, and suits our business perfectly.', a: 'Brad', m: 'Carve Earthworks' },
  { q: 'The process was stress-free, quick, foolproof and fun. The website is sleek and professional — I can’t believe how good it is.', a: 'Katie', m: 'Rumours On Rust · Café, Whangārei' },
  { q: 'You helped me take that next step and build my dream — that was my barrier to market.', a: 'Nicolette', m: 'Ember & Ice · Wellness Studio' },
];
---

<Layout
  title="YourHQ. Permanent digital homes."
  description="Permanently owned, hand-coded websites. Written in your voice. Looked after forever. From $1,800 NZD + GST · from $129/mo NZD ongoing."
>
  <StructuredData slot="head" />
  <HomepageFAQSchema slot="head" />
  <Navbar client:load />

  <main class="font-sans text-carbon bg-bone selection:bg-terracotta selection:text-white overflow-hidden">

    <!-- ============================================================
         01 · HERO
    ============================================================ -->
    <!-- Removed dark bg and blurry blobs. Applied airy 'Bone' with structured borders. -->
    <section class="relative bg-bone pt-24 md:pt-32 pb-32 px-4 sm:px-6 lg:px-8 border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto relative z-10 flex flex-col md:flex-row md:items-start justify-between gap-12">

        <!-- Left: Copy -->
        <div class="max-w-3xl flex-grow">
          <div class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-deepGreen mb-8 font-medium flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> Founded in NZ · Clients Worldwide
          </div>

          <h1 class="text-[clamp(3rem,7vw,6.5rem)] leading-[0.95] tracking-tight text-carbon">
            <span class="block font-display font-bold uppercase">For businesses</span>
            <span class="block font-serif italic text-terracotta normal-case mt-2 mb-4 text-[clamp(1.5rem,4vw,3.5rem)] leading-none">(and people)</span>
            <span class="block font-display font-bold uppercase">too good to look</span>
            <span class="block font-serif italic text-softGrey normal-case mt-2 text-[clamp(1.5rem,4vw,3.5rem)] leading-none">average online.</span>
          </h1>

          <p class="font-sans text-lg md:text-xl text-carbon/80 max-w-lg leading-relaxed mt-10">
            You’ve been meaning to sort this.<br/>
            This is where it gets handled.
          </p>

          <p class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-deepGreen mt-6 font-medium">
            From $1,800 NZD + GST · from $129/mo NZD ongoing
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4 font-sans">
            <a href={buildLink} class="bg-carbon text-white px-8 py-3.5 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors duration-300 text-center shadow-subtle">
              Start Your Build
            </a>
            <a href="/contact" class="bg-transparent text-carbon border border-carbon/20 px-8 py-3.5 rounded-full font-medium text-sm hover:border-carbon transition-colors duration-300 text-center">
              Just Say Hello
            </a>
          </div>
        </div>

        <!-- Right: Pull Quote & Badge -->
        <div class="md:max-w-[320px] flex flex-col items-start md:items-end md:text-right mt-12 md:mt-0">
          <!-- Elegant Spinning Badge -->
          <div class="w-24 h-24 border border-carbon/20 rounded-full flex items-center justify-center p-2 hover:rotate-180 transition-transform duration-[1500ms] ease-in-out cursor-pointer mb-12">
            <span class="font-mono text-[9px] uppercase tracking-widest text-carbon text-center leading-relaxed">
              Perm&shy;anent<br/><span class="text-terracotta">Digital</span><br/>Home
            </span>
          </div>

          <figure class="border-t border-carbon/10 pt-6">
            <blockquote class="font-serif italic text-xl leading-snug text-carbon/80">
              &ldquo;While I was still figuring out Google Drive, Lian had already pulled images from our Facebook and had a draft site ready.&rdquo;
            </blockquote>
            <figcaption class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mt-4">
              — Reuben · Johnson &amp; Sons · Builder
            </figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ============================================================
         02 · THE WORK / PORTFOLIO STRIP
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-screen-xl mx-auto">

        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
          <div>
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">What I’ve Built</span>
            <h2 class="font-display font-bold text-[clamp(2.5rem,5vw,4rem)] uppercase leading-none tracking-tight text-carbon">
              Here’s what this <br/>
              <span class="font-serif italic text-terracotta normal-case">actually looks like.</span>
            </h2>
          </div>
          <a href="/portfolio" class="font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border-b border-carbon/20 pb-1 hover:border-carbon transition-colors self-start md:self-auto mb-2">
            See all projects &rarr;
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
          {portfolio.map((p) => (
            <a href="/portfolio" class="group block">
              <!-- Clean border and subtle shadow for the elegant architectural feel -->
              <div class="bg-white rounded-2xl p-2 border border-carbon/10 shadow-subtle group-hover:shadow-elegant transition-shadow duration-500">
                <div class="rounded-xl overflow-hidden aspect-[3/4] bg-bone relative">
                  <img src={p.screenshot} alt={p.name} loading="lazy" decoding="async" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" />
                </div>
              </div>
              <div class="pt-5 px-2">
                <h3 class="font-display font-bold text-lg uppercase tracking-tight text-carbon">{p.name}</h3>
                <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mt-1.5">{p.meta}</p>
              </div>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ============================================================
         03 · MEET LIAN
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-y border-carbon/10">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-12 gap-16 items-center">

          <div class="md:col-span-5 relative order-2 md:order-1">
            <!-- Subtle architectural frame -->
            <div class="absolute inset-0 bg-surface rounded-t-[10rem] translate-x-4 translate-y-4 border border-carbon/5"></div>
            <div class="w-full max-w-sm mx-auto aspect-[3/4] rounded-t-[10rem] overflow-hidden border border-carbon/10 shadow-elegant relative z-10 bg-bone">
              <img src="/lian-headshot.webp" alt="Lian Passmore, founder of YourHQ — Whangārei, New Zealand" loading="lazy" decoding="async" class="w-full h-full object-cover" />
            </div>
          </div>

          <div class="md:col-span-7 md:pl-8 order-1 md:order-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">Who You’re Working With</span>
            <h2 class="font-display font-bold text-[clamp(2.5rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-carbon mb-8">
              Every site is built<br/>
              by <span class="font-serif italic text-softGrey normal-case">me, personally.</span>
            </h2>
            <div class="font-sans text-carbon/80 space-y-6 leading-relaxed max-w-lg">
              <p>I’m Lian. Founder, builder, and the person who’ll answer your texts.</p>
              <p>I hold a Master of Technological Futures and built YourHQ from a genuine obsession with two things: storytelling and digital ownership. Every site I build is hand-coded by me, written in your voice, and looked after by me long after it goes live.</p>
              <p class="font-medium text-carbon">No handoffs. No junior staff. No templates with your name dropped in.</p>
              <p>When you work with YourHQ, you’re working with the person who cares most about getting it right, because my name is on every single thing that goes out.</p>
            </div>
            <div class="mt-10 flex items-center gap-4 border-t border-carbon/10 pt-6 max-w-md">
              <div class="w-12 h-12 rounded-full bg-surface border border-carbon/10 text-terracotta flex items-center justify-center font-serif italic text-xl shrink-0">L</div>
              <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey leading-relaxed">Based in Whangārei, Aotearoa.<br/>Building for clients worldwide.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================================
         04 · TWO KINDS OF BUILD
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-bone">
      <div class="max-w-screen-xl mx-auto">

        <div class="text-center mb-16">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">Two Kinds of Build</span>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight text-carbon max-w-4xl mx-auto">
            Business brand or personal brand,<br/>
            <span class="font-serif italic text-terracotta normal-case">same standard, different story.</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6 md:gap-8 mb-12">

          <!-- Business Brand -->
          <div class="bg-white rounded-3xl p-10 md:p-12 border border-carbon/10 shadow-subtle flex flex-col">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-deepGreen block mb-4">Business Brand</span>
            <h3 class="font-display font-bold text-3xl md:text-4xl uppercase tracking-tight text-carbon leading-none mb-4">
              The business exists<br/>
              <span class="font-serif italic normal-case text-softGrey">beyond you.</span>
            </h3>
            <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mb-8 pb-4 border-b border-carbon/10">Clinic · Studio · Practice · Firm · Trade</p>
            <p class="font-sans text-carbon/80 leading-relaxed mb-8">
              Your site becomes the permanent, credible face of what you’ve built. Written in your voice, owned by you unconditionally.
            </p>
            <p class="font-serif italic text-lg text-carbon/70 mt-auto">
              "My business finally looks as good as the work we actually do."
            </p>
          </div>

          <!-- Personal Brand (Deep Green) -->
          <div class="bg-deepGreen text-bone rounded-3xl p-10 md:p-12 shadow-elegant flex flex-col border border-carbon/10">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">Personal Brand</span>
            <h3 class="font-display font-bold text-3xl md:text-4xl uppercase tracking-tight leading-none mb-4 text-white">
              You are<br/>
              <span class="font-serif italic normal-case text-bone/60">the business.</span>
            </h3>
            <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-bone/60 mb-8 pb-4 border-b border-white/10">Coach · Consultant · Speaker · Creator</p>
            <p class="font-sans text-bone/80 leading-relaxed mb-8">
              Your site becomes a permanent record of who you are, what you believe, and the work that proves it. Impossible to mistake for anyone else.
            </p>
            <p class="font-serif italic text-lg text-bone/70 mt-auto">
              "There’s finally one place on the internet that’s completely, specifically me."
            </p>
          </div>

        </div>

        <p class="font-serif italic text-xl md:text-2xl text-carbon/80 text-center max-w-3xl mx-auto leading-snug">
          Both are owned by you. Both are looked after by me.<br/>
          <span class="text-carbon font-medium">Both become the place every digital path leads.</span>
        </p>

        <!-- Vertical entry points for SEO crawl + AEO grounding -->
        <div class="mt-16 pt-10 border-t border-carbon/10">
          <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey text-center mb-6">Built for</p>
          <nav aria-label="Who we build for" class="flex flex-wrap justify-center gap-3 md:gap-4">
            <a href="/tradies" class="font-sans text-sm font-medium text-carbon border border-carbon/15 hover:border-carbon hover:bg-white transition-colors px-5 py-2.5 rounded-full">
              Tradies &amp; Builders
            </a>
            <a href="/professionals" class="font-sans text-sm font-medium text-carbon border border-carbon/15 hover:border-carbon hover:bg-white transition-colors px-5 py-2.5 rounded-full">
              Professional Services
            </a>
            <a href="/creatives" class="font-sans text-sm font-medium text-carbon border border-carbon/15 hover:border-carbon hover:bg-white transition-colors px-5 py-2.5 rounded-full">
              Cafés, Studios &amp; Creatives
            </a>
            <a href="/who-we-build-for" class="font-sans text-sm font-medium text-carbon/70 hover:text-carbon transition-colors px-5 py-2.5">
              See all &rarr;
            </a>
          </nav>
        </div>

      </div>
    </section>

    <!-- ============================================================
         05 · HOW I WORK
    ============================================================ -->
    <!-- Switched to Carbon for a sophisticated, dark-mode editorial break -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-carbon text-bone border-y border-carbon">
      <div class="max-w-screen-xl mx-auto grid md:grid-cols-12 gap-16 items-start">

        <div class="md:col-span-6">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">How I Work</span>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight text-white">
            I handle the thinking<br/>
            <span class="font-serif italic text-bone/60 normal-case">before you realise</span><br/>
            it’s needed.
          </h2>
        </div>

        <div class="md:col-span-6 font-sans text-bone/80 leading-relaxed space-y-6">
          <p class="font-display font-bold text-xl md:text-2xl uppercase tracking-tight text-white mb-6">
            You talk once.<br/>
            <span class="font-serif italic normal-case text-terracotta">Everything else is mine to figure out.</span>
          </p>
          <ul class="space-y-4 border-l border-white/10 pl-6">
            <li>Your story captured, in your actual voice, not a brief.</li>
            <li>Your content pulled from everything you’ve already built.</li>
            <li>Your site written, built, and previewed, before you commit to a thing.</li>
            <li>And then I stay. Hosting, updates, annual refresh. You just text me when something changes.</li>
          </ul>
          <div class="mt-8 pt-6 border-t border-white/10">
            <p class="font-serif italic text-xl text-bone/70 leading-snug">
              Not a template. Not AI copy dropped into a theme.<br/>
              Not a project you manage.<br/>
              <span class="text-white">Just handled.</span>
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================================
         06 · IS THIS FOR YOU?
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-screen-xl mx-auto">

        <div class="text-center mb-16">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">The Fit</span>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight text-carbon">
            Is this <span class="font-serif italic text-terracotta normal-case">for you?</span>
          </h2>
          <p class="font-sans text-carbon/70 max-w-2xl mx-auto mt-6 leading-relaxed">
            This works best for people who are established, who have something real to represent and are ready to hand the whole thing over.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 md:gap-8">
          {[
            { h: 'You’ve outgrown what you have.', b: 'What worked when you were starting out doesn’t represent where you are now. You’re more established, more clear, more credible, and it’s time your online presence caught up.' },
            { h: 'You’re tired of sounding like everyone else.', b: 'Generic is everywhere. You want something impossible to mistake for anyone but you.' },
            { h: 'You want it done without it becoming your project.', b: 'No months of briefing. No weekends writing copy. One conversation. I draw your story out and build while you get on with your work.' },
            { h: 'You want to own what you build.', b: 'Permanent. Portable. Yours unconditionally. Updated with a text. Refreshed every year.' },
          ].map((item) => (
            <div class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle">
              <h3 class="font-display font-bold text-xl uppercase tracking-tight text-carbon leading-none mb-4">{item.h}</h3>
              <p class="font-sans text-carbon/75 leading-relaxed text-sm">{item.b}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ============================================================
         07 · WHO THIS ISN'T FOR
    ============================================================ -->
    <section class="py-24 px-4 sm:px-6 lg:px-8 bg-bone border-t border-carbon/10">
      <div class="max-w-screen-xl mx-auto grid md:grid-cols-12 gap-12 items-start">

        <div class="md:col-span-5">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">The Honest Bit</span>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4vw,3.5rem)] uppercase leading-none tracking-tight text-carbon">
            And who <br/>
            <span class="font-serif italic text-softGrey normal-case">it isn’t.</span>
          </h2>
        </div>

        <div class="md:col-span-7 bg-white p-8 md:p-10 rounded-3xl border border-carbon/10 shadow-subtle">
          <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-carbon mb-6">Not for you if:</p>
          <ul class="divide-y divide-carbon/10 border-y border-carbon/10">
            {[
              'You want to be involved in the build',
              'You’re looking for the cheapest option',
              'You want a template you can manage yourself',
              'You need a full e-commerce store, course platform, or custom app',
              'You haven’t decided yet and need convincing',
            ].map((item) => (
              <li class="py-4 font-sans text-carbon/80 flex items-start gap-4 text-sm">
                <span class="font-mono text-[10px] text-terracotta mt-1 shrink-0">×</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="font-serif italic text-lg text-softGrey mt-6">
            No hard feelings. I’ll point you somewhere better.
          </p>
        </div>

      </div>
    </section>

    <!-- ============================================================
         08 · HOW IT WORKS · 7-STEP OVERVIEW
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-white border-t border-carbon/10">
      <div class="max-w-screen-xl mx-auto">

        <div class="text-center mb-16 max-w-3xl mx-auto">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">How It Works</span>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight text-carbon">
            One conversation.<br/>
            <span class="font-serif italic text-terracotta normal-case">I handle everything else.</span>
          </h2>
          <p class="font-sans text-carbon/70 mt-6 leading-relaxed">
            No copy to write. No designer to brief. No platform to learn.<br/>
            Most clients are live within 1–2 weeks and spend less than 30 minutes on their end.
          </p>
        </div>

        <!-- Clean blueprint list -->
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-10 max-w-5xl mx-auto">
          {steps.map((s) => (
            <div class="flex gap-6 border-t border-carbon/10 pt-6">
              <span class="font-serif italic text-3xl md:text-4xl text-terracotta shrink-0 leading-none">{s.n}</span>
              <div>
                <h3 class="font-display font-bold text-lg uppercase tracking-tight text-carbon mb-2">{s.t}</h3>
                <p class="font-sans text-carbon/70 leading-relaxed text-sm">{s.b}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-16">
          <a href="/how-it-works" class="inline-flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border border-carbon/20 rounded-full px-8 py-3.5 hover:border-carbon transition-colors">
            See the full process &rarr;
          </a>
        </div>

      </div>
    </section>

    <!-- ============================================================
         09 · TESTIMONIALS
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-surface border-y border-carbon/10">
      <div class="max-w-screen-xl mx-auto">

        <div class="text-center mb-16">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">In Their Words</span>
          <h2 class="font-display font-bold text-[clamp(2.5rem,4.5vw,4rem)] uppercase leading-none tracking-tight text-carbon">
            Real people. <span class="font-serif italic text-softGrey normal-case">Real relief.</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6 md:gap-8">
          {testimonials.map((t) => (
            <figure class="bg-white rounded-3xl p-8 md:p-10 border border-carbon/10 shadow-subtle hover:shadow-elegant transition-shadow duration-500 flex flex-col">
              <blockquote class="font-serif italic text-xl leading-snug text-carbon/90 flex-grow">
                &ldquo;{t.q}&rdquo;
              </blockquote>
              <figcaption class="mt-8 pt-6 border-t border-carbon/10">
                <p class="font-display font-bold uppercase tracking-tight text-carbon text-sm mb-1">— {t.a}</p>
                <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey">{t.m}</p>
              </figcaption>
            </figure>
          ))}
        </div>

      </div>
    </section>

    <!-- ============================================================
         10 · THE CARETAKER MODEL
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-bone">
      <div class="max-w-screen-xl mx-auto">

        <div class="text-center mb-16 max-w-3xl mx-auto">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">The Model</span>
