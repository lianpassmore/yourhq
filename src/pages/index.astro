---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import StructuredData from '../components/StructuredData.astro';
import HomepageFAQSchema from '../components/HomepageFAQSchema.astro';
import { BOOKING_URL, PHONE } from '../lib/site.js';

const portfolio = [
  { name: 'Rumours On Rust', screenshot: '/rumoursonrust-site.webp', meta: 'Café · Whangārei' },
  { name: 'Carve Earthworks',  screenshot: '/carve-earthworks-site.webp', meta: 'Earthworks · Northland' },
  { name: 'Ember & Ice',       screenshot: '/emberandice-site.webp',    meta: 'Wellness · Northland' },
  { name: 'Johnson & Sons',    screenshot: '/johnsonandsons-site.webp',  meta: 'Commercial Builder · Northland' },
];

const relief = [
  'Your story captured in a 20-minute conversation, not a brief.',
  'Your content pulled from everything you’ve already built. Socials, Google, your old site. You send me nothing.',
  'Your copy written in your voice, and you see every word before I build a thing.',
  'The full site on a private preview link. Love it, we go live. Don’t love it, full refund.',
  'And then I stay. Hosting, security, updates. You just message me.',
];

const notForYou = [
  'You don’t actually think you need a website, and you’re here to be convinced',
  'You’re shopping for the cheapest option',
  'You want to build it, or run it, yourself',
  'You’re selling physical products with inventory and shipping. That’s a Shopify job, and I’ll say so.',
];

const testimonials = [
  { q: 'A website was created in no time. It was exceptional and exactly what we wanted. No hassle and almost immediately ready.', a: 'Ross', m: 'Google review' },
  { q: 'The process was stress-free, quick, foolproof and fun. The website is sleek and professional. I can’t believe how good it is.', a: 'Katie', m: 'Rumours On Rust · Café, Whangārei' },
  { q: 'She knows so much more than I do, yet she did not talk down to me or make me feel at a loss for content. Her questions and prep work made everything easy and quick.', a: 'Cathy', m: 'Coaching, San Francisco' },
];
---

<Layout
  title="Website Design NZ | Built for You, Looked After | YourHQ"
  description="Hand-built websites for established NZ businesses. One conversation, everything handled, looked after for good. Websites from $3,800 + GST."
>
  <StructuredData slot="head" />
  <HomepageFAQSchema slot="head" />
  <Navbar client:load />

  <main class="font-sans text-carbon bg-bone selection:bg-terracotta selection:text-white overflow-hidden">

    <!-- ============================================================
         01 · HERO
    ============================================================ -->
    <section class="relative bg-bone pt-20 md:pt-28 pb-24 md:pb-32 px-4 sm:px-6 lg:px-8 border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto relative z-10 flex flex-col md:flex-row md:items-start justify-between gap-12">

        <!-- Left: Copy -->
        <div class="max-w-3xl flex-grow">
          <div class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-deepGreen mb-8 font-medium flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen shrink-0"></span> Limited builds each month · Every site looked after for good
          </div>

          <h1 class="text-[clamp(2.5rem,6.5vw,5.75rem)] leading-[1] tracking-tight text-carbon">
            <span class="block font-display font-bold uppercase">Too good to look</span>
            <span class="block font-serif italic text-terracotta normal-case mt-1 text-[clamp(1.75rem,4.5vw,3.75rem)] leading-tight">average online.</span>
            <span class="block font-display font-bold uppercase mt-4">Too busy to</span>
            <span class="block font-serif italic text-softGrey normal-case mt-1 text-[clamp(1.75rem,4.5vw,3.75rem)] leading-tight">fix it yourself.</span>
          </h1>

          <p class="font-sans text-lg md:text-xl text-carbon/80 max-w-xl leading-relaxed mt-10">
            One conversation. I write your website, build it, host it, and answer your texts.<br class="hidden md:block"/>
            You run the business. I look after the home.
          </p>

          <p class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-deepGreen mt-6 font-medium">
            Websites from $3,800 + GST · Care from $149 a month + GST
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4 font-sans">
            <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="bg-carbon text-white px-8 py-3.5 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors duration-300 text-center shadow-subtle">
              Book a Website Chat
            </a>
            <a href="/website-audit" class="bg-transparent text-carbon border border-carbon/20 px-8 py-3.5 rounded-full font-medium text-sm hover:border-carbon transition-colors duration-300 text-center">
              Get the Audit
            </a>
          </div>

          <p class="font-sans text-sm text-softGrey mt-6 max-w-md leading-relaxed">
            Rather not talk it through? <a href="/contact" class="underline decoration-carbon/30 underline-offset-4 hover:decoration-carbon text-carbon">The contact form</a> works just as well, some people think better in writing. Or just message me: {PHONE}.
          </p>
        </div>

        <!-- Right: Pull Quote & Badge -->
        <div class="md:max-w-[320px] flex flex-col items-start md:items-end md:text-right mt-4 md:mt-0">
          <div class="w-24 h-24 border border-carbon/20 rounded-full hidden md:flex items-center justify-center p-2 hover:rotate-180 transition-transform duration-[1500ms] ease-in-out cursor-pointer mb-12">
            <span class="font-mono text-[9px] uppercase tracking-widest text-carbon text-center leading-relaxed">
              Perm&shy;anent<br/><span class="text-terracotta">Digital</span><br/>Home
            </span>
          </div>

          <figure class="border-t border-carbon/10 pt-6">
            <blockquote class="font-serif italic text-xl leading-snug text-carbon/80">
              &ldquo;If you don&rsquo;t want the stress of building a website, this is the way to go.&rdquo;
            </blockquote>
            <figcaption class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mt-4">
              Ross · Google review
            </figcaption>
          </figure>
        </div>

      </div>
    </section>

    <!-- ============================================================
         02 · RECOGNITION
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-white border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto grid md:grid-cols-12 gap-12 md:gap-16 items-start">

        <div class="md:col-span-5">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">Sound Familiar?</span>
          <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-carbon">
            You&rsquo;ve got a website.<br/>
            <span class="font-serif italic text-softGrey normal-case">You&rsquo;re not proud of it.</span>
          </h2>
        </div>

        <div class="md:col-span-7 font-sans text-carbon/80 leading-relaxed space-y-6 max-w-2xl">
          <p>You paid good money for it years ago. The person who built it is gone, or slow, or charges like a wounded bull for a two-line change. The prices are old. The photo is older. You wince a little every time you send someone the link.</p>
          <p>Or maybe you never built one. Everything you&rsquo;ve made lives on Instagram and Facebook, the audience is real, the work is real, but when someone goes looking for the proper version of you, there&rsquo;s nothing there.</p>
          <p class="font-medium text-carbon">Different starting points. Same fix.</p>
          <p class="font-serif italic text-xl text-carbon/80">One conversation. Everything handled. And I stay.</p>
          <div class="pt-4">
            <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="inline-block bg-carbon text-white px-8 py-3.5 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors duration-300 shadow-subtle">
              Book a Website Chat
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================================
         03 · THE WORK / PORTFOLIO STRIP
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-screen-xl mx-auto">

        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
          <div>
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">What I&rsquo;ve Built</span>
            <h2 class="font-display font-bold text-[clamp(2.5rem,5vw,4rem)] uppercase leading-none tracking-tight text-carbon">
              Here&rsquo;s what this <br/>
              <span class="font-serif italic text-terracotta normal-case">actually looks like.</span>
            </h2>
          </div>
          <a href="/the-work" class="font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border-b border-carbon/20 pb-1 hover:border-carbon transition-colors self-start md:self-auto mb-2">
            See all projects &rarr;
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
          {portfolio.map((p) => (
            <a href="/the-work" class="group block">
              <div class="bg-white rounded-2xl p-2 border border-carbon/10 shadow-subtle group-hover:shadow-elegant transition-shadow duration-500">
                <div class="rounded-xl overflow-hidden aspect-[3/4] bg-bone relative">
                  <img src={p.screenshot} alt={p.name} loading="lazy" decoding="async" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" />
                </div>
              </div>
              <div class="pt-5 px-2">
                <h3 class="font-display font-bold text-lg uppercase tracking-tight text-carbon">{p.name}</h3>
                <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mt-1.5">{p.meta}</p>
              </div>
            </a>
          ))}
        </div>

        <figure class="mt-16 pt-10 border-t border-carbon/10 max-w-3xl mx-auto text-center">
          <blockquote class="font-serif italic text-xl md:text-2xl leading-snug text-carbon/85">
            &ldquo;I hadn&rsquo;t even figured out how to add photos to the Google Drive. Lian had already got photos off our Facebook page and had a draft site ready.&rdquo;
          </blockquote>
          <figcaption class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mt-5">
            Reuben · Johnson &amp; Sons · Draft site in under a day
          </figcaption>
        </figure>

      </div>
    </section>

    <!-- ============================================================
         04 · MEET LIAN
    ============================================================ -->
    <section class="py-24 md:py-32 bg-white border-y border-carbon/10">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-12 gap-16 items-center">

          <div class="md:col-span-5 relative order-2 md:order-1">
            <div class="absolute inset-0 bg-surface rounded-t-[10rem] translate-x-4 translate-y-4 border border-carbon/5"></div>
            <div class="w-full max-w-sm mx-auto aspect-[3/4] rounded-t-[10rem] overflow-hidden border border-carbon/10 shadow-elegant relative z-10 bg-bone">
              <img src="/lian-headshot.webp" alt="Lian Passmore, founder of YourHQ — Whangārei, New Zealand" loading="lazy" decoding="async" class="w-full h-full object-cover" />
            </div>
          </div>

          <div class="md:col-span-7 md:pl-8 order-1 md:order-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">Who You&rsquo;re Working With</span>
            <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-carbon mb-8">
              Every site is built by me.<br/>
              <span class="font-serif italic text-softGrey normal-case">Personally. Start to finish.</span>
            </h2>
            <div class="font-sans text-carbon/80 space-y-6 leading-relaxed max-w-lg">
              <p>I&rsquo;m Lian. Founder, builder, and the person who answers your texts.</p>
              <p>Strategy, copy, design, code, hosting. All me. No handoffs, no junior staff, no account manager between you and the person doing the work. When you message, I&rsquo;m the one who replies, and I&rsquo;m the one who makes the change.</p>
              <p>I hold a Master of Technological Futures and I built YourHQ on two obsessions: storytelling and digital ownership. Every site I build is written in your voice and looked after by me long after it goes live.</p>
              <p class="font-medium text-carbon">My name is on everything that goes out. That&rsquo;s the quality control.</p>
            </div>
            <div class="mt-10 flex items-center gap-4 border-t border-carbon/10 pt-6 max-w-md">
              <div class="w-12 h-12 rounded-full bg-surface border border-carbon/10 text-terracotta flex items-center justify-center font-serif italic text-xl shrink-0">L</div>
              <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey leading-relaxed">Based in Whangārei, Aotearoa.<br/>Building for clients worldwide.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============================================================
         05 · THE 2026 REALITY
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-carbon text-bone">
      <div class="max-w-screen-xl mx-auto">

        <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-start mb-16">
          <div class="md:col-span-5">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">The 2026 Reality</span>
            <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-white">
              People find you everywhere.<br/>
              <span class="font-serif italic text-bone/60 normal-case">They check you in one place.</span>
            </h2>
          </div>
          <div class="md:col-span-7 font-sans text-bone/80 leading-relaxed space-y-6 max-w-2xl">
            <p>Here&rsquo;s what&rsquo;s actually changed. People discover you on social, in Google, and now in AI answers. But before they spend a dollar, they verify. In a 2026 US study, 58% of consumers said they check a business&rsquo;s website to confirm what they saw on social media or in an AI recommendation. After an AI tool suggests a business, a third go straight to its website.</p>
            <p class="font-medium text-white">Your profiles are signals. Your website is the source.</p>
            <p>And the source gets judged hard. So the website&rsquo;s job in 2026 isn&rsquo;t traffic. It&rsquo;s trust. Fewer people arrive, but they arrive warmer, closer to buying, and judging harder. Which means an unloved website isn&rsquo;t neutral. It&rsquo;s actively costing you work.</p>
            <p>That&rsquo;s why every site I build is fast, current, accurate, and structured so both Google and AI tools can read it and cite it. And it&rsquo;s why I don&rsquo;t build and disappear.</p>
          </div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 border border-white/10 rounded-2xl overflow-hidden">
          {[
            { n: '41%', d: 'more trustworthy. How consumers rate a business with a website.' },
            { n: '60%', d: 'say an outdated site damages how they rate your quality.' },
            { n: '58%', d: 'check your website to verify what they saw on social or in AI answers.' },
            { n: '$177 vs $36', d: 'what people comfortably spend via a business website vs a social shop.' },
          ].map((s) => (
            <div class="bg-carbon p-8">
              <p class="font-display font-bold text-3xl md:text-4xl text-white leading-none mb-3">{s.n}</p>
              <p class="font-sans text-sm text-bone/70 leading-relaxed">{s.d}</p>
            </div>
          ))}
        </div>

        <p class="font-serif italic text-xl md:text-2xl text-bone/80 text-center max-w-2xl mx-auto leading-snug mt-16">
          An out-of-date website isn&rsquo;t a cosmetic problem.<br/>
          <span class="text-white">It&rsquo;s a trust problem. And trust is the whole game now.</span>
        </p>

      </div>
    </section>

    <!-- ============================================================
         06 · HOW I WORK
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-bone border-b border-carbon/10">
      <div class="max-w-screen-xl mx-auto grid md:grid-cols-12 gap-12 md:gap-16 items-start">

        <div class="md:col-span-5">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">How I Work</span>
          <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-carbon mb-6">
            One conversation.<br/>
            <span class="font-serif italic text-terracotta normal-case">I handle everything else.</span>
          </h2>
          <p class="font-sans text-carbon/70 leading-relaxed max-w-md">
            You talk once. Everything after that is mine to figure out.
          </p>
        </div>

        <div class="md:col-span-7 max-w-2xl">
          <ul class="divide-y divide-carbon/10 border-y border-carbon/10">
            {relief.map((item) => (
              <li class="py-5 font-sans text-carbon/80 leading-relaxed flex items-start gap-4">
                <span class="text-terracotta shrink-0 mt-0.5" aria-hidden="true">&#10003;</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="font-sans text-sm text-carbon/70 mt-6">Most clients spend less than 30 minutes on their end, start to live.</p>
          <a href="/how-it-works" class="mt-8 inline-flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border border-carbon/20 rounded-full px-8 py-3.5 hover:border-carbon transition-colors">
            See the full process &rarr;
          </a>
        </div>

      </div>
    </section>

    <!-- ============================================================
         07 · THE CARETAKER MODEL
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-deepGreen text-bone">
      <div class="max-w-screen-xl mx-auto grid md:grid-cols-12 gap-12 md:gap-16 items-start">

        <div class="md:col-span-5">
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-4">Why This Model Exists</span>
          <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-white">
            Nobody stayed.<br/>
            <span class="font-serif italic text-bone/70 normal-case">I stay. That&rsquo;s the whole model.</span>
          </h2>
        </div>

        <div class="md:col-span-7 font-sans text-bone/85 leading-relaxed space-y-6 max-w-2xl">
          <p>If you paid good money for a website years ago and the person who built it is long gone, that wasn&rsquo;t bad luck. That&rsquo;s how the industry works. Build it, invoice it, move on. And now you&rsquo;re the one holding a site with old prices, old photos, and nobody to call, watching it quietly age into the thing that scares your customers off.</p>
          <p>I built YourHQ around the opposite idea. I build your site, I host it, and I keep it current for as long as you&rsquo;re with me. New service? Message me. New testimonial? Message me. Something broke? I&rsquo;m on it.</p>
          <div class="border-l-2 border-terracotta pl-6 pt-2">
            <p class="text-bone/85">Last month Brad from Carve Earthworks sent through a list of copy tweaks for the site I built him six months ago. Live the same day. That&rsquo;s not a support ticket. That&rsquo;s the model.</p>
            <blockquote class="font-serif italic text-xl leading-snug text-white mt-5">
              &ldquo;The whole process was smooth, easy and stress free with a clean professional outcome that compliments our business.&rdquo;
            </blockquote>
            <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-bone/60 mt-4">Brad · Carve Earthworks · Google review</p>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================================
         08 · LIMITED BUILDS
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-white border-b border-carbon/10">
      <div class="max-w-3xl mx-auto text-center">
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">The Honest Constraint</span>
        <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-carbon mb-8">
          I take on a limited number of builds each month.
          <span class="font-serif italic text-terracotta normal-case block mt-2">Here&rsquo;s why.</span>
        </h2>
        <div class="font-sans text-carbon/80 leading-relaxed space-y-6 text-left max-w-2xl mx-auto">
          <p>Every site I build, I keep. That&rsquo;s the deal. Hosting it, updating it, answering the texts. Which means every new build adds to the list of businesses I&rsquo;m personally looking after, for good.</p>
          <p>So I cap it. Enough builds each month to do every one properly, and never so many that the people already on my books wait for support because I&rsquo;m chasing the next job.</p>
          <p>It&rsquo;s not a scarcity tactic. It&rsquo;s the maths of a one-person model with a forever promise attached. If the month is full, I&rsquo;ll tell you straight and hold your spot in the next one.</p>
        </div>
        <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="mt-10 inline-block bg-carbon text-white px-8 py-3.5 rounded-full font-medium text-sm hover:bg-deepGreen transition-colors duration-300 shadow-subtle">
          Book a Website Chat
        </a>
      </div>
    </section>

    <!-- ============================================================
         09 · WHAT IT COSTS
    ============================================================ -->
    <section class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 bg-surface">
      <div class="max-w-screen-xl mx-auto">
        <div class="grid lg:grid-cols-12 gap-16 md:gap-20 items-start">

          <div class="lg:col-span-5 lg:sticky lg:top-32">
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-4">What It Costs</span>
            <h2 class="font-display font-bold text-[clamp(2.25rem,4vw,3.5rem)] uppercase leading-[1.05] tracking-tight text-carbon mb-6">
              Two numbers.<br/>
              <span class="font-serif italic text-terracotta normal-case">The rest is a conversation.</span>
            </h2>
            <div class="font-sans text-carbon/70 leading-relaxed mb-10 max-w-md space-y-4">
              <p>Where it lands depends on what we&rsquo;re building, and that&rsquo;s what the call is for. After we talk, I send you a proposal for your exact site. One price, in writing, no surprises.</p>
            </div>
            <a href="/pricing" class="inline-flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border border-carbon/20 rounded-full px-8 py-3.5 hover:border-carbon transition-colors">
              How pricing works &rarr;
            </a>
          </div>

          <div class="lg:col-span-7 flex flex-col gap-6">

            <div class="bg-white rounded-3xl p-8 sm:p-10 border border-carbon/10 shadow-subtle flex flex-col sm:flex-row gap-8 justify-between items-start">
              <div>
                <h3 class="font-display font-bold text-xl uppercase tracking-tight text-carbon mb-2">The Build</h3>
                <p class="font-sans text-carbon/75 leading-relaxed text-sm max-w-sm">
                  Your story captured in one conversation. Every page written in your voice, built by hand, found on Google and cited by AI tools.
                </p>
              </div>
              <div class="text-left sm:text-right shrink-0">
                <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey block mb-1">One-time · from</span>
                <p class="font-display font-bold text-3xl text-carbon leading-none">$3,800</p>
                <p class="font-mono text-[9px] uppercase tracking-[0.15em] text-softGrey mt-1">NZD + GST</p>
              </div>
            </div>

            <div class="bg-white rounded-3xl p-8 sm:p-10 border border-carbon/10 shadow-subtle flex flex-col sm:flex-row gap-8 justify-between items-start">
              <div>
                <h3 class="font-display font-bold text-xl uppercase tracking-tight text-carbon mb-2">Monthly Care</h3>
                <p class="font-sans text-carbon/75 leading-relaxed text-sm max-w-sm">
                  Hosting, security, on-demand updates. Me, looking after your site. Scales with what your site actually does.
                </p>
              </div>
              <div class="text-left sm:text-right shrink-0">
                <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-terracotta block mb-1">Ongoing · from</span>
