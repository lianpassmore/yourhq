---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const buildLink = "https://buy.stripe.com/00w00i6me14s4BLev9dZ604";
---

<Layout
  title="Websites for Professional Services NZ | Hand-Coded, Looked After Forever | YourHQ"
  description="Hand-coded websites for physiotherapists, accountants, lawyers, consultants, coaches, and financial advisers. Pass the Google Test. From $1,800 + GST. Looked after forever."
>
  <Navbar client:load />

  <main class="bg-paper min-h-screen">

    <!-- HERO -->
    <section class="pt-32 pb-20 border-b border-carbon bg-[size:40px_40px] bg-grid-pattern">
      <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="inline-block py-1 px-3 rounded-full bg-frangipani/20 text-carbon font-bold text-sm mb-6 tracking-wide uppercase font-mono">
            For Professional Services
          </span>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[0.95] mb-8">
            When Someone Googles You<br/>
            <span class="text-frangipani">Before They Book. What Do They Find?</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-700 max-w-3xl leading-relaxed mb-2">
            Hand-coded websites for physiotherapists, accountants, lawyers, consultants, and advisers. Built carefully. Written in your voice. Compliance-aware.
          </p>
          <p class="font-mono text-xs uppercase tracking-widest text-gray-500">
            From $1,800 + GST &middot; from $129/mo &middot; Built in Aotearoa &middot; Working worldwide
          </p>
        </div>
      </div>
    </section>

    <!-- THE GOOGLE TEST -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-10 leading-tight">
          You Studied for Years to Be Trusted.<br/>
          <span class="text-gray-400">Your Website Should Carry That Weight.</span>
        </h2>
        <div class="space-y-6 text-lg text-carbon/90 leading-relaxed">
          <p>
            Before someone books a consult, signs a retainer, or refers a client. They Google you. They look at your site. They make a judgement in seconds.
          </p>
          <p>
            You can be the most experienced practitioner in your field. If your site is dated, slow, or generic, that judgement gets made against you.
          </p>
          <p>
            That's the Google Test. And it's not optional.
          </p>
          <p class="font-bold text-carbon">
            A YourHQ site passes it. Hand-coded, written in your voice, designed to look as credible as you actually are.
          </p>
        </div>
      </div>
    </section>

    <!-- BUILT FOR -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
            Built For Practitioners<br/>
            <span class="text-gray-400">Whose Reputation Is Their Business.</span>
          </h2>
          <div class="grid md:grid-cols-2 gap-0 border-l border-t border-carbon">
            {[
              ['Physiotherapists &amp; Clinicians', 'Solo, group practice, mobile'],
              ['Accountants &amp; Bookkeepers', 'Tax, advisory, business services'],
              ['Lawyers', 'Family, commercial, conveyancing, criminal'],
              ['Consultants', 'Strategy, operations, technology'],
              ['Financial Advisers &amp; Brokers', 'Mortgages, insurance, investment'],
              ['Coaches &amp; Architects', 'Executive, business, residential design']
            ].map(([trade, sub]) => (
              <div class="bg-white border-r border-b border-carbon p-6">
                <p class="font-extrabold text-lg mb-1">{trade}</p>
                <p class="font-mono text-xs uppercase tracking-widest text-gray-500">{sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- COMPLIANCE NOTE -->
    <section class="py-20 bg-white border-b border-carbon">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-paper border-l-4 border-frangipani p-8">
          <p class="font-mono text-xs font-bold uppercase tracking-widest text-frangipani mb-4">A Note on Compliance</p>
          <h3 class="text-2xl font-extrabold mb-4 leading-tight">I Write Carefully.</h3>
          <p class="text-carbon/90 leading-relaxed mb-4">
            I don't make clinical claims, guarantee outcomes, or use language that could create regulatory issues for professional services businesses. If you have specific advertising guidelines from your professional body, share them. I'll write to them.
          </p>
          <p class="text-carbon/80 italic">
            This is a conversation I have with almost every professional services client.
          </p>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
          What You Get.<br/>
          <span class="text-gray-400">All In.</span>
        </h2>

        <ul class="space-y-5 text-lg text-carbon/90">
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-frangipani text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">A site that reads like you wrote it.</p>
              <p class="text-base text-carbon/70">Drive-Home Interview captures your voice. I write the copy. You approve every word before a line of code is written.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-frangipani text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Hand-coded. Loads in under a second.</p>
              <p class="text-base text-carbon/70">Built for standard search and AI-generated answers. Mobile-first. No WordPress, no plugins, no platform breakage.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-frangipani text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Booking and intake wired in if you need it.</p>
              <p class="text-base text-carbon/70">Calendly, Acuity, Timely embedded and styled. Email capture for newsletters or lead magnets. Available as Power-Ups at build checkout.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-frangipani text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Owned by you. Unconditionally.</p>
              <p class="text-base text-carbon/70">Domain in your name from day one. If you ever leave, you take everything. Nothing held hostage.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-frangipani text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Refreshed every year. Included.</p>
              <p class="text-base text-carbon/70">As your practice evolves, your digital home evolves with it. New layout, new energy, no rebuild invoice.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-32 bg-carbon text-white text-center">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tighter mb-8 leading-tight">
          Pass the <span class="text-frangipani">Google Test.</span>
        </h2>
        <p class="text-xl text-gray-300 mb-12 leading-relaxed">
          One conversation. Live in 1 to 2 weeks.<br/>
          Hand-coded, in your voice, looked after forever.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={buildLink} class="inline-block bg-frangipani text-white px-12 py-5 border-2 border-frangipani hover:bg-transparent hover:text-white transition-colors font-bold uppercase tracking-widest text-lg">
            Start Your Build
          </a>
          <a href="/pricing" class="inline-block bg-transparent text-white px-12 py-5 border-2 border-white hover:bg-white hover:text-carbon transition-colors font-bold uppercase tracking-widest text-lg">
            See Pricing
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
