---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import NetworkSignupForm from '../components/NetworkSignupForm.jsx';

// FAQ Data
const faqs = [
  {
    question: "Do I get paid for referrals?",
    answer: "No. We focus on long-term value exchange, not transactional kickbacks. We reciprocate by introducing our clients to trusted professionals when it fits."
  },
  {
    question: "What if my client has a bad experience?",
    answer: "We fix it - or we refund them. Protecting your trust is non-negotiable."
  },
  {
    question: "How do I make a referral?",
    answer: "Text or email Nic after getting your client's permission. We take it from there."
  },
  {
    question: "Do I need to commit to anything?",
    answer: "No contracts. No minimums. Refer when it makes sense."
  },
  {
    question: "Can I refer clients outside Northland?",
    answer: "Yes. We work NZ-wide - fully remote process."
  }
];

// Schema markup for FAQs (for SEO & AEO)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

// Schema markup for the Partner Program
const partnerProgramSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Website Referral Partnership Program",
  "provider": {
    "@type": "Organization",
    "name": "YourHQ",
    "url": "https://yourhq.co.nz",
    "logo": "https://yourhq.co.nz/icon.svg",
    "areaServed": {
      "@type": "Country",
      "name": "New Zealand"
    },
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Northland",
      "addressCountry": "NZ"
    }
  },
  "description": "Join the YourHQ Network. A trusted referral partnership for accountants, mortgage brokers, bank BDMs, insurance brokers, and business coaches to help their clients get professional websites without the stress. No commissions, just reciprocal value exchange.",
  "audience": {
    "@type": "Audience",
    "audienceType": ["Accountant", "Bookkeeper", "Mortgage Broker", "Bank BDM", "Insurance Broker", "Business Coach"]
  }
};
---

<Layout
  title="YourHQ Network | Trusted Referral Circle for NZ Business Pros"
  description="Join the YourHQ Network. A trusted circle for accountants, brokers, and advisors to help their clients get online without the stress. No commissions, just reciprocity."
>
  <!-- Schema Markup for SEO & AEO -->
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(partnerProgramSchema)} />

  <!-- Navbar -->
  <Navbar client:load />

  <main class="bg-bone text-carbon min-h-screen font-sans selection:bg-deepGreen selection:text-white">
    
    <!-- HERO SECTION -->
    <section class="pt-32 pb-24 md:pt-40 md:pb-32 border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="max-w-4xl">
          
          <!-- Refined Badge -->
          <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-white rounded-full border border-carbon/5 shadow-subtle mb-10">
            <span class="w-2 h-2 bg-deepGreen rounded-full"></span>
            <span class="font-mono text-[10px] font-medium uppercase tracking-[0.1em] text-softGrey">Partner Program</span>
          </div>

          <!-- Tension Technique Heading -->
          <h1 class="font-display text-hero font-bold text-carbon mb-6">
            Your Clients Need Websites.<br />
            <span class="font-serif italic text-terracotta">We've Got You Covered.</span>
          </h1>

          <p class="font-sans text-subhead text-softGrey mb-6 max-w-2xl">
            When a client asks, <em class="font-serif text-carbon">"Do you know anyone who does websites?"</em> - now you do.
          </p>

          <p class="font-sans text-ui font-medium text-carbon/70 mb-10 max-w-2xl">
            Founder-led. Built in Whangārei. Servicing NZ-wide.
          </p>

          <!-- Buttons -->
          <div class="flex flex-col sm:flex-row gap-5">
            <a href="#join" class="inline-flex justify-center bg-deepGreen text-white px-8 py-3.5 rounded-full font-medium hover:bg-carbon hover:shadow-float transition-all duration-300">
              Join the Network
            </a>
            <a href="#how-it-works" class="inline-flex justify-center bg-white text-carbon px-8 py-3.5 rounded-full font-medium border border-carbon/5 shadow-subtle hover:border-carbon/20 transition-all duration-300">
              How It Works
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 1: THE PROBLEM -->
    <section class="py-24 bg-surface border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-20 items-start">
          
          <!-- Sticky Left Context -->
          <div class="lg:col-span-5 lg:sticky lg:top-32 self-start">
            <h2 class="font-display text-display font-bold text-carbon mb-4">
              The Problem
            </h2>
            <p class="font-serif italic text-headline text-terracotta mb-8">
              (From your side of the desk)
            </p>

            <div class="font-sans text-body text-softGrey mb-10 space-y-4">
              <p>You see it all the time:</p>
              <p>The tradie doing great work but losing jobs because they don't show up on Google.</p>
              <p>The salon owner whose whole business lives on Instagram.</p>
              <p>The consultant who's solid - but fails the "Google Test."</p>
            </div>

            <div class="border-l-4 border-signal pl-6">
              <p class="font-sans text-ui font-medium text-carbon leading-relaxed">
                They ask you for advice. You tell them they need a website. Then comes the awkward part: who do you send them to?
              </p>
            </div>
          </div>

          <!-- Right Content Cards -->
          <div class="lg:col-span-7 space-y-6 mt-12 lg:mt-0">
            
            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle">
              <h3 class="font-mono text-badge text-softGrey mb-3">Option A: Wix / DIY</h3>
              <p class="font-sans text-body text-carbon font-medium">40 hours of your client's time, frustration, and usually no finished result.</p>
            </div>
            
            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle">
              <h3 class="font-mono text-badge text-softGrey mb-3">Option B: Agencies</h3>
              <p class="font-sans text-body text-carbon font-medium">Big money ($5k+) and long delays - often overkill for what they actually need.</p>
            </div>

            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle">
              <h3 class="font-mono text-badge text-softGrey mb-3">Option C: Doing Nothing</h3>
              <p class="font-sans text-body text-carbon font-medium">Means having the exact same conversation again next quarter.</p>
            </div>

            <!-- The Pivot Box -->
            <div class="bg-deepGreen rounded-2xl p-10 shadow-elegant mt-10">
              <p class="font-serif italic text-accent text-white text-center">
                That's the gap the YourHQ Network fills.
              </p>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 2: WHAT WE DO -->
    <section class="py-24 bg-carbon border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="font-display text-display font-bold text-white mb-6">
            Websites for Small Biz.<br/>
            <span class="font-serif italic text-signal">Hand-Coded. Zero Homework.</span>
          </h2>
          <p class="font-sans text-subhead text-white/60">
            We fix the problem without creating more work for you or your client.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <div class="bg-bone rounded-2xl p-8 border-t-4 border-signal">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">One Phone Call</h3>
            <p class="font-sans text-body text-softGrey">A Drive-Home Interview. Car, couch, between meetings. We capture everything in their voice. They send us nothing.</p>
          </div>

          <div class="bg-bone rounded-2xl p-8 border-t-4 border-terracotta">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">No Homework</h3>
            <p class="font-sans text-body text-softGrey">We interview them, raid their existing footprint for content, and build it. No copywriting tasks for them.</p>
          </div>
          
          <div class="bg-bone rounded-2xl p-8 border-t-4 border-carbon/20">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Small Biz Pricing</h3>
            <p class="font-sans text-body text-softGrey">Setup <strong class="text-carbon font-semibold">$1,800 + GST</strong>. Ongoing care from <strong class="text-carbon font-semibold">$129/mo + GST</strong>.</p>
          </div>
          
          <div class="bg-bone rounded-2xl p-8 border-t-4 border-deepGreen">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">The Caretaker Model</h3>
            <p class="font-sans text-body text-softGrey">We don't build and disappear - we host, maintain, update, and refresh yearly so the site doesn't rot.</p>
          </div>
          
          <div class="bg-bone rounded-2xl p-8 border-t-4 border-signal relative lg:col-span-2">
            <div class="absolute top-6 right-6 font-mono text-[9px] uppercase tracking-widest text-signal bg-signal/10 px-2 py-1 rounded">Crucial</div>
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Simple Guarantee</h3>
            <p class="font-sans text-body text-softGrey max-w-lg">If they don't like the preview, we refund them. Your reputation stays intact.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 3: WHO WE HELP -->
    <section class="py-24 bg-white border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid md:grid-cols-2 gap-8">
          
          <!-- Good Fit -->
          <div class="bg-surface rounded-2xl p-10 border-l-4 border-deepGreen shadow-subtle">
            <h3 class="font-display text-headline font-bold text-carbon mb-8 flex items-center gap-4">
              <span class="flex items-center justify-center w-8 h-8 rounded-full bg-deepGreen text-white text-sm">✓</span>
              Good Fit Clients
            </h3>
            <ul class="space-y-4 font-sans text-body text-softGrey">
              <li class="flex items-start"><span class="text-deepGreen mr-3 mt-1">•</span> Tradies and service businesses</li>
              <li class="flex items-start"><span class="text-deepGreen mr-3 mt-1">•</span> Salons and beauty professionals</li>
              <li class="flex items-start"><span class="text-deepGreen mr-3 mt-1">•</span> Health & wellness practitioners</li>
              <li class="flex items-start"><span class="text-deepGreen mr-3 mt-1">•</span> Consultants and coaches</li>
              <li class="flex items-start"><span class="text-deepGreen mr-3 mt-1">•</span> Creatives needing a professional presence</li>
            </ul>
          </div>

          <!-- Not a Fit -->
          <div class="bg-surface rounded-2xl p-10 border-l-4 border-terracotta shadow-subtle">
            <h3 class="font-display text-headline font-bold text-carbon mb-8 flex items-center gap-4">
              <span class="flex items-center justify-center w-8 h-8 rounded-full bg-terracotta text-white text-sm">✕</span>
              Not a Fit
            </h3>
            <ul class="space-y-4 font-sans text-body text-softGrey">
              <li class="flex items-start"><span class="text-terracotta mr-3 mt-1">•</span> Online stores (products, inventory, variants - use Shopify for that)</li>
              <li class="flex items-start"><span class="text-terracotta mr-3 mt-1">•</span> DIYers who want to build it themselves</li>
              <li class="flex items-start"><span class="text-terracotta mr-3 mt-1">•</span> Businesses needing complex custom systems</li>
              <li class="flex items-start"><span class="text-terracotta mr-3 mt-1">•</span> People shopping for the absolute cheapest option</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 4: WHY JOIN -->
    <section class="py-24 bg-bone border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <h2 class="font-display text-headline font-bold text-carbon mb-16 text-center">Why Join The Network?</h2>
        
        <div class="grid sm:grid-cols-2 gap-6">
          
          <div class="bg-white rounded-2xl p-10 shadow-subtle border border-carbon/5">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-4">You Look Good</h3>
            <p class="font-sans text-body text-softGrey">Your client gets sorted quickly, properly, and without drama. That reflects well on you.</p>
          </div>

          <div class="bg-white rounded-2xl p-10 shadow-subtle border border-carbon/5">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-4">Referrals Flow Both Ways</h3>
            <p class="font-sans text-body text-softGrey">We ask every new client: <em class="font-serif italic text-carbon">"Who do you trust for accounting, finance, insurance, coaching?"</em> When you're the right fit, we make the intro.</p>
          </div>

          <div class="bg-white rounded-2xl p-10 shadow-subtle border border-carbon/5">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-4">Practical Tools</h3>
            <p class="font-sans text-body text-softGrey">We provide co-branded resources you can actually use - guides and checklists with your logo on them. Helpful, not salesy.</p>
          </div>

          <div class="bg-white rounded-2xl p-10 shadow-subtle border border-carbon/5">
            <h3 class="font-sans font-semibold text-subhead text-carbon mb-4">Founder-led & Built to Last</h3>
            <p class="font-sans text-body text-softGrey">Your clients aren't getting handed into a black hole. YourHQ is founder-led and designed for long-term care.</p>
          </div>

        </div>
      </div>
    </section>

   <!-- SECTION 5: VALUE EXCHANGE -->
    <section class="py-24 bg-surface border-b border-carbon/10">
      <div class="max-w-4xl mx-auto px-6 text-center">
        
        <h2 class="font-display text-display font-bold text-carbon mb-6">The Value Exchange</h2>
        
        <p class="font-sans text-subhead text-carbon mb-4">
          This is <span class="text-signal font-bold underline decoration-signal decoration-2 underline-offset-4">not</span> a commission program.
        </p>
        <p class="font-serif italic text-accent text-softGrey mb-12">
          We don't do kickbacks. We do relationships.
        </p>
        
        <!-- The Elevated Value Box -->
        <div class="bg-white rounded-2xl shadow-elegant border border-carbon/5 p-10 md:p-14">
          <div class="grid md:grid-cols-2 gap-10 md:gap-16 text-left">
            
            <div>
              <p class="font-mono text-badge text-deepGreen mb-6">You Get</p>
              <ul class="space-y-4 font-sans text-ui text-softGrey">
                <li class="flex items-start"><span class="text-carbon mr-3 mt-0.5">—</span> Warm referrals back</li>
                <li class="flex items-start"><span class="text-carbon mr-3 mt-0.5">—</span> Co-branded tools</li>
                <li class="flex items-start"><span class="text-carbon mr-3 mt-0.5">—</span> A reliable solution for clients</li>
                <li class="flex items-start"><span class="text-carbon mr-3 mt-0.5">—</span> Confidence your client will be cared for</li>
              </ul>
            </div>
            
            <div class="md:border-l md:border-carbon/10 md:pl-16 relative">
              <!-- Desktop Plus icon on divider -->
              <div class="hidden md:flex absolute top-1/2 -left-[14px] -translate-y-1/2 w-7 h-7 bg-white border border-carbon/10 rounded-full items-center justify-center font-mono text-softGrey text-xs">
                +
              </div>
              <p class="font-mono text-badge text-carbon mb-6">We Get</p>
              <ul class="space-y-4 font-sans text-ui text-softGrey">
                <li class="flex items-start"><span class="text-carbon mr-3 mt-0.5">—</span> Quality introductions to clients who actually need help</li>
              </ul>
            </div>
          </div>
          
          <div class="mt-12 border-t border-carbon/5 pt-8 text-center">
            <p class="font-serif italic text-accent text-carbon">Simple. Clean. Sustainable.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 5b: BUILT TOGETHER -->
    <section class="py-24 bg-bone border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-20 items-start">

          <div class="lg:col-span-5 lg:sticky lg:top-32 self-start">
            <p class="font-mono text-badge text-deepGreen mb-6">Built Together</p>
            <h2 class="font-display text-display font-bold text-carbon mb-6">
              We'd love to <span class="font-serif italic text-terracotta">build something with you.</span>
            </h2>
            <p class="font-sans text-body text-softGrey mb-6">
              The Network isn't a one-way pipe. We want to work out, together, what your clients actually need help with, and where YourHQ can add real value beyond just building websites.
            </p>
            <p class="font-sans text-body text-softGrey">
              Our founder has a background in learning and experience design. Helping people build capability is the part of the work she shines in, so this is a space we lean into properly.
            </p>
          </div>

          <div class="lg:col-span-7 space-y-5 mt-10 lg:mt-0">

            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle">
              <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Free Webinars for Your Clients</h3>
              <p class="font-sans text-body text-softGrey">Want us to run a session for your client base? "How to look better online," "The Google Test," "What an AI-ready website actually means." We tailor it to your audience. No sales pitch.</p>
            </div>

            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle">
              <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Co-Branded Resources</h3>
              <p class="font-sans text-body text-softGrey">Guides, checklists, and tools we'll build with your logo on them. Tell us what your clients keep asking about. We'll turn it into something useful you can hand them.</p>
            </div>

            <div class="bg-white rounded-2xl p-8 border border-carbon/5 shadow-subtle">
              <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Workshops &amp; Talks</h3>
              <p class="font-sans text-body text-softGrey">Conferences, team meetings, association events. We're up for it. Practical, capability-building sessions, in person or remote.</p>
            </div>

            <div class="bg-deepGreen rounded-2xl p-10 shadow-elegant">
              <p class="font-serif italic text-accent text-white text-center">
                Tell us where the gap is. We'll help fill it.
              </p>
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 6: HOW IT WORKS -->
    <section id="how-it-works" class="py-24 bg-white border-b border-carbon/10">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
            <h2 class="font-display text-headline font-bold text-carbon mb-20 text-center">How It Works (Practically)</h2>
            
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
                
                <!-- Step 1 -->
                <div class="relative pt-6">
                    <span class="font-serif italic text-8xl text-carbon/5 absolute -top-8 -left-4 select-none">01</span>
                    <div class="relative z-10">
                        <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Join the Network</h3>
                        <p class="font-sans text-body text-softGrey">Send us an email. We'll send you a short welcome kit and get you set up.</p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="relative pt-6">
                    <span class="font-serif italic text-8xl text-carbon/5 absolute -top-8 -left-4 select-none">02</span>
                    <div class="relative z-10">
                        <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Make the Intro</h3>
                        <p class="font-sans text-body text-softGrey">When a client mentions needing a website, just say: <em class="font-serif italic text-carbon">"I'm part of the YourHQ Network. Want me to connect you?"</em></p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="relative pt-6">
                    <span class="font-serif italic text-8xl text-carbon/5 absolute -top-8 -left-4 select-none">03</span>
                    <div class="relative z-10">
                        <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">We Take Over</h3>
                        <p class="font-sans text-body text-softGrey">We contact them, run the call, build the site, and keep you out of the weeds completely.</p>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="relative pt-6">
                    <span class="font-serif italic text-8xl text-carbon/5 absolute -top-8 -left-4 select-none">04</span>
                    <div class="relative z-10">
                        <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Everyone Wins</h3>
                        <p class="font-sans text-body text-softGrey">Your client moves forward. You strengthen the relationship. We grow together.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 7: WHO IS IT FOR -->
    <section class="py-24 bg-bone border-b border-carbon/10">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="font-display text-headline font-bold text-carbon mb-10">Who We're Looking For</h2>
            
            <div class="flex flex-wrap justify-center gap-3">
                <span class="px-6 py-2.5 bg-white rounded-full shadow-subtle border border-carbon/5 font-sans text-ui text-carbon">Accountants & Bookkeepers</span>
                <span class="px-6 py-2.5 bg-white rounded-full shadow-subtle border border-carbon/5 font-sans text-ui text-carbon">Mortgage Brokers</span>
                <span class="px-6 py-2.5 bg-white rounded-full shadow-subtle border border-carbon/5 font-sans text-ui text-carbon">Bank BDMs</span>
                <span class="px-6 py-2.5 bg-white rounded-full shadow-subtle border border-carbon/5 font-sans text-ui text-carbon">Insurance Brokers</span>
                <span class="px-6 py-2.5 bg-white rounded-full shadow-subtle border border-carbon/5 font-sans text-ui text-carbon">Business Coaches</span>
            </div>
            
            <p class="mt-12 font-sans text-ui text-softGrey">
                Based in <span class="font-medium text-carbon">Whangārei / Northland</span>, serving clients <span class="font-medium text-carbon">NZ-wide</span>.
            </p>
        </div>
    </section>

    <!-- SECTION 8: FAQ -->
    <section class="py-24 bg-surface border-b border-carbon/10">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-display text-headline font-bold text-carbon mb-16 text-center">Frequently Asked</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <div class="border-b border-carbon/10 pb-6 last:border-0 group">
              <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">{faq.question}</h3>
              <p class="font-sans text-body text-softGrey">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SECTION 9: JOIN VIA FORM -->
    <section id="join" class="py-24 bg-carbon text-white">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="font-display text-display font-bold text-white mb-6">Join the Network</h2>
            <p class="font-serif italic text-headline text-white/60 mb-16 max-w-2xl mx-auto">
                Tell us a bit about you. We'll send your welcome kit, referral tools, and follow up on anything you're keen to explore together.
            </p>

