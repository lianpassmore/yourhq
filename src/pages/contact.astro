---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.jsx';

const buildLink = "/start-build";
---

<Layout
  title="Contact YourHQ"
  description="Ready to hand this over? One conversation is all it takes. Text 022 172 5793 or send a message and Lian or Nic will be in touch within one business day."
>
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white">

    <!-- HERO -->
    <section class="pt-24 md:pt-32 pb-16 md:pb-24 border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-badge uppercase text-deepGreen mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> Get in Touch
          </span>
          <h1 class="font-display font-bold text-hero leading-none tracking-tight mb-8 text-carbon uppercase">
            Ready to Hand This Over?
          </h1>
          <p class="font-sans text-subhead text-softGrey max-w-2xl">
            One conversation is all it takes. Tell me a bit about yourself and I'll take it from there.
          </p>
        </div>
      </div>
    </section>

    <!-- CONTENT GRID -->
    <section class="py-16 md:py-24">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-12 gap-8 md:gap-16 items-start">

            <!-- LEFT: WHAT HAPPENS / CONTACT -->
            <div class="md:col-span-5 bg-carbon text-bone rounded-3xl p-8 md:p-12 shadow-elegant">
                <h2 class="font-display font-bold text-headline uppercase mb-10 text-white">
                  Here's What Happens<br/>
                  <span class="font-serif italic text-bone/60 normal-case font-normal">When You Reach Out.</span>
                </h2>

                <div class="space-y-8 mb-12">
                  <div class="border-l border-white/20 pl-6 group transition-colors hover:border-terracotta/50">
                    <p class="font-mono text-badge uppercase text-terracotta mb-2">Step 1</p>
                    <p class="font-sans text-body font-medium text-white mb-1">You send this form</p>
                    <p class="font-sans text-ui text-bone/70">Takes two minutes.</p>
                  </div>
                  <div class="border-l border-white/20 pl-6 group transition-colors hover:border-terracotta/50">
                    <p class="font-mono text-badge uppercase text-terracotta mb-2">Step 2</p>
                    <p class="font-sans text-body font-medium text-white mb-1">I get back to you</p>
                    <p class="font-sans text-ui text-bone/70">Lian or Nic will text you within one business day. Not an automated reply. A real person.</p>
                  </div>
                  <div class="border-l border-white/20 pl-6 group transition-colors hover:border-terracotta/50">
                    <p class="font-mono text-badge uppercase text-terracotta mb-2">Step 3</p>
                    <p class="font-sans text-body font-medium text-white mb-1">We book your Drive-Home Interview</p>
                    <p class="font-sans text-ui text-bone/70">A quick call at a time that suits you. Car, couch, between meetings.</p>
                  </div>
                  <div class="border-l border-white/20 pl-6 group transition-colors hover:border-terracotta/50">
                    <p class="font-mono text-badge uppercase text-terracotta mb-2">Step 4</p>
                    <p class="font-sans text-body font-medium text-white mb-1">I handle the rest</p>
                    <p class="font-sans text-ui text-bone/70">Copy, content raid, build, preview. You approve. We go live.</p>
                  </div>
                </div>

                <div class="border-t border-white/10 pt-10 mb-10">
                  <p class="font-mono text-badge uppercase text-softGrey mb-6">Contact Details</p>
                  <div class="space-y-4">
                    <a href="sms:0221725793" class="block font-sans text-subhead font-medium text-white hover:text-signal transition-colors">Text: 022 172 5793</a>
                    <a href="mailto:hello@yourhq.co.nz" class="block font-sans text-subhead font-medium text-white hover:text-signal transition-colors">Email: hello@yourhq.co.nz</a>
                  </div>
                  <p class="font-sans text-ui text-bone/50 mt-8">
                    Based in Whangārei, Aotearoa New Zealand. Working with clients worldwide.
                  </p>
                </div>

                <div class="border border-white/10 rounded-2xl p-8 bg-white/5">
                  <p class="font-sans text-body font-medium text-white mb-3">Not quite ready?</p>
                  <p class="font-sans text-ui text-bone/70 leading-relaxed">
                    That's fine. Use the form to ask a question. No commitment, no pressure. If I'm not the right fit, I'll tell you honestly and point you somewhere better.
                  </p>
                </div>
            </div>

            <!-- RIGHT: FORM -->
            <div class="md:col-span-7 bg-white rounded-3xl p-8 md:p-16 border border-carbon/5 shadow-subtle flex flex-col justify-center">

                <h2 class="font-display font-bold text-display uppercase text-carbon mb-2">Tell Me About You</h2>
                <p class="font-serif italic text-accent text-softGrey mb-12">Five minutes. That's all this takes.</p>

                <!-- Ensure ContactForm has internal styling that matches or inherits from the page -->
                <ContactForm client:load />

            </div>
        </div>
      </div>
    </section>

    <!-- SKIP TO BUILD -->
    <section class="py-24 md:py-32 bg-surface border-t border-carbon/5">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-display font-bold text-display uppercase mb-6 text-carbon">
          Ready to Skip Straight to It?
        </h2>
        <p class="font-sans text-body text-softGrey mb-12">
          Lock in your build and I'll text you a private link to your Drive-Home Interview.
        </p>
        <a href={buildLink} class="inline-flex justify-center items-center bg-carbon text-white px-8 py-4 rounded-full font-medium text-ui hover:bg-deepGreen transition-all duration-300 shadow-elegant hover:shadow-float">
          Start Your Build &rarr;
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>