---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.jsx';
import { BOOKING_URL, PHONE, EMAIL } from '../lib/site.js';

const whatHappens = [
  { s: 'Step 1', h: 'You book the chat or send the form', b: 'Two minutes, either way.' },
  { s: 'Step 2', h: 'I get back to you', b: 'I’ll text or email you within one business day. Not an automated reply. Me.' },
  { s: 'Step 3', h: 'You get a proposal', b: 'If we’re a fit, one page in writing within a couple of days: your site, what it includes, your numbers. No surprises, no obligation.' },
  { s: 'Step 4', h: 'You decide', b: 'Take your time. I take on a limited number of builds each month, so if the month is full I’ll hold your spot in the next one.' },
];
---

<Layout
  title="Book a Free 20-Minute Website Chat | YourHQ Whangārei"
  description="Book a free 20-minute chat about your website with Lian at YourHQ, or send the form if you'd rather write. Based in Whangārei, working with clients worldwide."
>
  <Navbar client:load />

  <main class="bg-bone font-sans text-carbon min-h-screen selection:bg-terracotta selection:text-white overflow-hidden">

    <!-- HERO -->
    <section class="pt-24 md:pt-32 pb-16 md:pb-24 border-b border-carbon/5">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="font-mono text-badge uppercase text-deepGreen mb-6 flex items-center gap-3">
            <span class="w-8 h-[1px] bg-deepGreen"></span> Get in Touch
          </span>
          <h1 class="font-display font-bold text-hero leading-none tracking-tight mb-8 text-carbon uppercase">
            Two Ways In.<br/>
            <span class="font-serif italic text-terracotta normal-case font-normal">Both Easy.</span>
          </h1>
          <p class="font-sans text-subhead text-softGrey max-w-2xl">
            Book a free 20-minute chat, or send the form if you&rsquo;d rather do this in writing. Same honesty, same outcome, no prep either way.
          </p>
        </div>
      </div>
    </section>

    <!-- CONTENT GRID -->
    <section class="py-16 md:py-24">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-12 gap-8 md:gap-16 items-start">

            <!-- LEFT: THE CHAT -->
            <div class="md:col-span-5 bg-carbon text-bone rounded-3xl p-8 md:p-12 shadow-elegant">
                <h2 class="font-display font-bold text-headline uppercase mb-4 text-white">
                  The Website Chat.<br/>
                  <span class="font-serif italic text-bone/60 normal-case font-normal">Twenty minutes, free.</span>
                </h2>
                <div class="font-sans text-body text-bone/80 space-y-4 mb-8">
                  <p>A relaxed chat about your website, or the one you don&rsquo;t have yet. No prep, no pitch, no homework. If you&rsquo;ve got an existing site, I&rsquo;ll look at it before we talk so we don&rsquo;t waste your twenty minutes on things I can see for myself.</p>
                  <p>You&rsquo;ll leave knowing your next step, whether or not it&rsquo;s with me. If I&rsquo;m not the right fit, I&rsquo;ll tell you straight and point you somewhere better.</p>
                </div>
                <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-bone text-carbon px-8 py-4 rounded-full font-medium text-sm hover:bg-terracotta hover:text-white transition-colors duration-300 mb-4">
                  Book a Website Chat
                </a>
                <p class="font-sans text-sm text-bone/60 text-center mb-3">Not a phone person? Totally fine. The form does the same job. &rarr;</p>
                <p class="font-sans text-sm text-bone/60 text-center mb-12">
                  Or answer seven quick questions and
                  <a href="/request-a-quote" class="text-bone underline underline-offset-4 hover:text-terracotta transition-colors">get a quote without a call &rarr;</a>
                </p>

                <div class="border-t border-white/10 pt-10 mb-10">
                  <p class="font-mono text-badge uppercase text-softGrey mb-6">Contact Details</p>
                  <div class="space-y-4">
                    <a href="sms:0275668803" class="block font-sans text-subhead font-medium text-white hover:text-terracotta transition-colors">Text: {PHONE}</a>
                    <a href={`mailto:${EMAIL}`} class="block font-sans text-subhead font-medium text-white hover:text-terracotta transition-colors">Email: {EMAIL}</a>
                  </div>
                  <p class="font-sans text-ui text-bone/50 mt-8">
                    Based in Whangārei, Aotearoa New Zealand. Working with clients worldwide.
                  </p>
                </div>

                <div class="border-t border-white/10 pt-10">
                  <p class="font-mono text-badge uppercase text-softGrey mb-6">What Happens Next</p>
                  <div class="space-y-6">
                    {whatHappens.map((step) => (
                      <div class="border-l border-white/20 pl-6">
                        <p class="font-mono text-badge uppercase text-terracotta mb-2">{step.s}</p>
                        <p class="font-sans text-body font-medium text-white mb-1">{step.h}</p>
                        <p class="font-sans text-ui text-bone/70">{step.b}</p>
                      </div>
                    ))}
                  </div>
                </div>
            </div>

            <!-- RIGHT: THE FORM -->
            <div class="md:col-span-7 bg-white rounded-3xl p-8 md:p-16 border border-carbon/5 shadow-subtle flex flex-col justify-center">

                <h2 class="font-display font-bold text-display uppercase text-carbon mb-2">Rather Write It Down?</h2>
                <p class="font-serif italic text-accent text-softGrey mb-12">Some people think better in writing. This form gets you the same straight answer and the same proposal as the call.</p>

                <ContactForm client:load />

                <div class="mt-12 border-t border-carbon/10 pt-8">
                  <p class="font-sans text-body font-medium text-carbon mb-2">Already have a site? Want the full evidence first?</p>
                  <p class="font-sans text-ui text-softGrey leading-relaxed mb-4">
                    The Website Audit scores every page, rewrites your copy, and hands you the complete rebuild brief. $997 + GST, and it comes off your build price if you go ahead within 90 days.
                  </p>
                  <a href="/website-audit" class="font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border-b border-carbon/20 pb-1 hover:border-carbon transition-colors">
                    See the Website Audit &rarr;
                  </a>
                </div>

            </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
