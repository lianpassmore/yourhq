---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Refer a Friend | YourHQ"
  description="Give a Month, Get a Month. The YourHQ Referral Program."
>
  <Navbar client:load />

  <main class="bg-bone text-carbon min-h-screen font-sans selection:bg-deepGreen selection:text-white">

    <!-- HERO SECTION -->
    <section class="pt-32 pb-24 md:pt-40 md:pb-32 border-b border-carbon/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center">
        
        <!-- Refined Badge -->
        <div class="inline-flex items-center gap-3 px-4 py-1.5 bg-white rounded-full border border-carbon/5 shadow-subtle mb-10">
            <span class="w-2 h-2 bg-signal rounded-full"></span>
            <span class="font-mono text-[10px] font-medium uppercase tracking-[0.1em] text-softGrey">Partnership Program</span>
        </div>

        <!-- Tension Technique Heading -->
        <h1 class="font-display text-hero font-bold text-carbon mb-8">
          Give a Month.<br/>
          <span class="font-serif italic text-terracotta">Get a Month.</span>
        </h1>
        
        <p class="font-sans text-subhead text-softGrey max-w-2xl mx-auto mb-16">
          Know a business owner who is still renting their digital home? 
          Send them our way. If they sign up, you both get a month of hosting on the house.
        </p>

        <!-- THE CARD -->
        <div class="max-w-md mx-auto bg-white rounded-2xl border border-carbon/5 p-10 shadow-elegant relative text-left">
            
            <h3 class="font-display text-headline font-bold text-carbon mb-8 text-center">How it works</h3>
            
            <div class="space-y-6">
                <!-- Step 1 -->
                <div class="flex items-start gap-4">
                    <span class="shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-surface border border-carbon/10 font-mono text-xs text-carbon mt-0.5">1</span>
                    <p class="font-sans text-body text-softGrey">Tell your friend to mention your name when they book their interview.</p>
                </div>
                
                <!-- Step 2 -->
                <div class="flex items-start gap-4">
                    <span class="shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-surface border border-carbon/10 font-mono text-xs text-carbon mt-0.5">2</span>
                    <p class="font-sans text-body text-softGrey">They get their <strong class="text-carbon font-semibold">1st Month Free</strong> (save up to $199).</p>
                </div>
                
                <!-- Step 3 -->
                <div class="flex items-start gap-4">
                    <span class="shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-surface border border-carbon/10 font-mono text-xs text-carbon mt-0.5">3</span>
                    <p class="font-sans text-body text-softGrey">You get your <strong class="text-carbon font-semibold">Next Month Free</strong> automatically.</p>
                </div>
            </div>
        </div>

      </div>
    </section>

    <!-- SHARE TOOLS -->
    <section class="py-24 bg-surface border-b border-carbon/10">
        <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center">
            
            <h2 class="font-display text-display font-bold text-carbon mb-16">
                Make the Intro<br/>
                <span class="font-serif italic text-headline text-softGrey">(Without It Being Awkward)</span>
            </h2>
            
            <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-8">
                
                <!-- Email Template -->
                <div class="bg-white rounded-2xl p-10 border border-carbon/5 shadow-subtle hover:shadow-float hover:border-signal/20 transition-all duration-300 group cursor-pointer text-left" onclick="navigator.clipboard.writeText('Hey! I got my website sorted by YourHQ - super easy. If you mention my name when you book, you get your first month free. Check them out: yourhq.co.nz'); alert('Message copied to clipboard!')">
                    <span class="text-4xl mb-6 block">📋</span>
                    <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Copy a Text</h3>
                    <p class="font-sans text-ui text-softGrey mb-8">Click to copy a pre-written text you can send to a mate.</p>
                    <span class="font-mono text-badge text-signal group-hover:underline">Tap to Copy &rarr;</span>
                </div>

                <!-- Direct Link -->
                <a href="mailto:?subject=Check out YourHQ&body=Hey! I got my website sorted by YourHQ - super easy. If you mention my name when you book, you get your first month free. Check them out: https://yourhq.co.nz" class="bg-white rounded-2xl p-10 border border-carbon/5 shadow-subtle hover:shadow-float hover:border-signal/20 transition-all duration-300 group text-left block">
                    <span class="text-4xl mb-6 block">✉️</span>
                    <h3 class="font-sans font-semibold text-subhead text-carbon mb-3">Send an Email</h3>
                    <p class="font-sans text-ui text-softGrey mb-8">Open your email app with a pre-filled message ready to go.</p>
                    <span class="font-mono text-badge text-signal group-hover:underline">Open Email &rarr;</span>
                </a>

            </div>
        </div>
    </section>

    <!-- FAQ / TERMS -->
    <section class="py-24 bg-bone">
        <div class="max-w-3xl mx-auto px-6">
            <h3 class="font-mono text-badge text-softGrey text-center mb-12">The Fine Print</h3>
            
            <div class="space-y-4">
                
                <details class="bg-white rounded-xl border border-carbon/5 p-6 shadow-subtle group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                    <summary class="font-sans font-semibold text-ui text-carbon flex justify-between items-center outline-none">
                        Is there a limit to how many people I can refer?
                        <span class="text-signal font-mono text-lg group-open:rotate-45 transition-transform duration-200">+</span>
                    </summary>
                    <p class="mt-4 pt-4 border-t border-carbon/5 font-sans text-body text-softGrey">
                        Nope. Refer 12 people and you don't pay hosting for a whole year.
                    </p>
                </details>
                
                <details class="bg-white rounded-xl border border-carbon/5 p-6 shadow-subtle group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                    <summary class="font-sans font-semibold text-ui text-carbon flex justify-between items-center outline-none">
                        When do I get my free month?
                        <span class="text-signal font-mono text-lg group-open:rotate-45 transition-transform duration-200">+</span>
                    </summary>
                    <p class="mt-4 pt-4 border-t border-carbon/5 font-sans text-body text-softGrey">
                        As soon as your friend pays their setup fee, we credit your next billing cycle.
                    </p>
                </details>
                
                <details class="bg-white rounded-xl border border-carbon/5 p-6 shadow-subtle group cursor-pointer [&_summary::-webkit-details-marker]:hidden">
                    <summary class="font-sans font-semibold text-ui text-carbon flex justify-between items-center outline-none">
                        Can I refer myself for a second business?
                        <span class="text-signal font-mono text-lg group-open:rotate-45 transition-transform duration-200">+</span>
                    </summary>
                    <p class="mt-4 pt-4 border-t border-carbon/5 font-sans text-body text-softGrey">
                        Nice try - yes. If you own a second business, we'll treat it as a referral.
                    </p>
                </details>

            </div>
        </div>
    </section>

  </main>
  <Footer />
</Layout>