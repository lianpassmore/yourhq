---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';

const buildLink = "https://buy.stripe.com/00w00i6me14s4BLev9dZ604";

const testimonials = [
  { quote: "The process was stress-free, quick, foolproof and fun. The website is sleek and professional. I can't believe how good it is.", author: "Katie", role: "Rumours On Rust · Cafe, Whangārei", color: "border-hibiscus" },
  { quote: "You helped me take that next step and build my dream. That was my barrier to market.", author: "Nicolette", role: "Ember & Ice · Wellness Studio", color: "border-deepGreen" }
];
---

<Layout
  title="Websites for Cafes, Studios & Creatives NZ | Hand-Coded, Looked After Forever | YourHQ"
  description="Hand-coded websites for cafes, hospitality, studios, photographers, and creators. Your Instagram is your signal. Your website is the source. From $1,800 + GST. Looked after forever."
>
  <Navbar client:load />

  <main class="bg-paper min-h-screen">

    <!-- HERO -->
    <section class="pt-32 pb-20 border-b border-carbon bg-[size:40px_40px] bg-grid-pattern">
      <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <span class="inline-block py-1 px-3 rounded-full bg-hibiscus/10 text-hibiscus font-bold text-sm mb-6 tracking-wide uppercase font-mono">
            For Hospo &amp; Creatives
          </span>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[0.95] mb-8">
            Your Instagram Is Your Signal.<br/>
            <span class="text-hibiscus">Your Website Is the Source.</span>
          </h1>
          <p class="text-xl md:text-2xl text-gray-700 max-w-3xl leading-relaxed mb-2">
            Hand-coded websites for cafes, studios, photographers, and creators. Written in your voice. Built to feel like you walk through the door.
          </p>
          <p class="font-mono text-xs uppercase tracking-widest text-gray-500">
            From $1,800 + GST &middot; from $129/mo &middot; Built in Aotearoa &middot; Working worldwide
          </p>
        </div>
      </div>
    </section>

    <!-- THE PAIN -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-10 leading-tight">
          You've Built Something Beautiful.<br/>
          <span class="text-gray-400">It Deserves a Permanent Home.</span>
        </h2>
        <div class="space-y-6 text-lg text-carbon/90 leading-relaxed">
          <p>
            Your Instagram looks the part. Your space looks the part. The work itself looks the part. But there's no single place online where someone can land and get the whole picture.
          </p>
          <p>
            Social is rented. The algorithm decides who sees you. One platform change and your reach drops. One hacked account and your audience disappears.
          </p>
          <p>
            A website fixes that. It's the source. The thing that keeps existing whether you post today or not. The place every other digital path leads.
          </p>
          <p class="font-bold text-carbon">
            Your aesthetic, captured properly. Your story, told in your voice. Owned by you, unconditionally.
          </p>
        </div>
      </div>
    </section>

    <!-- BUILT FOR -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
            Built For People<br/>
            <span class="text-gray-400">Whose Aesthetic Is the Product.</span>
          </h2>
          <div class="grid md:grid-cols-2 gap-0 border-l border-t border-carbon">
            {[
              ['Cafes &amp; Restaurants', 'Independent hospitality with a vibe to match'],
              ['Wellness Studios', 'Yoga, pilates, recovery, therapy spaces'],
              ['Photographers', 'Portrait, wedding, brand, editorial'],
              ['Designers &amp; Stylists', 'Interior, fashion, brand'],
              ['Tattoo &amp; Body Art', 'Studios, residencies, traveling artists'],
              ['Speakers, Podcasters, Writers', 'Anyone whose name is the brand']
            ].map(([trade, sub]) => (
              <div class="bg-white border-r border-b border-carbon p-6">
                <p class="font-extrabold text-lg mb-1">{trade}</p>
                <p class="font-mono text-xs uppercase tracking-widest text-gray-500">{sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="py-24 bg-white border-b border-carbon">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-12 leading-tight">
          What You Get.<br/>
          <span class="text-gray-400">All In.</span>
        </h2>

        <ul class="space-y-5 text-lg text-carbon/90">
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-hibiscus text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">A site that captures the feeling, not just the facts.</p>
              <p class="text-base text-carbon/70">Written in your voice from the Drive-Home Interview. Reviewed by me before a line of code is written.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-hibiscus text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Socials embedded, content raid included.</p>
              <p class="text-base text-carbon/70">Instagram, Facebook, Threads, X, LinkedIn, whichever you use, brought across. I pull what's already on your socials. You don't dig through your camera roll.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-hibiscus text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Add bookings or payments when you need them.</p>
              <p class="text-base text-carbon/70">Calendly or Acuity embedded. Stripe wired in for deposits, session packs, or digital products. Power-Ups added at checkout.</p>
            </div>
          </li>
          <li class="flex gap-4 border-b border-carbon/10 pb-5">
            <span class="text-hibiscus text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Owned by you. Unconditionally.</p>
              <p class="text-base text-carbon/70">Domain in your name from day one. If you ever leave, you take everything.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-hibiscus text-2xl">&check;</span>
            <div>
              <p class="font-bold text-carbon">Refreshed every year, included.</p>
              <p class="text-base text-carbon/70">As your work evolves, your digital home evolves with it. New layout, new energy, no rebuild invoice.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="py-24 bg-paper border-b border-carbon">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter mb-16 text-center">
          Real Spaces. <span class="text-hibiscus">Real Stories.</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-8">
          {testimonials.map((t) => (
            <div class={`bg-white text-carbon p-8 border-l-8 ${t.color} shadow-hard-sm`}>
              <p class="text-lg italic leading-relaxed mb-6">"{t.quote}"</p>
              <div class="border-t border-carbon/10 pt-4">
                <p class="font-extrabold">{t.author}</p>
                <p class="font-mono text-xs text-gray-500 uppercase tracking-widest">{t.role}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="text-center mt-12">
          <a href="/portfolio" class="inline-block font-bold uppercase tracking-widest text-sm text-carbon border-b-2 border-hibiscus hover:text-hibiscus transition-colors">
            See the full portfolio &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-32 bg-carbon text-white text-center">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tighter mb-8 leading-tight">
          The Source. <span class="text-hibiscus">Built Properly.</span>
        </h2>
        <p class="text-xl text-gray-300 mb-12 leading-relaxed">
          One conversation. Live in 1 to 2 weeks.<br/>
          Hand-coded, in your voice, looked after forever.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={buildLink} class="inline-block bg-hibiscus text-white px-12 py-5 border-2 border-hibiscus hover:bg-transparent hover:text-white transition-colors font-bold uppercase tracking-widest text-lg">
            Start Your Build
          </a>
          <a href="/pricing" class="inline-block bg-transparent text-white px-12 py-5 border-2 border-white hover:bg-white hover:text-carbon transition-colors font-bold uppercase tracking-widest text-lg">
            See Pricing
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
