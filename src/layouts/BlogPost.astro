---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

type Props = {
  frontmatter: CollectionEntry<'blog'>['data'];
}

const { frontmatter } = Astro.props as Props;
---

<Layout title={`${frontmatter.title} | YourHQ Journal`} description={frontmatter.description}>
  <Navbar client:load />

  <main class="bg-bone min-h-screen pt-32 pb-24">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="mb-12 text-center">
        <div class="flex justify-center flex-wrap gap-2 mb-6">
          {frontmatter.tags.map((tag) => (
            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-deepGreen border border-carbon/15 rounded-full px-3 py-1">{tag}</span>
          ))}
        </div>
        <h1 class="font-serif text-4xl md:text-6xl tracking-tight leading-[1.05] text-carbon mb-6">
          {frontmatter.title}
        </h1>
        <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-softGrey">
          {frontmatter.pubDate.toLocaleDateString('en-NZ', { year: 'numeric', month: 'long', day: 'numeric' })}
          <span class="mx-2 text-terracotta">·</span>
          By {frontmatter.author}
        </p>
      </div>

      <!-- Featured Image -->
      {frontmatter.image && (
        <figure class="mb-16 rounded-3xl overflow-hidden border border-carbon/10 shadow-elegant bg-white">
          <img src={frontmatter.image} alt={frontmatter.title} class="w-full h-auto object-cover" />
        </figure>
      )}

      <!-- Content -->
      <div class="prose prose-lg max-w-none
                  prose-headings:font-serif prose-headings:tracking-tight prose-headings:text-carbon
                  prose-p:text-carbon/80 prose-p:leading-relaxed
                  prose-a:text-terracotta prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-carbon
                  prose-blockquote:border-l-2 prose-blockquote:border-terracotta prose-blockquote:not-italic prose-blockquote:font-serif prose-blockquote:text-carbon
                  prose-img:rounded-2xl prose-img:border prose-img:border-carbon/10 prose-img:shadow-subtle
                  prose-hr:border-carbon/10">
        <slot />
      </div>

      <!-- Back Button -->
      <div class="mt-20 pt-12 border-t border-carbon/10 text-center">
        <a href="/blog" class="inline-flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.15em] text-carbon border border-carbon/20 rounded-full px-8 py-3.5 hover:border-carbon hover:bg-carbon hover:text-bone transition-colors">
          ← Back to the Journal
        </a>
      </div>

    </article>
  </main>

  <Footer />
</Layout>
